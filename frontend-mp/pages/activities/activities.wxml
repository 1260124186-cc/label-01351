<view class="page-container">
  <view class="header">
    <view class="header-title">
      <text class="title-main">文化活动</text>
      <text class="title-sub">志愿招募 · 共筑传承</text>
    </view>
    <view class="header-actions">
      <view class="action-btn" bindtap="goToMyActivities" wx:if="{{isLoggedIn}}">
        <text class="action-icon">📋</text>
        <text class="action-text">我的活动</text>
      </view>
    </view>
  </view>

  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索活动" 
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
    <view class="admin-btn" bindtap="goToPublish">
      <text class="admin-icon">➕</text>
    </view>
  </view>

  <scroll-view class="filter-scroll" scroll-x enable-flex>
    <view class="filter-group">
      <text class="filter-label">类型:</text>
      <view 
        class="filter-item {{currentType === item.id ? 'active' : ''}}"
        wx:for="{{typeList}}"
        wx:key="id"
        bindtap="onTypeChange"
        data-id="{{item.id}}"
      >
        <text class="filter-icon">{{item.icon}}</text>
        <text class="filter-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view class="filter-scroll second" scroll-x enable-flex>
    <view class="filter-group">
      <text class="filter-label">状态:</text>
      <view 
        class="filter-item status-{{item.id}} {{currentStatus === item.id ? 'active' : ''}}"
        wx:for="{{statusList}}"
        wx:key="id"
        bindtap="onStatusChange"
        data-id="{{item.id}}"
      >
        <text class="filter-icon">{{item.icon}}</text>
        <text class="filter-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="activity-list">
    <view class="loading-wrap" wx:if="{{loading && activityList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-wrap" wx:elif="{{!loading && activityList.length === 0}}">
      <text class="empty-icon">🎭</text>
      <text class="empty-text">暂无活动</text>
      <text class="empty-hint">敬请期待更多精彩活动</text>
    </view>

    <view 
      class="activity-card"
      wx:for="{{activityList}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="activity-cover type-{{item.type}}">
        <text class="cover-emoji">{{item.typeIcon}}</text>
      </view>
      <view class="activity-content">
        <view class="activity-header">
          <view class="activity-type tag-{{item.type}}">
            {{item.typeName}}
          </view>
          <view class="activity-status status-badge-{{item.statusInfo.id}}" style="background-color: {{item.statusInfo.id === 'open' ? 'rgba(82,196,26,0.1)' : item.statusInfo.id === 'full' ? 'rgba(255,107,107,0.1)' : 'rgba(153,153,153,0.1)'}}; color: {{item.statusInfo.color}};">
            {{item.statusInfo.name}}
          </view>
        </view>
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-info">
          <view class="info-item">
            <text class="info-icon">🕐</text>
            <text class="info-text">{{item.timeDisplay}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">📍</text>
            <text class="info-text">{{item.location}}</text>
          </view>
          <view class="info-item">
            <text class="info-icon">👥</text>
            <text class="info-text">{{item.registeredCount}}/{{item.maxParticipants}}人</text>
          </view>
        </view>
        <view class="activity-summary">{{item.summary}}</view>
      </view>
    </view>

    <view class="load-more" wx:if="{{activityList.length > 0}}">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">— 已经到底了 —</text>
      <text wx:else bindtap="loadMore">点击加载更多</text>
    </view>
  </view>
</view>

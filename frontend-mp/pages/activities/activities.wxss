.page-container {
  min-height: 100vh;
  background-color: #FFF8DC;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 22rpx;
  color: #FFFFFF;
  margin-top: 4rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.search-placeholder {
  color: #999999;
}

.search-clear {
  font-size: 28rpx;
  color: #999999;
  padding: 8rpx;
}

.admin-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.admin-icon {
  font-size: 36rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 24rpx 16rpx;
}

.filter-scroll.second {
  padding-top: 0;
}

.filter-group {
  display: inline-flex;
  align-items: center;
}

.filter-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 12rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 20rpx;
  margin-right: 12rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.filter-item.active {
  background-color: #8B4513;
}

.filter-item.active .filter-name,
.filter-item.active .filter-icon {
  color: #FFFFFF;
}

.filter-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
  color: #666666;
}

.filter-name {
  font-size: 24rpx;
  color: #666666;
}

.activity-list {
  padding: 0 24rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EEEEEE;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.activity-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.activity-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.activity-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.type-lecture {
  background: linear-gradient(135deg, #FFB347 0%, #FFCC33 100%);
}

.type-study {
  background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%);
}

.type-craft {
  background: linear-gradient(135deg, #DEB887 0%, #D2691E 100%);
}

.cover-emoji {
  font-size: 56rpx;
}

.activity-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.activity-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.activity-type {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-lecture {
  background-color: rgba(255, 179, 71, 0.15);
  color: #E67E22;
}

.tag-study {
  background-color: rgba(70, 130, 180, 0.15);
  color: #4682B4;
}

.tag-craft {
  background-color: rgba(139, 69, 19, 0.15);
  color: #8B4513;
}

.activity-status {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.activity-info {
  margin-bottom: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.info-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-summary {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: #999999;
}

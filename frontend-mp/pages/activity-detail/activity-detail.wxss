.page-container {
  min-height: 100vh;
  background-color: #FFF8DC;
  padding-bottom: 160rpx;
}

.login-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.login-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.login-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.btn-login {
  width: 400rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EEEEEE;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999999;
}

.activity-header {
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 32rpx 32rpx;
}

.type-lecture {
  background: linear-gradient(135deg, #FFB347 0%, #FFCC33 100%);
}

.type-study {
  background: linear-gradient(135deg, #87CEEB 0%, #4682B4 100%);
}

.type-craft {
  background: linear-gradient(135deg, #DEB887 0%, #D2691E 100%);
}

.header-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
}

.header-info {
  flex: 1;
}

.header-type-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}

.header-status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.activity-body {
  padding: 32rpx;
}

.activity-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 32rpx;
}

.activity-meta {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.meta-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.meta-item:last-child {
  border-bottom: none;
}

.meta-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.meta-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.progress-bar {
  margin-top: 12rpx;
  height: 8rpx;
  background-color: #EEEEEE;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B4513 0%, #CD853F 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.activity-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.link-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border-radius: 20rpx;
}

.link-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.link-text {
  font-size: 24rpx;
  color: #8B4513;
}

.activity-description {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.review-list {
  display: flex;
  flex-direction: column;
}

.review-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-content {
  flex: 1;
  min-width: 0;
}

.review-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-author {
  font-size: 22rpx;
  color: #999999;
}

.review-actions {
  padding: 12rpx;
}

.unlink-icon {
  font-size: 28rpx;
  color: #999999;
}

.empty-review {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

.activity-stats {
  display: flex;
  padding: 24rpx 0;
  border-top: 1rpx solid #F5F5F5;
  margin-top: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.stat-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.stat-value {
  font-size: 26rpx;
  color: #999999;
}

.activity-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
}

.btn-register {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background-color: #FFFFFF;
  color: #FF6B6B;
  font-size: 32rpx;
  border: 2rpx solid #FF6B6B;
  border-radius: 44rpx;
  line-height: 84rpx;
}

.btn-registered {
  flex: 1;
  height: 88rpx;
  background-color: #F5F5F5;
  color: #999999;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.btn-ended {
  flex: 1;
  height: 88rpx;
  background-color: #F5F5F5;
  color: #999999;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.btn-full {
  flex: 1;
  height: 88rpx;
  background-color: #F5F5F5;
  color: #999999;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.btn-back {
  width: 300rpx;
  height: 80rpx;
  background-color: #8B4513;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  line-height: 80rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 36rpx;
  color: #999999;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  max-height: 60vh;
}

.empty-articles {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.article-option {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.article-option:last-child {
  border-bottom: none;
}

.article-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.article-meta {
  font-size: 22rpx;
  color: #999999;
}

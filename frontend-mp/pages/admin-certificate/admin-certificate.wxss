/* pages/admin-certificate/admin-certificate.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 120rpx;
}

/* 结果区域 */
.result-section {
  padding: 60rpx 32rpx;
  text-align: center;
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.15);
}

.result-card.success {
  border: 4rpx solid #52c41a;
}

.result-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #52c41a;
  margin-bottom: 12rpx;
}

.result-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-btn.primary {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
}

.result-btn.secondary {
  background: #f5f0e8;
  color: #8B4513;
}

/* 通用标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.section-title-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.preview-count {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: 500;
}

.selected-count {
  font-size: 24rpx;
  color: #1890ff;
}

/* 模式选择 */
.mode-section {
  padding-top: 20rpx;
}

.mode-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.mode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.mode-item.active {
  border-color: #8B4513;
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.1) 0%, rgba(160, 82, 45, 0.05) 100%);
}

.mode-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.mode-name {
  font-size: 22rpx;
  color: #333333;
  text-align: center;
}

.mode-item.active .mode-name {
  color: #8B4513;
  font-weight: bold;
}

/* 表单区域 */
.form-section {
  padding: 20rpx 32rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 6rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 12rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  box-sizing: border-box;
}

.input-placeholder {
  color: #cccccc;
}

.selected-users {
  margin-bottom: 20rpx;
}

.selected-scroll {
  white-space: nowrap;
}

.selected-user {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.picker-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #f5f0e8;
  border: 2rpx dashed #8B4513;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.picker-btn:active {
  background: #eee5d8;
}

.picker-btn-text {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: 500;
}

.picker-btn-arrow {
  font-size: 32rpx;
  color: #8B4513;
  margin-left: 8rpx;
}

.tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #1890ff;
  line-height: 1.5;
}

/* 预览区域 */
.preview-section {
  margin-top: 16rpx;
}

.preview-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx dashed #e0d5c8;
}

.preview-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f0e8;
}

.preview-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.preview-info {
  flex: 1;
}

.preview-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.preview-unit {
  font-size: 24rpx;
  color: #999999;
}

.preview-reason,
.preview-date,
.preview-related {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.reason-label {
  color: #999999;
}

.preview-users {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f0e8;
}

.users-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.users-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-tag {
  padding: 8rpx 20rpx;
  background: #f5f0e8;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #8B4513;
}

/* 提交按钮 */
.submit-section {
  padding: 40rpx 32rpx 0;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit[disabled] {
  background: #cccccc;
}

/* 弹窗通用 */
.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 80vh;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-actions {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.user-list {
  flex: 1;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #f5f0e8;
  transition: all 0.2s;
}

.user-item:active {
  background: #faf8f5;
}

.user-item.selected {
  background: rgba(139, 69, 19, 0.08);
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #999999;
}

.user-check {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #dddddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.user-item.selected .user-check {
  background: #8B4513;
  border-color: #8B4513;
}

.modal-footer {
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid #f0ebe3;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

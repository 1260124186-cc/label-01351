.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 未登录提示 */
.login-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E8B57;
}

.create-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 139, 87, 0.3);
}

.create-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 词条列表 */
.entry-list {
  padding: 0 24rpx 48rpx;
}

.entry-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.entry-hero {
  width: 140rpx;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-letter {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.entry-info {
  flex: 1;
  padding: 24rpx;
}

.entry-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.entry-category {
  padding: 6rpx 16rpx;
  background-color: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
}

.entry-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.entry-meta {
  display: flex;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-right: 32rpx;
}

.entry-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  flex: 1;
  padding: 14rpx 0;
  text-align: center;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-view {
  background-color: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
}

.action-edit {
  background-color: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.action-delete {
  background-color: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

/* 表单弹窗 */
.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.form-container {
  width: 90%;
  max-height: 85vh;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.form-close {
  font-size: 36rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

.form-scroll {
  flex: 1;
  padding: 0 32rpx;
  max-height: 60vh;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.required {
  color: #FF6B6B;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  min-height: 120rpx;
  box-sizing: border-box;
}

.content-area {
  min-height: 240rpx;
}

/* 标签组 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background-color: var(--color-bg);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border: 2rpx solid transparent;
}

.tag-item.active {
  background-color: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  border-color: #2E8B57;
}

/* 标签输入 */
.tag-input-wrap {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 26rpx;
}

.tag-add-btn {
  padding: 16rpx 32rpx;
  background-color: #2E8B57;
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 目录输入 */
.catalog-input-wrap {
  margin-bottom: 16rpx;
}

.catalog-level-select {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.level-btn {
  padding: 12rpx 32rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.level-btn.active {
  background-color: #2E8B57;
  color: #FFFFFF;
}

.catalog-input-row {
  display: flex;
  gap: 16rpx;
}

.catalog-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 26rpx;
}

.catalog-add-btn {
  padding: 16rpx 32rpx;
  background-color: #2E8B57;
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.catalog-list {
  background-color: var(--color-bg);
  border-radius: 12rpx;
  padding: 16rpx;
}

.catalog-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.catalog-item.level-1 {
  padding-left: 16rpx;
  font-weight: 500;
}

.catalog-item.level-2 {
  padding-left: 48rpx;
  font-size: 24rpx;
}

.catalog-item:active {
  background-color: rgba(255, 107, 107, 0.1);
}

.catalog-title {
  font-size: 26rpx;
  color: var(--color-text);
}

.catalog-remove {
  font-size: 24rpx;
  color: #FF6B6B;
}

/* 表单底部 */
.form-footer {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  border-top: 1rpx solid var(--color-border);
}

.btn-cancel {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.btn-submit {
  flex: 2;
  padding: 24rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.btn-submit.disabled {
  opacity: 0.5;
}

/* 已选项列表 */
.selected-items {
  margin-bottom: 16rpx;
}

.selected-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.selected-item-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.selected-item-remove {
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 4rpx 8rpx;
}

/* 选择器展开/收起 */
.picker-toggle {
  padding: 16rpx;
  text-align: center;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.picker-toggle-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* 选择器列表 */
.picker-list {
  max-height: 400rpx;
  overflow-y: auto;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  padding: 8rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 8rpx;
}

.picker-option:active {
  background-color: rgba(46, 139, 87, 0.05);
}

.picker-option.selected {
  background-color: rgba(46, 139, 87, 0.1);
}

.picker-checkbox {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--color-primary);
}

.picker-option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.picker-option-title {
  font-size: 26rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-option-meta {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.picker-empty {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 48rpx;
}

.login-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 12rpx;
}

.stats-pending {
  background: linear-gradient(135deg, #FFF3CD 0%, #FFE69C 100%);
}

.stats-approved {
  background: linear-gradient(135deg, #D4EDDA 0%, #A7E3B8 100%);
}

.stats-rejected {
  background: linear-gradient(135deg, #F8D7DA 0%, #F3A4AB 100%);
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.stats-value {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-text);
}

.status-tabs {
  display: flex;
  background-color: #FFFFFF;
  padding: 0 12rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.status-tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.status-tab.active {
  color: #2E8B57;
  font-weight: 500;
}

.status-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #2E8B57;
  border-radius: 3rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.draft-list {
  padding: 0 24rpx;
}

.draft-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.draft-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.draft-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-pending {
  background-color: rgba(255, 193, 7, 0.15);
  color: #E6A23C;
}

.status-approved {
  background-color: rgba(46, 139, 87, 0.15);
  color: #2E8B57;
}

.status-rejected {
  background-color: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
}

.draft-info {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.info-item {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.draft-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-view {
  background-color: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
}

.action-approve {
  background-color: rgba(46, 139, 87, 0.15);
  color: #2E8B57;
  font-weight: 500;
}

.action-reject {
  background-color: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
  font-weight: 500;
}

.action-detail {
  background-color: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

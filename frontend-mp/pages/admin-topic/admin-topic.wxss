.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.login-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.login-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.create-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

.create-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.topic-list {
  padding: 0 24rpx 48rpx;
}

.topic-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.topic-cover {
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.cover-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-align: center;
}

.topic-info {
  padding: 24rpx;
}

.topic-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.topic-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.topic-category {
  padding: 6rpx 16rpx;
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.topic-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.topic-meta {
  display: flex;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-right: 32rpx;
}

.topic-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.action-view {
  background-color: rgba(74, 144, 226, 0.1);
  color: #4A90E2;
}

.action-edit {
  background-color: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.action-delete {
  background-color: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.form-container {
  width: 90%;
  max-height: 85vh;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.form-close {
  font-size: 36rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

.form-scroll {
  flex: 1;
  max-height: 60vh;
}

.form-inner {
  padding: 0 32rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  overflow: hidden;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.required {
  color: #FF6B6B;
}

.form-input {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  min-height: 160rpx;
  box-sizing: border-box;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  background-color: var(--color-bg);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.tag-item.active {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
  border-color: #8B4513;
}

.tag-input-wrap {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag-input {
  display: block;
  flex: 1;
  min-width: 0;
  padding: 16rpx 20rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.tag-add-btn {
  padding: 16rpx 28rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.selected-items {
  margin-bottom: 12rpx;
}

.selected-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.selected-item-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.selected-item-remove {
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 4rpx 8rpx;
  flex-shrink: 0;
}

.select-btn {
  padding: 20rpx;
  text-align: center;
  border: 2rpx dashed var(--color-border);
  border-radius: 12rpx;
}

.select-btn-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.extended-field-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.extended-field-group .form-input {
  margin-bottom: 0;
}

.extended-list {
  margin-top: 8rpx;
}

.extended-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.extended-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-right: 12rpx;
}

.extended-text {
  font-size: 26rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.extended-source-label {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.extended-remove {
  font-size: 24rpx;
  color: #FF6B6B;
  padding: 4rpx 8rpx;
  flex-shrink: 0;
}

.form-footer {
  display: flex;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.btn-cancel {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.btn-submit {
  flex: 2;
  padding: 22rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.btn-submit.disabled {
  opacity: 0.5;
}

.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

.picker-panel {
  position: relative;
  width: 100%;
  max-height: 70vh;
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.picker-cancel {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx 16rpx;
}

.picker-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.picker-confirm {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.picker-scroll {
  flex: 1;
  padding: 8rpx 24rpx 32rpx;
  max-height: 58vh;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 8rpx;
}

.picker-option:active {
  background-color: rgba(139, 69, 19, 0.05);
}

.picker-option.selected {
  background-color: rgba(139, 69, 19, 0.08);
}

.picker-checkbox {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--color-primary);
  flex-shrink: 0;
}

.picker-option-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.picker-option-title {
  font-size: 26rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-option-meta {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.picker-empty {
  text-align: center;
  padding: 64rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

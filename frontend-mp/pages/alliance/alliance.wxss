/* pages/alliance/alliance.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 120rpx;
}

/* 顶部标题 */
.header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: bold;
  border-bottom: 4rpx solid var(--color-primary);
}

/* 内容区域 */
.content-section {
  padding: 24rpx;
}

/* 类型筛选 */
.type-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-filter-item {
  padding: 12rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all 0.2s;
}

.type-filter-item.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

/* 精选卡片 */
.featured-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.source-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  background-color: rgba(34, 139, 34, 0.1);
  color: var(--color-secondary);
}

.featured-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
}

.featured-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.featured-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.copyright-notice {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 16rpx;
}

/* 节点管理 */
.register-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.register-btn:active {
  background-color: #6B3410;
}

.node-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.node-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.node-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.node-status {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-approved {
  background-color: rgba(34, 139, 34, 0.1);
  color: #228B22;
}

.status-pending {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.status-rejected {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.node-info {
  margin-bottom: 16rpx;
}

.node-api {
  font-size: 24rpx;
  color: var(--color-text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: monospace;
  background-color: rgba(0, 0, 0, 0.03);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.node-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.approve {
  background-color: rgba(34, 139, 34, 0.1);
  color: #228B22;
}

.action-btn.reject {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.action-btn.remove {
  background-color: rgba(0, 0, 0, 0.05);
  color: var(--color-text-light);
}

/* 搜索 */
.search-section {
  padding: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.alliance-toggle {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.toggle-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-left: 12rpx;
}

.search-type-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-result-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-source {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  background-color: rgba(34, 139, 34, 0.1);
  color: var(--color-secondary);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  min-height: 200rpx;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.modal-btn-cancel {
  background-color: transparent;
  border: 2rpx solid var(--color-border);
  color: var(--color-text-secondary);
}

.modal-btn-submit {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.modal-btn-submit:active {
  background-color: #6B3410;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-light);
}

<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{authorName}}">
    <!-- 作者信息卡片 -->
    <view class="author-card">
      <view class="author-content">
        <view class="author-avatar">
          <image wx:if="{{authorAvatar}}" class="avatar-image" src="{{authorAvatar}}" mode="aspectFill" />
          <text wx:else class="avatar-text">{{authorName[0] || '作'}}</text>
        </view>
        <view class="author-info">
          <view class="author-name-row">
            <view class="author-name">{{authorName}}</view>
          </view>
          <view class="author-tip" wx:if="{{isSelf}}">
            <text class="tip-text">这是你的主页</text>
          </view>
        </view>
      </view>

      <!-- 统计数据 -->
      <view class="author-stats">
        <view class="stat-item">
          <text class="stat-value">{{articleCount}}</text>
          <text class="stat-label">投稿</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{likeCount}}</text>
          <text class="stat-label">获赞</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{viewCount}}</text>
          <text class="stat-label">阅读</text>
        </view>
      </view>

      <!-- 本人主页入口 -->
      <view class="self-entry" wx:if="{{isSelf}}" bindtap="goToMine">
        <view class="self-entry-left">
          <text class="self-icon">👤</text>
          <text class="self-text">查看我的页面</text>
        </view>
        <text class="self-arrow">›</text>
      </view>
    </view>

    <!-- Ta 的文章 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">Ta 的文章</text>
        <text class="section-count">共 {{articles.length}} 篇</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrap" wx:if="{{articles.length === 0}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无公开文章</text>
      </view>

      <!-- 文章列表 -->
      <view class="article-list" wx:else>
        <view
          class="article-item"
          wx:for="{{articles}}"
          wx:key="id"
          bindtap="goToDetail"
          data-id="{{item.id}}"
        >
          <view class="article-main">
            <view class="article-title">{{item.title}}</view>
            <view class="article-meta">
              <text class="meta-category tag-{{item.category}}">{{item.categoryName}}</text>
              <text class="meta-date">{{item.createTime}}</text>
            </view>
            <view class="article-summary" wx:if="{{item.summary}}">
              {{item.summary}}
            </view>
          </view>
          <view class="article-stats">
            <view class="mini-stat">
              <text class="mini-icon">👁</text>
              <text class="mini-value">{{item.viewCount}}</text>
            </view>
            <view class="mini-stat">
              <text class="mini-icon">👍</text>
              <text class="mini-value">{{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 错误状态 -->
  <view class="error-wrap" wx:else>
    <text class="error-icon">😕</text>
    <text class="error-text">作者不存在或已注销</text>
    <button class="btn-back" bindtap="goBack">返回</button>
  </view>
</view>

/* pages/author-home/author-home.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-light);
}

/* 作者信息卡片 */
.author-card {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 69, 19, 0.08);
}

.author-content {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.author-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.author-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
}

.author-tip {
  display: inline-flex;
}

.tip-text {
  font-size: 22rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 统计数据 */
.author-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 1rpx solid #f0ebe3;
  border-bottom: 1rpx solid #f0ebe3;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0ebe3;
}

/* 本人主页入口 */
.self-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.08) 0%, rgba(160, 82, 45, 0.04) 100%);
  border-radius: 16rpx;
  margin-top: 8rpx;
}

.self-entry-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.self-icon {
  font-size: 32rpx;
}

.self-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.self-arrow {
  font-size: 36rpx;
  color: var(--color-text-light);
}

/* 内容区块 */
.section {
  margin: 0 32rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.section-count {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-light);
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.article-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.06);
}

.article-main {
  flex: 1;
  min-width: 0;
}

.article-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.meta-category {
  display: inline-flex;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-folklore {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.tag-farming {
  background-color: rgba(34, 139, 34, 0.1);
  color: #228B22;
}

.tag-craft {
  background-color: rgba(70, 130, 180, 0.1);
  color: #4682B4;
}

.tag-memory {
  background-color: rgba(218, 165, 32, 0.1);
  color: #B8860B;
}

.meta-date {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.article-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.mini-stat {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.mini-icon {
  font-size: 22rpx;
  opacity: 0.6;
}

.mini-value {
  font-size: 22rpx;
  color: var(--color-text-light);
}

/* 错误状态 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.btn-back {
  padding: 20rpx 48rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

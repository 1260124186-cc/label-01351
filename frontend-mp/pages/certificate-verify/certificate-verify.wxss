/* pages/certificate-verify/certificate-verify.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 60rpx;
}

/* 顶部说明 */
.header-section {
  text-align: center;
  padding: 60rpx 48rpx 40rpx;
}

.header-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

/* 表单区域 */
.form-section {
  padding: 0 32rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.1);
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-item:last-of-type {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.input-wrapper {
  position: relative;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #8B4513;
  background: #ffffff;
}

.code-input {
  text-align: center;
  font-size: 40rpx;
  letter-spacing: 20rpx;
  font-weight: bold;
  color: #8B4513;
  font-family: monospace;
}

.input-placeholder {
  color: #cccccc;
  font-size: 28rpx;
  letter-spacing: 0;
  font-weight: normal;
  text-align: left;
}

.input-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  padding: 8rpx;
}

/* 历史记录下拉 */
.history-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  margin-top: 8rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #e0d5c8;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10rpx);
  transition: all 0.2s ease;
}

.history-dropdown.show {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f0e8;
}

.history-title {
  font-size: 24rpx;
  color: #999999;
}

.history-clear {
  font-size: 24rpx;
  color: #1890ff;
}

.history-list {
  max-height: 400rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #faf8f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #faf8f5;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  font-family: monospace;
}

/* 按钮 */
.btn-verify {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.btn-verify[disabled] {
  background: #cccccc;
}

.btn-reset {
  width: 100%;
  height: 72rpx;
  background: #f5f0e8;
  color: #8B4513;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 结果区域 */
.result-section {
  padding: 40rpx 32rpx 0;
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.result-card.success {
  border: 4rpx solid #52c41a;
}

.result-card.error {
  border: 4rpx solid #ff4d4f;
}

.result-header {
  text-align: center;
  margin-bottom: 20rpx;
}

.result-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-status {
  font-size: 36rpx;
  font-weight: bold;
}

.result-card.success .result-status {
  color: #52c41a;
}

.result-card.error .result-status {
  color: #ff4d4f;
}

.result-message {
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  padding: 0 20rpx;
}

.certificate-info {
  margin-top: 32rpx;
}

.info-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #e0d5c8 50%, transparent 100%);
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f0e8;
}

.info-row:last-of-type {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.valid {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-badge.revoked {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.status-badge.expired {
  background: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

/* 防伪信息 */
.anti-forgery-info {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #faf8f5;
  border-radius: 16rpx;
}

.forgery-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.forgery-item:last-child {
  margin-bottom: 0;
}

.forgery-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #999999;
}

.forgery-value {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
}

.forgery-value.valid {
  color: #52c41a;
}

.forgery-value.invalid {
  color: #ff4d4f;
}

.forgery-value.hash {
  font-family: monospace;
  font-size: 20rpx;
  color: #666666;
  word-break: break-all;
}

.btn-view-detail {
  width: 100%;
  height: 80rpx;
  margin-top: 32rpx;
  background: #ffffff;
  color: #8B4513;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #8B4513;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 说明区域 */
.tips-section {
  margin: 40rpx 32rpx 0;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tips-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.tips-list {
  padding-left: 8rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-dot {
  font-size: 24rpx;
  color: #8B4513;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.tips-content {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
}

.accept-banner {
  position: relative;
  padding: 20rpx 24rpx;
  background: linear-gradient(90deg, rgba(70, 130, 180, 0.15), rgba(70, 130, 180, 0.05));
  border-bottom: 1rpx solid rgba(70, 130, 180, 0.2);
}

.accept-banner-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.banner-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.banner-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.banner-texts {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.banner-title {
  font-size: 26rpx;
  color: #2c5f8d;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.banner-sub {
  font-size: 22rpx;
  color: #6c9ac0;
}

.banner-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.banner-btn {
  border-radius: 28rpx !important;
  font-size: 24rpx !important;
  padding: 0 28rpx !important;
  line-height: 56rpx !important;
  height: 56rpx !important;
}

.btn-approve {
  background: linear-gradient(135deg, #8B4513, #CD853F) !important;
  color: #FFFFFF !important;
  border: none !important;
}

.btn-refuse {
  background: #FFFFFF !important;
  color: #ff4d4f !important;
  border: 1rpx solid #ffccc7 !important;
}

.waiting-banner {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  background: rgba(250, 173, 20, 0.08);
  border-bottom: 1rpx solid rgba(250, 173, 20, 0.15);
}

.waiting-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
}

.waiting-text {
  font-size: 24rpx;
  color: #d48806;
  flex: 1;
}

.rejected-banner {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  background: rgba(255, 77, 79, 0.06);
  border-bottom: 1rpx solid rgba(255, 77, 79, 0.15);
}

.rejected-icon {
  font-size: 30rpx;
  margin-right: 12rpx;
}

.rejected-text {
  font-size: 24rpx;
  color: #ff4d4f;
  flex: 1;
}

.source-banner {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: rgba(139, 69, 19, 0.05);
  border-bottom: 1rpx solid rgba(139, 69, 19, 0.08);
}

.source-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}

.source-text {
  font-size: 22rpx;
  color: #8B4513;
}

.chat-scroll {
  flex: 1;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

.chat-loading,
.empty-messages {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid #e0d5c8;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.empty-icon {
  font-size: 90rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.messages-wrap {
  padding-bottom: 20rpx;
}

.msg-date-sep {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 20rpx;
}

.msg-date-text {
  font-size: 22rpx;
  color: #bbbbbb;
  padding: 6rpx 18rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 16rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.msg-mine {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D2B48C, #8B4513);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-mine {
  background: linear-gradient(135deg, #CD853F, #8B4513);
}

.msg-avatar .avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.msg-mine .msg-avatar {
  margin-left: 14rpx;
}

.msg-other .msg-avatar {
  margin-right: 14rpx;
}

.msg-body {
  max-width: 70%;
  min-width: 0;
}

.msg-sender {
  margin-bottom: 6rpx;
  padding-left: 4rpx;
}

.sender-name {
  font-size: 22rpx;
  color: #999999;
}

.msg-bubble {
  display: inline-block;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  word-break: break-word;
  line-height: 1.6;
  position: relative;
  max-width: 100%;
  box-sizing: border-box;
}

.msg-mine .msg-bubble {
  background: linear-gradient(135deg, #FFF4E0 0%, #FFE4B5 100%);
  color: #5c3a1a;
}

.bubble-stranger {
  border: 2rpx dashed rgba(70, 130, 180, 0.4);
  background: rgba(70, 130, 180, 0.04) !important;
}

.msg-mine .bubble-stranger {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.12) 0%, rgba(250, 173, 20, 0.06) 100%) !important;
  border: 2rpx dashed rgba(250, 173, 20, 0.4);
}

.stranger-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #4682B4;
  font-weight: 700;
  background: rgba(70, 130, 180, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.tag-mine {
  color: #d48806;
  background: rgba(250, 173, 20, 0.15);
}

.msg-text {
  font-size: 28rpx;
  color: #333333;
  white-space: pre-wrap;
}

.msg-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 10rpx;
}

.msg-mine .msg-meta {
  justify-content: flex-end;
}

.msg-time {
  font-size: 20rpx;
  color: #bbbbbb;
}

.msg-read {
  font-size: 20rpx;
  color: #faad14;
}

.scroll-bottom-anchor {
  height: 1rpx;
  width: 100%;
}

.input-bar {
  display: flex;
  align-items: flex-end;
  padding: 16rpx 16rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #f0ebe3;
  position: relative;
}

.input-disabled {
  opacity: 0.6;
  pointer-events: none;
}

.input-left {
  padding-right: 12rpx;
  flex-shrink: 0;
}

.more-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0 !important;
  line-height: 72rpx !important;
  border-radius: 50% !important;
  background: #f5f0e8 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none !important;
  font-size: 0 !important;
}

.more-btn::after {
  border: none;
}

.more-icon {
  font-size: 40rpx;
  color: #8B4513;
  font-weight: 700;
  letter-spacing: -4rpx;
  line-height: 1;
}

.input-wrap {
  flex: 1;
  background: #f8f5f0;
  border-radius: 36rpx;
  padding: 14rpx 24rpx;
  margin-right: 12rpx;
  min-height: 72rpx;
  max-height: 240rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.chat-input {
  width: 100%;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  max-height: 200rpx;
}

.input-right {
  flex-shrink: 0;
}

.send-btn {
  min-width: 140rpx;
  height: 72rpx;
  padding: 0 28rpx !important;
  line-height: 72rpx !important;
  border-radius: 36rpx !important;
  font-size: 26rpx !important;
  font-weight: 600;
  background: #e0d5c8 !important;
  color: #999999 !important;
  border: none !important;
}

.send-btn::after {
  border: none;
}

.send-active {
  background: linear-gradient(135deg, #8B4513, #CD853F) !important;
  color: #FFFFFF !important;
  box-shadow: 0 4rpx 14rpx rgba(139, 69, 19, 0.25);
}

.char-count {
  position: absolute;
  top: -2rpx;
  right: 180rpx;
  transform: translateY(-100%);
  padding: 2rpx 12rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 14rpx;
}

.count-text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
}

.mask-show {
  opacity: 1;
  pointer-events: auto;
}

.more-sheet,
.report-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f5f1ea;
  flex-shrink: 0;
}

.sheet-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 700;
}

.sheet-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f5f0e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999999;
}

.sheet-body {
  flex: 1;
  padding: 20rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
}

.sheet-item {
  display: flex;
  align-items: center;
  padding: 26rpx 20rpx;
  border-radius: 18rpx;
  transition: background-color 0.15s;
  margin-bottom: 8rpx;
}

.sheet-item:active {
  background: #f8f5f0;
}

.sheet-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 56rpx;
  text-align: center;
}

.sheet-label {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.sheet-danger .sheet-label {
  color: #ff4d4f;
}

.report-section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.reason-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reason-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #faf7f2;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  transition: all 0.15s;
}

.reason-selected {
  background: rgba(139, 69, 19, 0.08);
  border-color: #8B4513;
}

.reason-icon {
  font-size: 30rpx;
  margin-right: 14rpx;
}

.reason-name {
  flex: 1;
  font-size: 26rpx;
  color: #555555;
}

.reason-selected .reason-name {
  color: #8B4513;
  font-weight: 600;
}

.reason-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #8B4513;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.desc-wrap {
  background: #faf7f2;
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  position: relative;
}

.desc-input {
  width: 100%;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
  min-height: 160rpx;
  max-height: 300rpx;
}

.desc-count {
  position: absolute;
  right: 22rpx;
  bottom: 12rpx;
  font-size: 20rpx;
  color: #bbbbbb;
}

.report-tip {
  display: flex;
  align-items: flex-start;
  padding: 18rpx 20rpx;
  background: rgba(250, 173, 20, 0.06);
  border-radius: 14rpx;
  margin-top: 16rpx;
}

.tip-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 22rpx;
  color: #ad6800;
  line-height: 1.6;
  flex: 1;
}

.sheet-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f1ea;
  background: #FFFFFF;
  flex-shrink: 0;
}

.sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx !important;
  border-radius: 44rpx !important;
  font-size: 28rpx !important;
  font-weight: 600;
  border: none !important;
}

.sheet-btn::after {
  border: none;
}

.btn-cancel {
  background: #f5f0e8 !important;
  color: #666666 !important;
}

.btn-submit {
  background: linear-gradient(135deg, #8B4513, #CD853F) !important;
  color: #FFFFFF !important;
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.2);
}

.btn-disabled {
  opacity: 0.5;
  box-shadow: none !important;
}

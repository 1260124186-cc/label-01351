.page-container {
  min-height: 100vh;
  background-color: #FFF8DC;
  padding-bottom: 40rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F5E6D3;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.cover-section {
  position: relative;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.cover-section.type-figure {
  background: linear-gradient(135deg, #FF9800 0%, #FFB74D 100%);
}
.cover-section.type-memory {
  background: linear-gradient(135deg, #2196F3 0%, #64B5F6 100%);
}
.cover-section.type-craft {
  background: linear-gradient(135deg, #9C27B0 0%, #BA68C8 100%);
}
.cover-section.type-folklore {
  background: linear-gradient(135deg, #FFC107 0%, #FFD54F 100%);
}
.cover-section.type-farming {
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
}
.cover-section.type-other {
  background: linear-gradient(135deg, #757575 0%, #9E9E9E 100%);
}

.cover-emoji {
  position: absolute;
  font-size: 280rpx;
  opacity: 0.15;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.cover-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.4) 100%);
}

.cover-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
}

.cover-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.cover-type {
  padding: 8rpx 20rpx;
  background-color: rgba(255,255,255,0.25);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
}

.cover-status {
  padding: 8rpx 20rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.cover-urgent {
  padding: 8rpx 20rpx;
  background-color: #FF4757;
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.cover-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.cover-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.author-icon {
  font-size: 24rpx;
}

.author-name {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.author-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.progress-card {
  margin: -40rpx 32rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.15);
  position: relative;
  z-index: 10;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.achievement-badge {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #1890FF 0%, #40A9FF 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.progress-numbers {
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 28rpx;
}

.number-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.number-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B4513;
}

.number-value.target {
  color: #666;
}

.number-value.urgent {
  color: #FF4757;
}

.number-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.number-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #EEE;
}

.progress-bar-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #F5E6D3;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-percent {
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  min-width: 80rpx;
  text-align: right;
}

.deadline-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin: 0 32rpx 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #FFFFFF;
}

.action-btn.primary.disabled {
  background: #CCC;
  color: #FFFFFF;
}

.action-btn.secondary {
  background: linear-gradient(135deg, #1890FF 0%, #40A9FF 100%);
  color: #FFFFFF;
}

.action-btn.danger {
  flex: 0.6;
  background-color: #FFF1F0;
  color: #FF4757;
  border: 1rpx solid #FFCCC7;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.info-section {
  margin: 0 32rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.info-content {
  padding: 0 4rpx;
}

.info-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  font-size: 24rpx;
  color: #CD853F;
  background-color: rgba(205, 133, 63, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #FAFAFA;
  border-radius: 16rpx;
}

.article-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5E6D3;
}

.article-image {
  width: 100%;
  height: 100%;
}

.article-emoji {
  font-size: 48rpx;
}

.article-info {
  flex: 1;
  min-width: 0;
}

.article-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.article-arrow {
  font-size: 40rpx;
  color: #CCC;
  margin-left: 12rpx;
}

.empty-articles {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.empty-articles .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-articles .empty-text {
  font-size: 24rpx;
}

.bottom-space {
  height: 40rpx;
}

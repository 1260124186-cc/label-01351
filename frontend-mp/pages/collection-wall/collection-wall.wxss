.page-container {
  min-height: 100vh;
  background-color: #FFF8DC;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 22rpx;
  color: #FFFFFF;
  margin-top: 4rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.1);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

.admin-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.admin-icon {
  font-size: 36rpx;
  color: #FFFFFF;
}

.urgent-section,
.hot-section {
  margin: 0 32rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(139, 69, 19, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-toggle {
  font-size: 24rpx;
  color: #999;
}

.urgent-scroll {
  white-space: nowrap;
  padding: 24rpx 28rpx;
}

.urgent-card {
  display: inline-block;
  width: 360rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE8E8 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  vertical-align: top;
}

.urgent-card:last-child {
  margin-right: 0;
}

.urgent-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.urgent-type-icon {
  font-size: 36rpx;
}

.urgent-status-badge {
  font-size: 22rpx;
  font-weight: bold;
}

.urgent-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.urgent-progress-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.urgent-progress-bar {
  flex: 1;
  height: 12rpx;
  background-color: rgba(255, 107, 107, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.urgent-progress-fill {
  height: 100%;
  background-color: #FF6B6B;
  border-radius: 6rpx;
}

.urgent-progress-text {
  font-size: 22rpx;
  color: #FF6B6B;
  font-weight: bold;
}

.hot-list {
  padding: 12rpx 0;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-rank.rank-1 {
  background-color: #FF4757;
}

.hot-rank.rank-2 {
  background-color: #FF6B81;
}

.hot-rank.rank-3 {
  background-color: #FFA502;
}

.hot-rank.rank-4,
.hot-rank.rank-5 {
  background-color: #A4B0BE;
}

.hot-content {
  flex: 1;
  min-width: 0;
}

.hot-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.hot-type-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.hot-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-meta {
  display: flex;
  gap: 24rpx;
}

.hot-meta-item {
  font-size: 22rpx;
  color: #999;
}

.hot-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 16rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 32rpx 16rpx;
}

.filter-scroll.second,
.filter-scroll.third {
  padding-top: 0;
  padding-bottom: 16rpx;
}

.filter-group {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 4rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.06);
}

.filter-item.active {
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
}

.filter-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.filter-name {
  font-size: 26rpx;
  color: #666;
}

.filter-item.active .filter-name {
  color: #FFFFFF;
}

.collection-list {
  padding: 8rpx 32rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F5E6D3;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

.collection-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
}

.collection-card.urgent-card-bg {
  border: 2rpx solid #FF6B6B;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F9 100%);
}

.collection-cover {
  width: 180rpx;
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.collection-cover.type-figure {
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4B8 100%);
}

.collection-cover.type-memory {
  background: linear-gradient(135deg, #E8F4FD 0%, #C9E4F6 100%);
}

.collection-cover.type-craft {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}

.collection-cover.type-folklore {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.collection-cover.type-farming {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.collection-cover.type-other {
  background: linear-gradient(135deg, #F5F5F5 0%, #E0E0E0 100%);
}

.cover-emoji {
  font-size: 64rpx;
}

.collection-content {
  flex: 1;
  padding: 24rpx;
  min-width: 0;
}

.collection-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.collection-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.collection-type.tag-figure {
  background-color: rgba(255, 152, 0, 0.15);
  color: #FF9800;
}

.collection-type.tag-memory {
  background-color: rgba(33, 150, 243, 0.15);
  color: #2196F3;
}

.collection-type.tag-craft {
  background-color: rgba(156, 39, 176, 0.15);
  color: #9C27B0;
}

.collection-type.tag-folklore {
  background-color: rgba(255, 193, 7, 0.15);
  color: #FFC107;
}

.collection-type.tag-farming {
  background-color: rgba(76, 175, 80, 0.15);
  color: #4CAF50;
}

.collection-type.tag-other {
  background-color: rgba(158, 158, 158, 0.15);
  color: #9E9E9E;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.urgent-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background-color: #FF4757;
  color: #FFFFFF;
  font-weight: bold;
}

.collection-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-section {
  margin-bottom: 16rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.progress-count {
  font-size: 26rpx;
  font-weight: bold;
  color: #8B4513;
}

.progress-days {
  font-size: 24rpx;
  color: #666;
}

.progress-days.ended {
  color: #999;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 14rpx;
  background-color: #F5E6D3;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s;
}

.progress-percent {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  min-width: 70rpx;
  text-align: right;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag-item {
  font-size: 22rpx;
  color: #CD853F;
  background-color: rgba(205, 133, 63, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.collection-summary {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.collection-footer {
  display: flex;
  gap: 24rpx;
}

.footer-item {
  display: flex;
  align-items: center;
}

.footer-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more text {
  font-size: 24rpx;
  color: #999;
}

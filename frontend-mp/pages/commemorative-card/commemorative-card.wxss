.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5E6D3 0%, #FFF8F0 50%, #F5E6D3 100%);
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8D5C4;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #A0522D;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #A0522D;
}

.card-wrapper {
  padding: 40rpx 32rpx;
}

.card-outer {
  position: relative;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 30%, #CD853F 70%, #DAA520 100%);
  border-radius: 24rpx;
  padding: 8rpx;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.3);
}

.card-border-decor {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #DAA520;
  border-style: solid;
  z-index: 2;
}

.top-left {
  top: 16rpx;
  left: 16rpx;
  border-width: 4rpx 0 0 4rpx;
  border-radius: 8rpx 0 0 0;
}

.top-right {
  top: 16rpx;
  right: 16rpx;
  border-width: 4rpx 4rpx 0 0;
  border-radius: 0 8rpx 0 0;
}

.bottom-left {
  bottom: 16rpx;
  left: 16rpx;
  border-width: 0 0 4rpx 4rpx;
  border-radius: 0 0 0 8rpx;
}

.bottom-right {
  bottom: 16rpx;
  right: 16rpx;
  border-width: 0 4rpx 4rpx 0;
  border-radius: 0 0 8rpx 0;
}

.card-inner {
  background: linear-gradient(180deg, #FFFBF5 0%, #FFF5E6 100%);
  border-radius: 20rpx;
  padding: 48rpx 36rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.header-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #CD853F, transparent);
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  padding: 0 24rpx;
  letter-spacing: 8rpx;
}

.person-section {
  margin-bottom: 24rpx;
}

.person-label {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 24rpx;
  color: #CD853F;
  letter-spacing: 4rpx;
  padding: 4rpx 20rpx;
  border: 1rpx solid #CD853F;
  border-radius: 16rpx;
}

.person-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.person-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #CD853F;
  margin-bottom: 12rpx;
}

.person-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}

.divider-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx 0;
}

.divider-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #A0522D, transparent);
}

.divider-icon {
  font-size: 36rpx;
  margin: 0 20rpx;
}

.skill-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 36rpx 0;
  padding: 20rpx 0;
  border-top: 1rpx dashed #CD853F;
  border-bottom: 1rpx dashed #CD853F;
}

.skill-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.skill-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #A0522D;
  letter-spacing: 4rpx;
}

.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 36rpx 0;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #A0522D;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #CD853F;
}

.time-section {
  text-align: center;
  margin: 24rpx 0;
}

.time-text {
  font-size: 24rpx;
  color: #A0522D;
  letter-spacing: 2rpx;
}

.card-bottom-decor {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
}

.decor-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #DAA520, transparent);
}

.decor-symbol {
  font-size: 28rpx;
  color: #DAA520;
  margin: 0 16rpx;
}

.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
}

.save-btn {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.3);
}

.share-btn {
  background: linear-gradient(135deg, #A0522D, #DAA520);
  box-shadow: 0 8rpx 24rpx rgba(160, 82, 45, 0.3);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea.tall {
  min-height: 240rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-chip {
  padding: 12rpx 20rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.category-chip.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.difficulty-row {
  display: flex;
  gap: 16rpx;
}

.difficulty-chip {
  padding: 12rpx 24rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.difficulty-chip.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.selected-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.selected-tool {
  padding: 8rpx 16rpx;
  background: rgba(139, 69, 19, 0.1);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
}

.tool-toggle {
  padding: 12rpx 20rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tool-chip {
  padding: 10rpx 16rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.tool-chip.active {
  background: rgba(139, 69, 19, 0.15);
  color: #8B4513;
  font-weight: 500;
  border: 1rpx solid #8B4513;
}

.list-items {
  margin-bottom: 16rpx;
}

.list-item {
  position: relative;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.step-item {
  border-left: 4rpx solid #8B4513;
}

.step-badge {
  font-size: 22rpx;
  color: #8B4513;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.item-main {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.item-spec {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.item-qty {
  font-size: 24rpx;
  color: #8B4513;
  margin-left: auto;
}

.item-note {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.caution-note {
  color: #B8860B;
}

.item-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 4rpx 8rpx;
}

.add-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(139, 69, 19, 0.03);
  border-radius: 12rpx;
  border: 1rpx dashed rgba(139, 69, 19, 0.2);
}

.add-input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.add-input.short {
  width: 50%;
}

.add-textarea {
  width: 100%;
  min-height: 100rpx;
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.add-btn {
  padding: 14rpx 0;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.add-btn.small {
  width: 80rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  flex-shrink: 0;
}

.reading-type-row {
  display: flex;
  gap: 10rpx;
}

.type-chip {
  padding: 8rpx 16rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.type-chip.active {
  background: rgba(139, 69, 19, 0.1);
  color: #8B4513;
  font-weight: 500;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(139, 69, 19, 0.08);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
  gap: 8rpx;
}

.tag-remove {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.tag-input-row {
  display: flex;
  gap: 12rpx;
}

.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.6;
}

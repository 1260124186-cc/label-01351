.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.detail-hero {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.hero-meta {
  display: flex;
  gap: 12rpx;
}

.meta-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.category-badge {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
}

.difficulty-badge {
  background: rgba(46, 139, 87, 0.3);
  color: #FFFFFF;
}

.hero-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.hero-summary {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.hero-info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.info-icon {
  margin-right: 6rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 6rpx 14rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #FFFFFF;
}

.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow-x: auto;
}

.tab-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
  min-width: 0;
  flex: 1;
}

.tab-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.tab-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.tab-item.active .tab-name {
  color: #FFFFFF;
  font-weight: 500;
}

.tab-content {
  padding: 24rpx;
}

.section-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.section-body {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.reading-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reading-item {
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

.reading-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.reading-type {
  margin-right: 10rpx;
  font-size: 28rpx;
}

.reading-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reading-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.relation-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.relation-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

.relation-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.relation-info {
  flex: 1;
}

.relation-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.relation-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-light);
}

.relation-arrow {
  font-size: 36rpx;
  color: var(--color-text-light);
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.material-item {
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

.material-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.material-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.material-quantity {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: 500;
}

.material-spec {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
}

.material-note {
  font-size: 24rpx;
  color: var(--color-text-light);
  line-height: 1.5;
}

.tool-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tool-tag {
  padding: 10rpx 20rpx;
  background: rgba(139, 69, 19, 0.08);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #8B4513;
}

.process-list {
  padding-left: 16rpx;
}

.process-item {
  display: flex;
  margin-bottom: 8rpx;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  width: 56rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-line {
  width: 4rpx;
  flex: 1;
  background: linear-gradient(to bottom, #CD853F, #DEB887);
  min-height: 32rpx;
  margin: 8rpx 0;
}

.process-info {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.step-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.step-keypoint {
  margin-bottom: 10rpx;
}

.keypoint-label {
  display: inline-block;
  padding: 4rpx 10rpx;
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
  font-size: 22rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.keypoint-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.step-caution {
  margin-bottom: 8rpx;
}

.caution-label {
  font-size: 22rpx;
  color: #DAA520;
}

.caution-text {
  font-size: 26rpx;
  color: #B8860B;
  line-height: 1.6;
}

.step-duration {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 8rpx;
}

.mistake-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mistake-item {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #DAA520;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mistake-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.mistake-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.mistake-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #B8860B;
}

.mistake-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.empty-mistakes,
.empty-reviews {
  text-align: center;
  padding: 40rpx 0;
}

.empty-mistakes .empty-text,
.empty-reviews .empty-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.review-header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.review-count {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}

.review-add-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.review-input-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rating-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.rating-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 36rpx;
  color: #DDD;
}

.star.active {
  color: #FFB800;
}

.review-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.review-submit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.char-count {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.submit-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-item {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.review-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.review-time {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-light);
}

.review-rating {
  display: flex;
}

.review-rating .star {
  font-size: 24rpx;
}

.review-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.checkin-btn.checked .action-text {
  color: #2E8B57;
}

.share-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: none;
  margin: 0;
  padding: 0;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.share-text {
  font-size: 30rpx;
}

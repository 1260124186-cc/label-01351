.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 40rpx;
}

.header-banner {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.banner-content {
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.search-bar {
  padding: 24rpx 24rpx 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-light);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 24rpx 24rpx 8rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-right: 12rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  min-width: 100rpx;
}

.category-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.category-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.category-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.category-item.active .category-name {
  color: #FFFFFF;
  font-weight: 500;
}

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx 8rpx;
}

.filter-left {
  flex: 1;
  overflow: hidden;
}

.difficulty-scroll {
  white-space: nowrap;
}

.difficulty-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  margin-right: 12rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.difficulty-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.filter-right {
  margin-left: 16rpx;
}

.sort-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sort-arrow {
  font-size: 18rpx;
  margin-left: 6rpx;
}

.sort-dropdown {
  margin: 0 24rpx 8rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  gap: 8rpx;
  position: relative;
  z-index: 10;
}

.sort-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  border-radius: 8rpx;
}

.sort-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.tutorial-list {
  padding: 0 24rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.tutorial-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  gap: 12rpx;
}

.meta-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.category-badge {
  background: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.difficulty-badge {
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.card-stats {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.card-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-info-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 4rpx 12rpx;
  background: rgba(139, 69, 19, 0.06);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #A0522D;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
}

<!--pages/detail/detail.wxml-->
<view class="page-container">
  <!-- 未登录状态 -->
  <view class="login-wrap" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-icon">👤</text>
      <text class="login-text">登录后查看文章详情</text>
      <button class="btn-login" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 加载状态 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 文章内容 -->
    <view class="article-wrap" wx:elif="{{article}}">
      <!-- 分类标签 -->
      <view class="article-category tag-{{article.category}}">
        {{article.categoryName}}
      </view>

      <!-- 标题 -->
      <view class="article-title">{{article.title}}</view>

      <!-- 作者信息 -->
      <view class="article-meta">
        <view class="meta-author">
          <view class="author-avatar">
            <text class="avatar-text">{{article.authorName[0]}}</text>
          </view>
          <text class="author-name">{{article.authorName}}</text>
        </view>
        <text class="meta-date">{{article.createTime}}</text>
      </view>

      <!-- 文章正文 -->
      <view class="article-content">{{article.content}}</view>

      <!-- 文章统计 -->
      <view class="article-stats-section">
        <view class="stat-item">
          <text class="stat-icon">👁</text>
          <text class="stat-value">{{article.viewCount}} 阅读</text>
        </view>
        <view class="stat-item">
          <text class="stat-icon">👍</text>
          <text class="stat-value">{{article.likeCount}} 点赞</text>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="article-footer">
      <view class="footer-actions">
        <button class="btn-favorite {{favorited ? 'favorited' : ''}}" bindtap="onFavorite">
          <text class="favorite-icon">{{favorited ? '⭐' : '☆'}}</text>
          <text class="favorite-text">{{favorited ? '已收藏' : '收藏'}}</text>
        </button>
        <button class="btn-like {{liked ? 'liked' : ''}}" bindtap="onLike">
          <text class="like-icon">{{liked ? '❤️' : '🤍'}}</text>
          <text class="like-text">{{liked ? '已点赞' : '点赞'}}</text>
        </button>
      </view>
    </view>

    <!-- 错误状态 -->
    <view class="error-wrap" wx:else>
      <text class="error-icon">😕</text>
      <text class="error-text">文章不存在或已删除</text>
      <button class="btn-back" bindtap="goBack">返回首页</button>
    </view>
  </block>
</view>

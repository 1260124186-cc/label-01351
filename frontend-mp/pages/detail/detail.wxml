<!--pages/detail/detail.wxml-->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 文章内容 -->
  <view class="article-wrap" wx:elif="{{article}}">
    <!-- 分类标签 -->
    <view class="article-category tag-{{article.category}}">
      {{article.categoryName}}
    </view>

    <!-- 标题 -->
    <view class="article-title">{{article.title}}</view>

    <!-- 标签列表 -->
    <view class="article-tags" wx:if="{{article.tags && article.tags.length > 0}}">
      <view
        class="article-tag-item"
        wx:for="{{article.tags}}"
        wx:key="*this"
        wx:for-item="tag"
        bindtap="onTagClick"
        data-tag="{{tag}}"
      >
        <text>#{{tag}}</text>
      </view>
    </view>

    <!-- 摘要 -->
    <view class="article-summary" wx:if="{{article.summary}}">
      <text class="summary-label">摘要：</text>
      <text class="summary-text">{{article.summary}}</text>
    </view>

    <!-- 作者信息 -->
    <view class="article-meta">
      <view class="meta-author clickable" bindtap="goToAuthorHome" data-authorid="{{article.authorId}}">
        <view class="author-avatar">
          <text class="avatar-text">{{article.authorName[0]}}</text>
        </view>
        <text class="author-name author-link">{{article.authorName}}</text>
        <text class="author-arrow">›</text>
      </view>
      <text class="meta-date">{{article.createTime}}</text>
    </view>

    <!-- 文章正文 -->
    <view class="article-content">{{article.content}}</view>

    <!-- 文章统计 -->
    <view class="article-stats-section">
      <view class="stat-item">
        <text class="stat-icon">👁</text>
        <text class="stat-value">{{article.viewCount}} 阅读</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">👍</text>
        <text class="stat-value">{{article.likeCount}} 点赞</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">💬</text>
        <text class="stat-value">{{article.commentCount || 0}} 评论</text>
      </view>
      <view class="stat-item report-action" bindtap="onReportTap">
        <text class="stat-icon">🚨</text>
        <text class="stat-value">举报</text>
      </view>
    </view>

      <!-- 评论区 -->
      <view class="comment-section">
        <view class="comment-header">
          <text class="comment-title">评论 ({{article.commentCount || 0}})</text>
        </view>

        <!-- 评论列表 -->
        <view class="comment-list" wx:if="{{comments.length > 0}}">
          <block wx:for="{{comments}}" wx:key="id" wx:for-item="comment">
            <view class="comment-item">
              <view class="comment-header-row">
                <view class="comment-avatar">
                  <text class="comment-avatar-text">{{comment.authorName[0]}}</text>
                </view>
                <view class="comment-info">
                  <view class="comment-author-row">
                    <text class="comment-author-name comment-author-link" bindtap="goToAuthorHome" data-authorid="{{comment.authorId}}">{{comment.authorName}}</text>
                    <text class="author-tag" wx:if="{{comment.isAuthor}}">作者</text>
                  </view>
                  <text class="comment-time">{{comment.relativeTime}}</text>
                </view>
              </view>

              <view class="comment-content">{{comment.content}}</view>

              <view class="comment-actions">
                <view class="comment-action" bindtap="onCommentLike" data-commentid="{{comment.id}}" data-isliked="{{comment.isLiked}}">
                  <text class="action-icon">{{comment.isLiked ? '❤️' : '🤍'}}</text>
                  <text class="action-text">{{comment.likeCount || 0}}</text>
                </view>
                <view class="comment-action" bindtap="onReplyTap" data-commentid="{{comment.id}}" data-authorid="{{comment.authorId}}" data-authorname="{{comment.authorName}}">
                  <text class="action-icon">💬</text>
                  <text class="action-text">回复</text>
                </view>
                <view class="comment-action delete-action" wx:if="{{comment.canDelete}}" bindtap="onDeleteComment" data-commentid="{{comment.id}}">
                  <text class="action-icon">🗑</text>
                  <text class="action-text">删除</text>
                </view>
              </view>

              <!-- 回复列表 -->
              <view class="reply-list" wx:if="{{comment.replies && comment.replies.length > 0}}">
                <block wx:for="{{comment.replies}}" wx:key="id" wx:for-item="reply">
                  <view class="reply-item">
                    <view class="reply-header">
                      <view class="reply-avatar">
                        <text class="reply-avatar-text">{{reply.authorName[0]}}</text>
                      </view>
                      <view class="reply-info">
                        <view class="reply-author-row">
                          <text class="reply-author-name reply-author-link" bindtap="goToAuthorHome" data-authorid="{{reply.authorId}}">{{reply.authorName}}</text>
                          <text class="author-tag" wx:if="{{reply.isAuthor}}">作者</text>
                          <text class="reply-prefix" wx:if="{{reply.replyToUserName}}">回复 {{reply.replyToUserName}}</text>
                        </view>
                        <text class="reply-time">{{reply.relativeTime}}</text>
                      </view>
                    </view>
                    <view class="reply-content">{{reply.content}}</view>
                    <view class="reply-actions">
                      <view class="comment-action" bindtap="onCommentLike" data-commentid="{{reply.id}}" data-isliked="{{reply.isLiked}}">
                        <text class="action-icon">{{reply.isLiked ? '❤️' : '🤍'}}</text>
                        <text class="action-text">{{reply.likeCount || 0}}</text>
                      </view>
                      <view class="comment-action delete-action" wx:if="{{reply.canDelete}}" bindtap="onDeleteComment" data-commentid="{{reply.id}}">
                        <text class="action-icon">🗑</text>
                        <text class="action-text">删除</text>
                      </view>
                    </view>
                  </view>
                </block>
              </view>
            </view>
          </block>
        </view>

        <!-- 空评论状态 -->
        <view class="empty-comments" wx:else>
          <text class="empty-icon">💭</text>
          <text class="empty-text">还没有评论，快来抢沙发吧~</text>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{commentLoading}}">
          <view class="loading-spinner small"></view>
          <text class="load-more-text">加载中...</text>
        </view>
        <view class="load-more no-more" wx:elif="{{!commentHasMore && comments.length > 0}}">
          <text class="no-more-text">没有更多评论了</text>
        </view>
      </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrap" wx:else>
    <text class="error-icon">😕</text>
    <text class="error-text">文章不存在或已删除</text>
    <button class="btn-back" bindtap="goBack">返回首页</button>
  </view>

  <!-- 举报弹窗 -->
  <view class="report-modal {{showReportModal ? 'show' : ''}}">
    <view class="report-mask" bindtap="onCloseReport"></view>
    <view class="report-content">
      <view class="report-header">
        <text class="report-title">举报内容</text>
        <view class="report-close" bindtap="onCloseReport">✕</view>
      </view>
      <view class="report-body">
        <view class="report-options">
          <view class="report-option {{reportReason === 'illegal' ? 'selected' : ''}}" bindtap="onSelectReportReason" data-reason="illegal">
            <view class="option-radio">
              <view class="radio-inner"></view>
            </view>
            <text class="option-text">违法违规</text>
          </view>
          <view class="report-option {{reportReason === 'false' ? 'selected' : ''}}" bindtap="onSelectReportReason" data-reason="false">
            <view class="option-radio">
              <view class="radio-inner"></view>
            </view>
            <text class="option-text">虚假信息</text>
          </view>
          <view class="report-option {{reportReason === 'infringement' ? 'selected' : ''}}" bindtap="onSelectReportReason" data-reason="infringement">
            <view class="option-radio">
              <view class="radio-inner"></view>
            </view>
            <text class="option-text">侵权</text>
          </view>
          <view class="report-option {{reportReason === 'other' ? 'selected' : ''}}" bindtap="onSelectReportReason" data-reason="other">
            <view class="option-radio">
              <view class="radio-inner"></view>
            </view>
            <text class="option-text">其他</text>
          </view>
        </view>
        <view class="report-desc-wrap">
          <textarea
            class="report-desc"
            placeholder="补充说明（选填）"
            value="{{reportDescription}}"
            bindinput="onReportDescInput"
            maxlength="200"
          />
          <text class="report-desc-count">{{reportDescription.length}}/200</text>
        </view>
      </view>
      <view class="report-footer">
        <button class="btn-report-cancel" bindtap="onCloseReport">取消</button>
        <button class="btn-report-submit" bindtap="onSubmitReport" disabled="{{!reportReason}}">提交举报</button>
      </view>
    </view>
  </view>

  <!-- 底部操作栏（已登录：点赞+收藏+评论输入） -->
  <view class="bottom-action-bar" wx:if="{{article && isLoggedIn}}">
    <view class="action-icons">
      <view class="action-icon-item {{liked ? 'active' : ''}}" bindtap="onLike">
        <text class="icon-emoji">{{liked ? '❤️' : '🤍'}}</text>
        <text class="icon-label">{{article.likeCount || 0}}</text>
      </view>
      <view class="action-icon-item {{favorited ? 'active' : ''}}" bindtap="onFavorite">
        <text class="icon-emoji">{{favorited ? '⭐' : '☆'}}</text>
        <text class="icon-label">{{favorited ? '已收藏' : '收藏'}}</text>
      </view>
    </view>
    <view class="comment-input-area">
      <view class="reply-info" wx:if="{{showReplyInput}}">
        <text class="reply-to-text">回复 {{replyToUserName}}</text>
        <view class="cancel-reply" bindtap="onCancelReply">✕</view>
      </view>
      <view class="input-and-btn">
        <view class="input-wrap">
          <input
            class="comment-input"
            placeholder="{{showReplyInput ? '回复 ' + replyToUserName + '...' : '写下你的评论（2-500字）'}}"
            value="{{commentContent}}"
            bindinput="onCommentInput"
            maxlength="500"
            confirm-type="send"
            bindconfirm="onSubmitComment"
          />
          <view class="char-count">{{commentContent.length}}/500</view>
        </view>
        <button class="btn-send" bindtap="onSubmitComment" disabled="{{!commentContent.trim()}}">发送</button>
      </view>
    </view>
  </view>

  <!-- 底部操作栏（未登录：登录引导） -->
  <view class="bottom-action-bar login-guide-bar" wx:if="{{article && !isLoggedIn}}">
    <view class="login-guide-content">
      <text class="guide-icon">🔒</text>
      <text class="guide-text">登录后点赞 / 收藏 / 评论</text>
    </view>
    <button class="btn-guide-login" bindtap="goToLogin">去登录</button>
  </view>
</view>

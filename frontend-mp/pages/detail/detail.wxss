/* pages/detail/detail.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner.small {
  width: 36rpx;
  height: 36rpx;
  border-width: 3rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-light);
}

/* 文章内容 */
.article-wrap {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 分类标签 */
.article-category {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.tag-folklore {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.tag-farming {
  background-color: rgba(34, 139, 34, 0.1);
  color: #228B22;
}

.tag-craft {
  background-color: rgba(70, 130, 180, 0.1);
  color: #4682B4;
}

.tag-memory {
  background-color: rgba(218, 165, 32, 0.1);
  color: #B8860B;
}

/* 标题 */
.article-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 32rpx;
}

/* 标签列表 */
.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.article-tag-item {
  display: inline-flex;
  padding: 10rpx 24rpx;
  background-color: rgba(34, 139, 34, 0.08);
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--color-secondary);
  font-weight: 500;
  transition: all 0.2s;
}

.article-tag-item:active {
  background-color: rgba(34, 139, 34, 0.16);
  transform: scale(0.96);
}

/* 摘要 */
.article-summary {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.06) 0%, rgba(160, 82, 45, 0.04) 100%);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid var(--color-primary);
}

.article-summary .summary-label {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-right: 12rpx;
}

.article-summary .summary-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* 作者信息 */
.article-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 40rpx;
}

.meta-author {
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.author-name {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.clickable {
  transition: opacity 0.2s;
}

.clickable:active {
  opacity: 0.7;
}

.author-link {
  color: #8B4513;
  font-weight: 500;
}

.author-arrow {
  font-size: 32rpx;
  color: #8B4513;
  margin-left: 4rpx;
  opacity: 0.7;
}

.meta-date {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 文章正文 */
.article-content {
  font-size: 32rpx;
  color: var(--color-text);
  line-height: 2;
  white-space: pre-wrap;
  text-align: justify;
}

/* 文章统计 */
.article-stats-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
  flex-wrap: wrap;
}

.article-stats-section .stat-item {
  display: flex;
  align-items: center;
  background: #faf8f5;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.article-stats-section .stat-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.article-stats-section .stat-value {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  white-space: nowrap;
}

.report-action .stat-value {
  color: #ff6b6b;
}

/* 评论区 */
.comment-section {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 12rpx solid #f0ebe3;
}

.comment-header {
  margin-bottom: 32rpx;
}

.comment-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text);
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.comment-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.comment-header-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #A0522D 0%, #CD853F 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-avatar-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.comment-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.comment-author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.comment-author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.comment-author-link {
  color: #8B4513;
  transition: opacity 0.2s;
}

.comment-author-link:active {
  opacity: 0.7;
}

.author-tag {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 12rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.comment-time {
  font-size: 22rpx;
  color: #999999;
}

.comment-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.7;
  margin-bottom: 16rpx;
  padding-left: 72rpx;
}

.comment-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-left: 72rpx;
}

.comment-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 26rpx;
}

.action-text {
  font-size: 24rpx;
  color: #888888;
}

.delete-action .action-icon,
.delete-action .action-text {
  color: #FF6B6B;
}

/* 回复列表 */
.reply-list {
  margin-top: 20rpx;
  margin-left: 72rpx;
  padding: 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reply-item {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.reply-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.reply-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.reply-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #CD853F 0%, #DEB887 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.reply-avatar-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.reply-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reply-author-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.reply-author-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reply-author-link {
  color: #8B4513;
  transition: opacity 0.2s;
}

.reply-author-link:active {
  opacity: 0.7;
}

.reply-prefix {
  font-size: 24rpx;
  color: #888888;
}

.reply-time {
  font-size: 20rpx;
  color: #999999;
}

.reply-content {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.6;
  padding-left: 56rpx;
  margin-bottom: 12rpx;
}

.reply-actions {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding-left: 56rpx;
}

/* 空评论状态 */
.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  gap: 12rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #888888;
}

.no-more {
  padding: 24rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #BBBBBB;
}

/* 底部占位 */
.bottom-placeholder {
  height: 180rpx;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  border-top: 1rpx solid #f0ebe3;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

/* 已登录：操作图标区 */
.action-icons {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
  min-width: 80rpx;
}

.action-icon-item:active {
  transform: scale(0.94);
  background: #faf8f5;
}

.action-icon-item .icon-emoji {
  font-size: 40rpx;
}

.action-icon-item .icon-label {
  font-size: 20rpx;
  color: #888888;
  margin-top: 4rpx;
}

.action-icon-item.active .icon-label {
  color: #8B4513;
  font-weight: 500;
}

/* 已登录：评论输入区 */
.comment-input-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.reply-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  margin-bottom: 12rpx;
  background: #faf8f5;
  border-radius: 8rpx;
}

.reply-to-text {
  font-size: 24rpx;
  color: #666666;
}

.cancel-reply {
  font-size: 28rpx;
  color: #999999;
  padding: 0 8rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #f5f0e8;
  border-radius: 40rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  flex: 1;
  min-width: 0;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: transparent;
  min-width: 0;
}

.char-count {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.btn-send {
  height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
}

.btn-send[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}

.comment-input-area .input-and-btn {
  display: flex;
  align-items: center;
  min-width: 0;
}

/* 未登录：登录引导栏 */
.login-guide-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, #fffaf0 0%, #fff5e6 100%);
  border-top: 2rpx solid #8B4513;
  gap: 20rpx;
}

.login-guide-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.guide-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: 500;
  flex: 1;
  min-width: 0;
}

.btn-guide-login {
  height: 72rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(139, 69, 19, 0.25);
}

.btn-guide-login:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 错误状态 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.btn-back {
  padding: 20rpx 48rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

/* 未登录状态 */
.login-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 32rpx;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.12);
}

.login-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.login-text {
  display: block;
  font-size: 30rpx;
  color: #888888;
  margin-bottom: 40rpx;
}

.btn-login {
  width: 60%;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.report-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.report-modal.show {
  opacity: 1;
  visibility: visible;
}

.report-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.report-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.85);
  width: 620rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  transition: transform 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.report-modal.show .report-content {
  transform: translate(-50%, -50%) scale(1);
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  background: linear-gradient(90deg, #faf8f5 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0ebe3;
}

.report-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.report-close {
  font-size: 40rpx;
  color: #999999;
  padding: 8rpx;
  line-height: 1;
}

.report-body {
  padding: 32rpx 40rpx;
}

.report-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.report-option {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #faf8f5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.report-option.selected {
  background: #fff8f0;
  border-color: #8B4513;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #cccccc;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.report-option.selected .option-radio {
  border-color: #8B4513;
}

.radio-inner {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.2s;
}

.report-option.selected .radio-inner {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
}

.option-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.report-desc-wrap {
  position: relative;
}

.report-desc {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.6;
}

.report-desc-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 22rpx;
  color: #BBBBBB;
}

.report-footer {
  display: flex;
  padding: 24rpx 40rpx 36rpx;
  gap: 24rpx;
  border-top: 1rpx solid #f0ebe3;
}

.btn-report-cancel,
.btn-report-submit {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-report-cancel {
  background-color: #f5f0e8;
  color: #666666;
}

.btn-report-submit {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.3);
}

.btn-report-submit[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
  box-shadow: none;
}

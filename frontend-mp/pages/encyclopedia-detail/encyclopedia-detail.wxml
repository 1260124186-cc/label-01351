<view class="page-container">
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{t.loading}}</text>
  </view>

  <block wx:elif="{{entry}}">
    <view class="entry-hero">
      <view class="entry-header">
        <view class="entry-category tag-{{entry.category}}">
          {{entry.category === 'festival' ? '节气节日' : entry.category === 'craft' ? '传统技艺' : entry.category === 'custom' ? '民俗文化' : entry.category === 'history' ? '历史典故' : entry.category === 'art' ? '艺术形式' : '文化'}}
        </view>
        <view class="entry-stats">
          <text class="stat-item">👁 {{entry.viewCount}}</text>
          <text class="stat-item">👍 {{entry.likeCount}}</text>
        </view>
      </view>
      <view class="entry-title-wrap">
        <view class="entry-title">{{entry.title}}</view>
        <view class="entry-bilingual" wx:if="{{titlePinyin || titlePhonetic}}">
          <text class="bilingual-pinyin" wx:if="{{titlePinyin}}">{{titlePinyin}}</text>
          <text class="bilingual-sep" wx:if="{{titlePinyin && titlePhonetic}}"> / </text>
          <text class="bilingual-phonetic" wx:if="{{titlePhonetic}}">{{titlePhonetic}}</text>
        </view>
      </view>
      <view class="entry-summary">{{entry.summary}}</view>
      <view class="entry-tags" wx:if="{{entry.tags && entry.tags.length > 0}}">
        <view class="tag-item" wx:for="{{entry.tags}}" wx:key="*this">
          #{{item}}
        </view>
      </view>
      <view class="entry-meta">
        <text class="meta-item">👤 {{entry.authorName}}</text>
        <text class="meta-item">📅 {{entry.createTime}}</text>
      </view>
    </view>

    <view class="catalog-section" wx:if="{{entry.catalog && entry.catalog.length > 0}}">
      <view class="catalog-header" bindtap="toggleCatalog">
        <text class="catalog-title">{{t.catalog}}</text>
        <text class="catalog-toggle">{{catalogExpanded ? t.collapse : t.expand}}</text>
      </view>
      <view class="catalog-content" wx:if="{{catalogExpanded}}">
        <view
          class="catalog-item level-{{item.level}}"
          wx:for="{{entry.catalog}}"
          wx:key="id"
          bindtap="scrollToSection"
          data-id="{{item.id}}"
        >
          <text class="catalog-dot" wx:if="{{item.level === 1}}"></text>
          <text class="catalog-text">{{item.title}}</text>
        </view>
      </view>
    </view>

    <view class="tab-bar">
      <view
        class="tab-item {{activeTab === 'content' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="content"
      >
        {{t.contentTab}}
      </view>
      <view
        class="tab-item {{activeTab === 'articles' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="articles"
      >
        {{t.articlesTab}}
      </view>
      <view
        class="tab-item {{activeTab === 'topics' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="topics"
      >
        {{t.topicsTab}}
      </view>
    </view>

    <view class="tab-content">
      <block wx:if="{{activeTab === 'content'}}">
        <view class="content-card">
          <view class="section-title">{{t.contentTab}}</view>
          <view class="content-text">
            <text wx:for="{{contentParagraphs}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </block>

      <block wx:elif="{{activeTab === 'articles'}}">
        <view wx:if="{{entry.relatedArticles && entry.relatedArticles.length > 0}}">
          <view
            class="article-card"
            wx:for="{{entry.relatedArticles}}"
            wx:key="id"
            bindtap="goToArticle"
            data-id="{{item.id}}"
          >
            <view class="article-header">
              <view class="article-category tag-{{item.category}}">
                {{item.categoryName}}
              </view>
              <text class="article-date">{{item.createTime}}</text>
            </view>
            <view class="article-title">{{item.title}}</view>
            <view class="article-content">{{item.summary}}</view>
            <view class="article-footer">
              <view class="article-author">
                <text class="author-icon">👤</text>
                <text class="author-name">{{item.authorName}}</text>
              </view>
              <view class="article-stats">
                <text class="stat-icon">👁</text>
                <text class="stat-value">{{item.viewCount}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-wrap" wx:else>
          <text class="empty-icon">📝</text>
          <text class="empty-text">{{t.noRelatedArticles}}</text>
        </view>
      </block>

      <block wx:elif="{{activeTab === 'topics'}}">
        <view wx:if="{{entry.relatedTopics && entry.relatedTopics.length > 0}}">
          <view
            class="topic-card"
            wx:for="{{entry.relatedTopics}}"
            wx:key="id"
            bindtap="goToTopic"
            data-id="{{item.id}}"
          >
            <view class="topic-cover">
              <text class="cover-emoji">📚</text>
            </view>
            <view class="topic-info">
              <view class="topic-title">{{item.title}}</view>
              <view class="topic-meta">{{item.articleCount}}篇文章</view>
            </view>
          </view>
        </view>
        <view class="empty-wrap" wx:else>
          <text class="empty-icon">🔗</text>
          <text class="empty-text">{{t.noRelatedTopics}}</text>
        </view>
      </block>
    </view>
  </block>

  <view class="empty-wrap" wx:else>
    <text class="empty-icon">📖</text>
    <text class="empty-text">{{t.notFound}}</text>
  </view>

  <view class="bottom-bar" wx:if="{{entry}}">
    <view class="action-item" bindtap="onFavorite">
      <text class="action-icon">⭐</text>
      <text class="action-text">{{t.favorite}}</text>
    </view>
    <view class="action-item" bindtap="onLike">
      <text class="action-icon">👍</text>
      <text class="action-text">{{t.like}}</text>
    </view>
    <button class="share-btn" open-type="share">
      <text class="share-icon">📤</text>
      <text class="share-text">{{t.share}}</text>
    </button>
  </view>
</view>

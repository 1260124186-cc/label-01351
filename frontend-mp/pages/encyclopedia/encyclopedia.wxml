<view class="page-container">
  <view class="header">
    <view class="header-title">
      <text class="title-main">文化百科</text>
      <text class="title-sub">传承智慧 · 探索文明</text>
    </view>
  </view>

  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索词条" 
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
    <view class="admin-btn" bindtap="goToAdmin">
      <text class="admin-icon">✏️</text>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view 
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onCategoryChange"
      data-id="{{item.id}}"
    >
      <text class="category-icon">{{item.icon}}</text>
      <text class="category-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <view class="hot-entries" wx:if="{{entryList.length > 0 && page === 1}}">
    <view class="section-header">
      <text class="section-title">🔥 热门词条</text>
    </view>
    <scroll-view class="hot-scroll" scroll-x enable-flex>
      <view 
        class="hot-item"
        wx:for="{{entryList}}"
        wx:for-index="index"
        wx:key="id"
        wx:if="{{index < 5}}"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <text class="hot-rank rank-{{index + 1}}">{{index + 1}}</text>
        <text class="hot-title">{{item.title}}</text>
      </view>
    </scroll-view>
  </view>

  <view class="entry-list">
    <view class="loading-wrap" wx:if="{{loading && entryList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-wrap" wx:elif="{{!loading && entryList.length === 0}}">
      <text class="empty-icon">📖</text>
      <text class="empty-text">暂无词条</text>
      <text class="empty-hint">敬请期待更多精彩内容</text>
    </view>

    <view 
      class="entry-card"
      wx:for="{{entryList}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="entry-header">
        <view class="entry-category tag-{{item.category}}">
          {{item.category === 'festival' ? '节气节日' : item.category === 'craft' ? '传统技艺' : item.category === 'custom' ? '民俗文化' : item.category === 'history' ? '历史典故' : item.category === 'art' ? '艺术形式' : '文化'}}
        </view>
        <view class="entry-views">
          <text class="view-icon">👁</text>
          <text class="view-count">{{item.viewCount}}</text>
        </view>
      </view>
      <view class="entry-title">{{item.title}}</view>
      <view class="entry-summary">{{item.summaryText}}</view>
      <view class="entry-footer">
        <view class="entry-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">#{{tag}}</text>
        </view>
        <text class="entry-date">{{item.createTime}}</text>
      </view>
    </view>

    <view class="load-more" wx:if="{{entryList.length > 0}}">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">— 已经到底了 —</text>
      <text wx:else bindtap="loadMore">点击加载更多</text>
    </view>
  </view>
</view>

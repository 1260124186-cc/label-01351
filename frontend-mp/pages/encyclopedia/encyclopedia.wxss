.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-light);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

.admin-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.admin-icon {
  font-size: 36rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx 24rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  margin-right: 16rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.category-item.active {
  background-color: #2E8B57;
}

.category-item.active .category-name,
.category-item.active .category-icon {
  color: #FFFFFF;
}

.category-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: var(--color-text-secondary);
}

.category-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.hot-entries {
  padding: 0 24rpx 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.hot-scroll {
  white-space: nowrap;
}

.hot-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.hot-item:active {
  transform: scale(0.96);
}

.hot-rank {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: bold;
  margin-right: 12rpx;
  color: #FFFFFF;
}

.rank-1 {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.rank-2 {
  background: linear-gradient(135deg, #C0C0C0 0%, #A9A9A9 100%);
}

.rank-3 {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
}

.rank-4, .rank-5 {
  background-color: #E8E8E8;
  color: #666666;
}

.hot-title {
  font-size: 26rpx;
  color: var(--color-text);
  white-space: nowrap;
}

.entry-list {
  padding: 0 24rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #2E8B57;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.entry-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.entry-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.entry-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.entry-category {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-festival {
  background-color: rgba(218, 165, 32, 0.1);
  color: #B8860B;
}

.tag-craft {
  background-color: rgba(70, 130, 180, 0.1);
  color: #4682B4;
}

.tag-custom {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.tag-history {
  background-color: rgba(128, 0, 128, 0.1);
  color: #800080;
}

.tag-art {
  background-color: rgba(255, 99, 71, 0.1);
  color: #FF6347;
}

.entry-views {
  display: flex;
  align-items: center;
}

.view-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
  color: var(--color-text-light);
}

.view-count {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.entry-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.entry-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.entry-tags {
  display: flex;
  gap: 12rpx;
  flex: 1;
  overflow: hidden;
}

.tag {
  font-size: 22rpx;
  color: #2E8B57;
  white-space: nowrap;
}

.entry-date {
  font-size: 24rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-light);
}

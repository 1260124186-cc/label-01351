.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 140rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.detail-hero {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.hero-scene {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.scene-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.scene-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.hero-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.hero-summary {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}

.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.tab-item.active .tab-name {
  color: #FFFFFF;
  font-weight: 500;
}

.tab-content {
  padding: 24rpx;
}

.process-list {
  padding-left: 16rpx;
}

.process-item {
  display: flex;
  margin-bottom: 8rpx;
}

.process-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  width: 56rpx;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-line {
  width: 4rpx;
  flex: 1;
  background: linear-gradient(to bottom, #CD853F, #DEB887);
  min-height: 32rpx;
  margin: 8rpx 0;
}

.process-info {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.step-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.taboo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.taboo-item {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #DAA520;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.taboo-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.taboo-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.taboo-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #B8860B;
}

.taboo-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.region-filter-bar {
  margin-bottom: 20rpx;
}

.region-filter-scroll {
  white-space: nowrap;
}

.region-filter-item {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin-right: 12rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.region-filter-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.region-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.region-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.region-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.region-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.region-province {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}

.region-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.empty-region {
  text-align: center;
  padding: 40rpx 0;
}

.empty-region-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.modern-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modern-item {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #2E8B57;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.modern-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.modern-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.modern-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E8B57;
}

.modern-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.share-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: none;
  margin: 0;
  padding: 0;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.share-text {
  font-size: 30rpx;
}

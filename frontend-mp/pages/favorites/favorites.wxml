<!--pages/favorites/favorites.wxml-->
<view class="page-container">
  <!-- 未登录状态 -->
  <view class="login-wrap" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-icon">⭐</text>
      <text class="login-text">登录后查看我的收藏</text>
      <button class="btn-login" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索收藏的文章"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
      />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>

    <!-- 搜索历史 -->
    <view class="search-history" wx:if="{{showSearchHistory && searchHistory.length > 0}}">
      <view class="search-history-header">
        <text class="history-title">搜索历史</text>
        <text class="history-clear" bindtap="clearSearchHistory">清空</text>
      </view>
      <view class="search-history-list">
        <view
          class="history-item"
          wx:for="{{searchHistory}}"
          wx:key="*this"
          bindtap="onHistoryItemTap"
          data-keyword="{{item}}"
        >
          <text class="history-icon">🕐</text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onCategoryChange"
      data-id="{{item.id}}"
    >
      <text class="category-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 排序切换 -->
  <view class="sort-bar">
    <view class="sort-label">排序：</view>
    <view class="sort-options">
      <view
        class="sort-item {{sortType === item.id ? 'active' : ''}}"
        wx:for="{{sortOptions}}"
        wx:key="id"
        bindtap="onSortChange"
        data-sort="{{item.id}}"
      >
        <text class="sort-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="favorite-list">
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading && favoriteList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:elif="{{!loading && favoriteList.length === 0}}">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">暂无收藏</text>
      <text class="empty-hint">快去收藏喜欢的文章吧</text>
    </view>

    <!-- 收藏卡片 -->
    <view
      class="favorite-card"
      wx:for="{{favoriteList}}"
      wx:key="id"
    >
      <view class="card-content" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="article-header">
          <view class="article-category tag-{{item.category}}">
            {{item.categoryName}}
          </view>
          <text class="article-date">{{item.relativeTime}}</text>
        </view>

        <view class="article-title">{{item.title}}</view>

        <view class="article-content">{{item.summary}}</view>

        <view class="article-footer">
          <view class="article-author">
            <text class="author-icon">👤</text>
            <text class="author-name">{{item.authorName}}</text>
          </view>
          <view class="article-stats">
            <view class="stat-item">
              <text class="stat-icon">👁</text>
              <text class="stat-value">{{item.viewCount}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">👍</text>
              <text class="stat-value">{{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="card-action">
        <view class="unfavorite-btn" bindtap="onUnfavorite" data-id="{{item.id}}" data-index="{{index}}">
          <text class="unfavorite-icon">⭐</text>
          <text class="unfavorite-text">取消收藏</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{favoriteList.length > 0}}">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">— 已经到底了 —</text>
      <text wx:else bindtap="loadMore">点击加载更多</text>
    </view>
  </view>
  </block>
</view>

/* pages/figure-detail/figure-detail.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 人物档案头部 */
.profile-header {
  display: flex;
  gap: 28rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.profile-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: #F0F0F0;
}

.profile-deceased {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.7);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.profile-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.identity-tag-large {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-icon {
  margin-right: 4rpx;
}

.profile-lifespan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.age-text {
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.profile-region {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.separator {
  margin: 0 12rpx;
  color: rgba(255, 255, 255, 0.5);
}

.profile-crafts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.craft-tag-large {
  padding: 6rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 6rpx;
}

/* 通用卡片 */
.section-card {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.intro-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.2s;
}

.tab-item.active {
  background-color: rgba(139, 69, 19, 0.1);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.tab-item.active .tab-text {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background-color: #F53F3F;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* Tab 内容 */
.tab-content {
  padding: 0 24rpx;
}

/* 时间轴 */
.timeline-container {
  padding: 16rpx 0;
}

.timeline-item {
  position: relative;
  display: flex;
  padding-left: 48rpx;
  padding-bottom: 32rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  background-color: var(--color-primary);
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(139, 69, 19, 0.2);
}

.timeline-line {
  position: absolute;
  left: 9rpx;
  top: 32rpx;
  width: 2rpx;
  bottom: 0;
  background-color: var(--color-border);
}

.timeline-content {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.timeline-year {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.timeline-event {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 作品卡片 */
.works-container {
  padding: 16rpx 0;
}

.work-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.work-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.work-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  flex: 1;
  margin-right: 16rpx;
}

.work-type-tag {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.type-work {
  background-color: rgba(218, 165, 32, 0.15);
  color: #B8860B;
}

.type-story {
  background-color: rgba(70, 130, 180, 0.15);
  color: #4682B4;
}

.type-article {
  background-color: rgba(139, 69, 19, 0.15);
  color: #8B4513;
}

.work-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* 相关文章 */
.articles-container {
  padding: 16rpx 0;
}

.article-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.article-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.article-category {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-meta {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.stats-info {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 26rpx;
}

.stat-value {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.action-buttons {
  display: flex;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
  min-width: 0;
}

.like-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #F7F7F7;
  border-radius: 36rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.like-btn.liked {
  background-color: rgba(245, 63, 63, 0.1);
}

.like-btn:active {
  transform: scale(0.95);
}

.like-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.like-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}

.like-btn.liked .like-text {
  color: #F53F3F;
}

.like-count {
  font-size: 22rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  margin: 0;
  flex-shrink: 0;
  white-space: nowrap;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  background-color: #6B3410;
}

.share-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.retry-btn::after {
  border: none;
}

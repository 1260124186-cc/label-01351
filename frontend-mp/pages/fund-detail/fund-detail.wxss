.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 顶部 */
.detail-header {
  position: relative;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 32rpx;
  color: #fff;
}

.status-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.project-title {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.project-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.meta-item {
  font-size: 24rpx;
  opacity: 0.85;
}

/* 筹款进度 */
.fund-progress {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 28rpx;
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700 0%, #ffb347 100%);
  border-radius: 7rpx;
}

.progress-percent {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
  width: 90rpx;
  text-align: right;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #666;
}

.tab-item.active .tab-name {
  color: #8B4513;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background: #8B4513;
  border-radius: 3rpx;
}

/* Tab 内容 */
.tab-content {
  height: calc(100vh - 520rpx);
}

.tab-panel {
  padding: 24rpx 32rpx;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 受益说明 */
.beneficiary-box {
  background: #fff9e6;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #fa8c16;
}

.beneficiary-text {
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.7;
}

/* 时间线 */
.timeline {
  padding-left: 16rpx;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 32rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  z-index: 2;
}

.timeline-line {
  position: absolute;
  left: 9rpx;
  top: 28rpx;
  bottom: 0;
  width: 2rpx;
  background: #eee;
}

.timeline-content {
  flex: 1;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.timeline-type {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.timeline-date {
  font-size: 24rpx;
  color: #999;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty-timeline,
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 文章列表 */
.article-list,
.activity-list,
.donation-list {
  margin: -8rpx 0;
}

.article-item,
.activity-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-item:last-child,
.activity-item:last-child {
  border-bottom: none;
}

.article-info,
.activity-info {
  flex: 1;
  min-width: 0;
}

.article-title,
.activity-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.article-meta,
.activity-meta {
  display: flex;
  gap: 20rpx;
}

.meta-author,
.meta-location,
.meta-time {
  font-size: 24rpx;
  color: #999;
}

.article-arrow,
.activity-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* 捐赠公示 */
.donate-info-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff9e6 0%, #fff5e6 100%);
  border-radius: 16rpx;
  padding: 28rpx;
}

.info-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.info-content {
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #8B6914;
  margin-bottom: 6rpx;
}

.info-desc {
  font-size: 24rpx;
  color: #a0893c;
}

.donation-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.donation-item:last-child {
  border-bottom: none;
}

.donation-left {
  display: flex;
  align-items: center;
}

.donor-avatar {
  width: 72rpx;
  height: 72rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.donor-info {
  display: flex;
  flex-direction: column;
}

.donor-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.donation-method {
  font-size: 22rpx;
  color: #999;
}

.donation-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.donation-amount {
  font-size: 30rpx;
  font-weight: bold;
  color: #52c41a;
  margin-bottom: 6rpx;
}

.donation-date {
  font-size: 22rpx;
  color: #999;
}

.donation-methods {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.method-item {
  flex: 1;
  min-width: 30%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #fafafa;
  border-radius: 12rpx;
}

.method-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.method-name {
  font-size: 24rpx;
  color: #666;
}

.donation-tip {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f6ffed;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #52c41a;
  line-height: 1.6;
}

/* 留言 */
.comment-list {
  margin: -8rpx 0;
}

.comment-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.comment-user {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 留言输入 */
.comment-input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.input-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.input-tip {
  font-size: 22rpx;
  color: #fa8c16;
}

.input-wrap {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.comment-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.textarea-placeholder {
  color: #ccc;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.word-count {
  font-size: 22rpx;
  color: #999;
}

.btn-submit {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #fff;
  font-size: 26rpx;
  border-radius: 32rpx;
  line-height: 1.4;
}

.btn-submit.disabled {
  background: #ccc;
  color: #fff;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bar-left {
  display: flex;
  gap: 40rpx;
}

.bar-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
}

.bar-right {
  flex: 1;
  margin-left: 40rpx;
}

.btn-donate {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  margin-right: 8rpx;
}

/* 管理员浮动按钮 */
.admin-fab {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.4);
  z-index: 99;
}

.fab-icon {
  font-size: 40rpx;
}

/* 错误 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
}

/* 捐赠弹窗 */
.donate-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.donate-modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.donate-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.donate-notice {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff9e6;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.notice-text {
  flex: 1;
  font-size: 26rpx;
  color: #8B6914;
}

.method-section {
  margin-bottom: 32rpx;
}

.method-card {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.method-head {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.method-detail {
  padding-left: 16rpx;
}

.detail-row {
  display: flex;
  padding: 8rpx 0;
}

.detail-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.donate-reminder {
  background: #f6ffed;
  border-radius: 16rpx;
  padding: 24rpx;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 16rpx;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reminder-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.modal-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

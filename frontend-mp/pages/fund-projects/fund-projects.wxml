<view class="fund-page">
  <!-- 顶部统计卡片 -->
  <view class="stats-header">
    <view class="stats-bg"></view>
    <view class="stats-content">
      <view class="stats-title">
        <text class="stats-icon">💝</text>
        <text class="stats-name">文化公益基金</text>
      </view>
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-value">{{totalProjects}}</text>
          <text class="stat-label">公益项目</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">¥{{totalRaised > 10000 ? (totalRaised / 10000).toFixed(1) + '万' : totalRaised.toLocaleString()}}</text>
          <text class="stat-label">累计筹款</text>
        </view>
      </view>
      <view class="donate-btn" bindtap="goToDonateInfo">
        <text class="donate-icon">❤️</text>
        <text class="donate-text">我要捐赠</text>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索基金项目"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</view>
    </view>
    <view class="admin-entry" wx:if="{{isAdmin}}" bindtap="goToAdmin">
      <text class="admin-icon">🛠</text>
      <text class="admin-text">管理</text>
    </view>
  </view>

  <!-- 状态筛选 -->
  <scroll-view class="status-tabs" scroll-x enable-flex>
    <view
      class="status-chip {{currentStatus === item.id ? 'active' : ''}}"
      wx:for="{{statusList}}"
      wx:key="id"
      bindtap="onStatusChange"
      data-id="{{item.id}}"
    >
      <text class="chip-icon">{{item.icon}}</text>
      <text class="chip-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 列表内容 -->
  <view class="list-container">
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading && projectList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:elif="{{projectList.length === 0 && !loading}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无基金项目</text>
      <text class="empty-desc">敬请期待更多文化公益项目</text>
    </view>

    <!-- 项目列表 -->
    <view class="project-list" wx:else>
      <view
        class="project-card"
        wx:for="{{projectList}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <view class="project-name">{{item.name}}</view>
          <view class="project-status" style="background-color: {{item.statusInfo.color}}20; color: {{item.statusInfo.color}};">
            {{item.statusInfo.icon}} {{item.statusInfo.name}}
          </view>
        </view>

        <view class="progress-section">
          <view class="progress-info">
            <view class="progress-item">
              <text class="progress-label">目标</text>
              <text class="progress-value target">{{item.targetAmountDisplay}}</text>
            </view>
            <view class="progress-item">
              <text class="progress-label">已筹</text>
              <text class="progress-value raised">{{item.raisedAmountDisplay}}</text>
            </view>
            <view class="progress-item">
              <text class="progress-label">已用</text>
              <text class="progress-value used">{{item.usedAmountDisplay}}</text>
            </view>
          </view>
          <view class="progress-bar-wrap">
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.progress}}%;"></view>
            </view>
            <text class="progress-percent">{{item.progress}}%</text>
          </view>
        </view>

        <view class="beneficiary-section">
          <text class="beneficiary-icon">🤝</text>
          <text class="beneficiary-text">{{item.beneficiaryDescShort}}</text>
        </view>

        <view class="card-footer">
          <text class="footer-info">👁 {{item.viewCount || 0}} 浏览</text>
          <text class="footer-info">💬 {{item.commentCount || 0}} 留言</text>
          <text class="footer-arrow">查看详情 ›</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{loadingMore}}">
        <view class="load-spinner"></view>
        <text class="load-text">加载中...</text>
      </view>
      <view class="no-more" wx:elif="{{!hasMore && projectList.length > 0}}">
        <text class="no-more-text">— 没有更多了 —</text>
      </view>
    </view>
  </view>
</view>

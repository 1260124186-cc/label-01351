<!--pages/index/index.wxml-->
<view class="page-container">
  <!-- 顶部标题区域 -->
  <view class="header">
    <view class="header-title">
      <text class="title-main">乡村文化库</text>
      <text class="title-sub">传承乡村文化 · 传递银龄力量</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索文章标题或内容"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
      />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>

    <!-- 搜索历史 -->
    <view class="search-history" wx:if="{{showSearchHistory && searchHistory.length > 0}}">
      <view class="search-history-header">
        <text class="history-title">搜索历史</text>
        <text class="history-clear" bindtap="clearSearchHistory">清空</text>
      </view>
      <view class="search-history-list">
        <view
          class="history-item"
          wx:for="{{searchHistory}}"
          wx:key="*this"
          bindtap="onHistoryItemTap"
          data-keyword="{{item}}"
        >
          <text class="history-icon">🕐</text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 金刚区入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToMap">
      <view class="entry-icon-wrap icon-map">
        <text class="entry-icon">🗺️</text>
      </view>
      <text class="entry-name">文化地图</text>
      <text class="entry-desc">乡土地标</text>
    </view>
    <view class="entry-item" bindtap="goToTopics">
      <view class="entry-icon-wrap icon-topic">
        <text class="entry-icon">📖</text>
      </view>
      <text class="entry-name">文化专题</text>
      <text class="entry-desc">体系化内容</text>
    </view>
    <view class="entry-item" bindtap="goToEncyclopedia">
      <view class="entry-icon-wrap icon-encyclopedia">
        <text class="entry-icon">📚</text>
      </view>
      <text class="entry-name">文化百科</text>
      <text class="entry-desc">词条知识</text>
    </view>
    <view class="entry-item" bindtap="goToFigures">
      <view class="entry-icon-wrap icon-figure">
        <text class="entry-icon">👥</text>
      </view>
      <text class="entry-name">银龄人物</text>
      <text class="entry-desc">传承故事</text>
    </view>
    <view class="entry-item" bindtap="goToActivities">
      <view class="entry-icon-wrap icon-activity">
        <text class="entry-icon">🎭</text>
      </view>
      <text class="entry-name">文化活动</text>
      <text class="entry-desc">志愿招募</text>
    </view>
    <view class="entry-item" bindtap="goToCalendar">
      <view class="entry-icon-wrap icon-calendar">
        <text class="entry-icon">📅</text>
      </view>
      <text class="entry-name">文化日历</text>
      <text class="entry-desc">节气节日</text>
    </view>
    <view class="entry-item" bindtap="goToPublish">
      <view class="entry-icon-wrap icon-publish">
        <text class="entry-icon">✏️</text>
      </view>
      <text class="entry-name">我要投稿</text>
      <text class="entry-desc">分享故事</text>
    </view>
    <view class="entry-item" bindtap="goToFundProjects">
      <view class="entry-icon-wrap icon-fund">
        <text class="entry-icon">💝</text>
      </view>
      <text class="entry-name">文化基金</text>
      <text class="entry-desc">公益透明</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x enable-flex>
    <view
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onCategoryChange"
      data-id="{{item.id}}"
    >
      <text class="category-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 排序切换 -->
  <view class="sort-bar">
    <view class="sort-label">排序：</view>
    <view class="sort-options">
      <view
        class="sort-item {{sortType === item.id ? 'active' : ''}}"
        wx:for="{{sortOptions}}"
        wx:key="id"
        bindtap="onSortChange"
        data-sort="{{item.id}}"
      >
        <text class="sort-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 标签筛选器 -->
  <view class="tag-filter-bar" wx:if="{{tag}}">
    <view class="tag-filter-wrap">
      <text class="tag-filter-label">标签筛选：</text>
      <view class="tag-filter-active">
        <text class="filter-tag-prefix">#</text>
        <text class="filter-tag-text">{{tag}}</text>
      </view>
      <view class="tag-filter-clear" bindtap="clearTagFilter">
        <text class="clear-icon">✕</text>
        <text class="clear-text">清除</text>
      </view>
    </view>
  </view>

  <!-- 文章列表 -->
  <view class="article-list">
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading && articleList.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 搜索空结果 -->
    <view class="empty-wrap empty-search" wx:elif="{{!loading && articleList.length === 0 && emptyResultType === 'search'}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到相关文章</text>
      <text class="empty-hint">换个关键词试试吧</text>

      <!-- 热门文章推荐 -->
      <view class="hot-articles" wx:if="{{hotArticles.length > 0}}">
        <view class="hot-articles-header">
          <text class="hot-title">🔥 热门文章推荐</text>
        </view>
        <view class="hot-articles-list">
          <view
            class="hot-article-item"
            wx:for="{{hotArticles}}"
            wx:key="id"
            bindtap="goToHotArticle"
            data-id="{{item.id}}"
          >
            <view class="hot-article-rank">{{index + 1}}</view>
            <view class="hot-article-info">
              <text class="hot-article-title">{{item.title}}</text>
              <view class="hot-article-meta">
                <text class="hot-category tag-{{item.category}}">{{item.categoryName}}</text>
                <text class="hot-views">👁 {{item.viewCount}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 普通空状态 -->
    <view class="empty-wrap" wx:elif="{{!loading && articleList.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无文章</text>
      <text class="empty-hint">快去投稿分享你的故事吧</text>
    </view>

    <!-- 文章卡片 -->
    <view
      class="article-card"
      wx:for="{{articleList}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="article-header">
        <view class="article-category tag-{{item.category}}">
          {{item.categoryName}}
        </view>
        <text class="article-date">{{item.relativeTime}}</text>
      </view>

      <view class="article-title">{{item.title}}</view>

      <view class="article-content">{{item.summary}}</view>

      <!-- 文章标签 -->
      <view class="article-card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
        <view
          class="card-tag-item"
          wx:for="{{item.tags}}"
          wx:for-item="tag"
          wx:for-index="tagIndex"
          wx:key="*this"
          catchtap="onCardTagClick"
          data-tag="{{tag}}"
          data-id="{{item.id}}"
        >
          <text>#{{tag}}</text>
        </view>
      </view>

      <view class="article-footer">
        <view class="article-author">
          <text class="author-icon">👤</text>
          <text class="author-name">{{item.authorName}}</text>
        </view>
        <view class="article-stats">
          <view class="stat-item">
            <text class="stat-icon">👁</text>
            <text class="stat-value">{{item.viewCount}}</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">👍</text>
            <text class="stat-value">{{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{articleList.length > 0}}">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">— 已经到底了 —</text>
      <text wx:else bindtap="loadMore">点击加载更多</text>
    </view>
  </view>
</view>

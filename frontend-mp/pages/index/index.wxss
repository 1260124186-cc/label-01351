/* pages/index/index.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 120rpx;
}

/* 顶部标题 */
.header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.village-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.village-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.village-icon {
  font-size: 28rpx;
}

.village-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.village-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-light);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

/* 搜索历史 */
.search-history {
  margin-top: 16rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.history-clear {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.search-history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: var(--color-bg);
  border-radius: 24rpx;
}

.history-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: var(--color-text-light);
}

.history-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx 20rpx;
}

.sort-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 16rpx;
}

.sort-options {
  display: flex;
  flex: 1;
  gap: 12rpx;
}

.sort-item {
  padding: 10rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.sort-item.active {
  background-color: var(--color-primary);
}

.sort-item.active .sort-name {
  color: #FFFFFF;
}

.sort-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 金刚区入口 */
.quick-entry {
  display: flex;
  justify-content: space-between;
  padding: 0 24rpx 32rpx;
  flex-wrap: wrap;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  margin-bottom: 16rpx;
}

.entry-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.icon-map {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.icon-topic {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.icon-encyclopedia {
  background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%);
}

.icon-figure {
  background: linear-gradient(135deg, #4A90E2 0%, #67B8F7 100%);
}

.icon-activity {
  background: linear-gradient(135deg, #FF6B9D 0%, #C44569 100%);
}

.icon-calendar {
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
}

.icon-publish {
  background: linear-gradient(135deg, #9B59B6 0%, #BB8FCE 100%);
}

.icon-fund {
  background: linear-gradient(135deg, #E74C3C 0%, #F1948A 100%);
}

.entry-icon {
  font-size: 40rpx;
}

.entry-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.entry-desc {
  font-size: 20rpx;
  color: var(--color-text-light);
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx 24rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  margin-right: 16rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.category-item.active {
  background-color: var(--color-primary);
}

.category-item.active .category-name {
  color: #FFFFFF;
}

.category-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 标签筛选栏 */
.tag-filter-bar {
  padding: 0 24rpx 20rpx;
}

.tag-filter-wrap {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: rgba(34, 139, 34, 0.06);
  border: 2rpx solid rgba(34, 139, 34, 0.2);
  border-radius: 40rpx;
}

.tag-filter-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.tag-filter-active {
  flex: 1;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: rgba(34, 139, 34, 0.15);
  border-radius: 24rpx;
}

.filter-tag-prefix {
  font-size: 26rpx;
  color: var(--color-secondary);
  margin-right: 4rpx;
}

.filter-tag-text {
  font-size: 26rpx;
  color: var(--color-secondary);
  font-weight: 500;
}

.tag-filter-clear {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  margin-left: 12rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid var(--color-border);
}

.clear-icon {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-right: 6rpx;
}

.clear-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 文章列表 */
.article-list {
  padding: 0 24rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 文章卡片 */
.article-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.article-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.article-category {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-folklore {
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.tag-farming {
  background-color: rgba(34, 139, 34, 0.1);
  color: #228B22;
}

.tag-craft {
  background-color: rgba(70, 130, 180, 0.1);
  color: #4682B4;
}

.tag-memory {
  background-color: rgba(218, 165, 32, 0.1);
  color: #B8860B;
}

.article-date {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.article-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 16rpx;
}

/* 卡片标签 */
.article-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-tag-item {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background-color: rgba(34, 139, 34, 0.06);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: var(--color-secondary);
  font-weight: 500;
  transition: all 0.2s;
}

.card-tag-item:active {
  background-color: rgba(34, 139, 34, 0.15);
  transform: scale(0.96);
}

.article-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.article-author {
  display: flex;
  align-items: center;
}

.author-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.author-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.article-stats {
  display: flex;
  align-items: center;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-left: 24rpx;
}

.stat-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.stat-value {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 搜索空结果 */
.empty-search {
  padding-top: 80rpx;
}

/* 热门文章推荐 */
.hot-articles {
  margin-top: 40rpx;
  width: 100%;
  padding: 0 24rpx;
}

.hot-articles-header {
  margin-bottom: 20rpx;
}

.hot-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}

.hot-articles-list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.hot-article-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.2s;
}

.hot-article-item:last-child {
  border-bottom: none;
}

.hot-article-item:active {
  background-color: var(--color-bg);
}

.hot-article-rank {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  background-color: var(--color-primary);
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.hot-article-item:nth-child(1) .hot-article-rank {
  background-color: #FF6B6B;
}

.hot-article-item:nth-child(2) .hot-article-rank {
  background-color: #FF8E53;
}

.hot-article-item:nth-child(3) .hot-article-rank {
  background-color: #FFD700;
  color: #333;
}

.hot-article-info {
  flex: 1;
  min-width: 0;
}

.hot-article-title {
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.hot-article-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hot-category {
  display: inline-flex;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.hot-views {
  font-size: 22rpx;
  color: var(--color-text-light);
}

/* pages/interview-collection-detail/interview-collection-detail.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 合集头部 */
.collection-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.header-cover {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.7) 100%);
}

.header-content {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.header-icon {
  font-size: 48rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.header-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.header-stats .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-stats .stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.header-stats .stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 合集描述 */
.collection-desc {
  margin: -24rpx 24rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.desc-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* 列表标题 */
.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.list-count {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 访谈列表 */
.interview-list {
  padding: 0 24rpx;
}

.interview-card {
  display: flex;
  gap: 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.interview-card:active {
  transform: scale(0.98);
}

.card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D2B48C 0%, #F5DEB3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.card-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.age-tag {
  padding: 4rpx 12rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #8B4513;
  flex-shrink: 0;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-light);
  flex-wrap: wrap;
}

.meta-item {
  flex-shrink: 0;
}

.meta-separator {
  margin: 0 12rpx;
  color: var(--color-border);
  flex-shrink: 0;
}

.card-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.craft-tag {
  padding: 4rpx 12rpx;
  background-color: rgba(139, 69, 19, 0.08);
  border-radius: 4rpx;
  font-size: 22rpx;
  color: #8B4513;
  flex-shrink: 0;
}

.card-stats {
  display: flex;
  gap: 24rpx;
}

.card-stats .stats-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stats-icon {
  font-size: 22rpx;
}

.stats-text {
  font-size: 22rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-bottom: 32rpx;
  text-align: center;
}

.btn-create {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-create::after {
  border: none;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
}

.loading-spinner.small {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.retry-btn::after {
  border: none;
}

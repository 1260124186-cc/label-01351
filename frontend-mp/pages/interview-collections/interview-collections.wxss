/* pages/interview-collections/interview-collections.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 页面头部 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.create-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  transition: all 0.2s;
}

.create-btn:active {
  transform: scale(0.96);
  background-color: rgba(255, 255, 255, 0.3);
}

.create-icon {
  font-size: 28rpx;
}

.create-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 合集列表 */
.collection-list {
  padding: 24rpx;
}

.collection-card {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.collection-card:active {
  transform: scale(0.98);
}

.card-cover {
  position: relative;
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 30%, rgba(0, 0, 0, 0.6) 100%);
}

.cover-content {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.collection-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.collection-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-content {
  flex: 1;
  padding: 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.card-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.card-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.card-arrow {
  display: flex;
  align-items: center;
  padding-right: 20rpx;
  color: var(--color-text-light);
  font-size: 36rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

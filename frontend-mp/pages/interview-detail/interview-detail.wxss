/* pages/interview-detail/interview-detail.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 受访者档案头部 */
.profile-header {
  display: flex;
  gap: 28rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 0 0 32rpx 32rpx;
}

.profile-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D2B48C 0%, #F5DEB3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #8B4513;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.profile-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.age-tag-large {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  gap: 4rpx;
}

.age-icon {
  margin-right: 4rpx;
}

.profile-basic {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.profile-region {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.separator {
  margin: 0 12rpx;
  color: rgba(255, 255, 255, 0.5);
}

.profile-crafts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.craft-tag-large {
  padding: 6rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 6rpx;
}

/* 通用卡片 */
.section-card {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

/* 访谈信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

/* 访谈摘要 */
.summary-card {
  background: linear-gradient(135deg, #FFF8DC 0%, #FFEFD5 100%);
  border-left: 8rpx solid #DAA520;
}

.summary-content {
  font-size: 28rpx;
  color: #8B4513;
  line-height: 1.8;
  font-style: italic;
}

/* 访谈实录 */
.interview-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dialogue-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.speaker-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
  align-self: flex-start;
}

.speaker-tag.interviewer {
  background-color: rgba(70, 130, 180, 0.15);
  color: #4682B4;
}

.speaker-tag.interviewee {
  background-color: rgba(139, 69, 19, 0.15);
  color: #8B4513;
}

.dialogue-text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
  padding-left: 12rpx;
  border-left: 4rpx solid var(--color-border);
}

/* 相关标签 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background-color: rgba(139, 69, 19, 0.08);
  color: #8B4513;
  font-size: 24rpx;
  border-radius: 20rpx;
}

/* 关联人物卡片 */
.related-figure-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #FAF8F5;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.related-figure-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.figure-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #F0F0F0;
  flex-shrink: 0;
}

.figure-info {
  flex: 1;
  min-width: 0;
}

.figure-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.figure-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.figure-identity-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.figure-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.arrow-icon {
  font-size: 36rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
}

/* 所属专题合集 */
.collections-container {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.collection-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #FAF8F5;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.collection-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.collection-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.collection-info {
  flex: 1;
  min-width: 0;
}

.collection-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.stats-info {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 26rpx;
}

.stat-value {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.action-buttons {
  display: flex;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-end;
  min-width: 0;
}

.like-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #F7F7F7;
  border-radius: 36rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.like-btn.liked {
  background-color: rgba(245, 63, 63, 0.1);
}

.like-btn:active {
  transform: scale(0.95);
}

.like-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.like-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}

.like-btn.liked .like-text {
  color: #F53F3F;
}

.like-count {
  font-size: 22rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 36rpx;
  font-size: 24rpx;
  border: none;
  margin: 0;
  flex-shrink: 0;
  white-space: nowrap;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  background-color: #6B3410;
}

.share-icon {
  font-size: 26rpx;
  flex-shrink: 0;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.retry-btn::after {
  border: none;
}

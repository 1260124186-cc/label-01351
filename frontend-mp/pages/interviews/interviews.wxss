/* pages/interviews/interviews.wxss */
.container {
  min-height: 100vh;
  background-color: #FFF8DC;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-section {
  flex: 1;
}

.main-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.sub-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.create-btn {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 16rpx 24rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  backdrop-filter: blur(10rpx);
}

.create-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.create-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #8B4513;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background-color: #8B4513;
  border-radius: 3rpx;
}

.content {
  padding: 24rpx 32rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 48rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 64rpx;
}

.filter-btn {
  position: relative;
  padding: 12rpx;
  margin-left: 16rpx;
}

.filter-btn.has-filter {
  background-color: #FFF0E5;
  border-radius: 50%;
}

.filter-icon {
  font-size: 32rpx;
}

.filter-count {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  background-color: #F53F3F;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

.filter-panel {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-section {
  margin-bottom: 32rpx;
}

.filter-section:last-child {
  margin-bottom: 24rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s ease;
}

.filter-option.selected {
  background-color: #8B4513;
  color: #fff;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
}

.reset-btn {
  padding: 12rpx 32rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.interview-list {
  margin-top: 8rpx;
}

.interview-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.interview-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.interviewee-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #F5DEB3 0%, #DEB887 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-icon {
  font-size: 48rpx;
}

.interviewee-basic {
  flex: 1;
}

.interviewee-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.interviewee-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.age-tag {
  padding: 4rpx 12rpx;
  background-color: #E8F4FD;
  color: #165DFF;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.occupation-tag {
  padding: 4rpx 12rpx;
  background-color: #F0F5EB;
  color: #00B42A;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.region-badge {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.card-body {
  margin-bottom: 20rpx;
}

.summary {
  font-size: 28rpx;
  color: #4E5969;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.craft-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.craft-tag {
  font-size: 22rpx;
  color: #8B4513;
  background-color: #FFF0E5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #86909C;
}

.collections-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.collections-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more-btn {
  font-size: 26rpx;
  color: #8B4513;
}

.collection-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.collection-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.collection-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.collection-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFF0E5 0%, #FFE4CC 100%);
  border-radius: 16rpx;
}

.collection-info {
  flex: 1;
}

.collection-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.collection-count {
  font-size: 24rpx;
  color: #86909C;
}

.loading {
  text-align: center;
  padding: 32rpx;
  color: #86909C;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx;
  color: #C9CDD4;
  font-size: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #86909C;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #C9CDD4;
}

<view class="page-container">
  <view class="form-section">
    <view class="section-label">想学的技艺 *</view>
    <view class="skill-grid">
      <view
        class="skill-chip {{form.skillType === item.id ? 'active' : ''}}"
        wx:for="{{skillTags}}"
        wx:key="id"
        bindtap="onSkillTypeChange"
        data-id="{{item.id}}"
      >
        {{item.icon}} {{item.name}}
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-label">标题 *</view>
    <input class="form-input" placeholder="如：想学剪纸艺术" value="{{form.title}}" bindinput="onTitleInput" maxlength="30" />
  </view>

  <view class="form-section">
    <view class="section-label">描述 *</view>
    <textarea class="form-textarea" placeholder="详细描述你想学的内容和目标" value="{{form.description}}" bindinput="onDescriptionInput" maxlength="500" />
  </view>

  <view class="form-section">
    <view class="section-label">所在地区 *</view>
    <view class="region-grid">
      <view
        class="region-chip {{form.region === item.id ? 'active' : ''}}"
        wx:for="{{regions}}"
        wx:key="id"
        bindtap="onRegionChange"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-label">时间安排</view>
    <view class="time-grid">
      <view
        class="time-chip {{form.timeCommitment === item.id ? 'active' : ''}}"
        wx:for="{{timeCommitments}}"
        wx:key="id"
        bindtap="onTimeCommitmentChange"
        data-id="{{item.id}}"
      >
        {{item.icon}} {{item.name}}
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-label">标签</view>
    <view class="tag-row">
      <view class="tag-item" wx:for="{{form.tags}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" bindtap="removeTag" data-index="{{index}}">✕</text>
      </view>
    </view>
    <view class="tag-input-row">
      <input class="add-input" placeholder="输入标签" value="{{tagInput}}" bindinput="onTagInput" confirm-type="done" bindconfirm="onTagsChange" maxlength="10" />
      <view class="add-btn small" bindtap="onTagsChange">+</view>
    </view>
  </view>

  <view class="submit-area">
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
      {{submitting ? '提交中...' : '发布想学清单'}}
    </view>
  </view>
</view>

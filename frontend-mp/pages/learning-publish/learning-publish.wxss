.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.skill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-chip {
  padding: 12rpx 20rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.skill-chip.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.region-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.region-chip {
  padding: 12rpx 24rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.region-chip.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.time-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.time-chip {
  padding: 12rpx 20rpx;
  background: var(--color-bg);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.time-chip.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(139, 69, 19, 0.08);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #8B4513;
  gap: 8rpx;
}

.tag-remove {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.tag-input-row {
  display: flex;
  gap: 12rpx;
}

.add-input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.add-btn.small {
  width: 80rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  flex-shrink: 0;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn.disabled {
  opacity: 0.6;
}

<!--pages/login/login.wxml-->
<view class="page-container">
  <view class="login-card">
    <view class="login-header">
      <text class="login-title">欢迎来到乡村文化库</text>
      <text class="login-desc">{{loginMode === 'wechat' ? '微信授权快捷登录' : '昵称登录'}}</text>
    </view>

    <block wx:if="{{loginMode === 'wechat'}}">
      <view class="wechat-login-section">
        <view class="wechat-avatar-section" wx:if="{{wechatStep === 'profile' || wechatStep === 'done'}}">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="wechat-avatar-img" src="{{wechatAvatar || '/assets/icons/home.png'}}" mode="aspectFill" />
            <view class="avatar-edit-hint">点击更换头像</view>
          </button>
          <view class="wechat-nickname-input-wrap">
            <input
              class="wechat-nickname-input"
              type="nickname"
              placeholder="请输入昵称"
              value="{{wechatNickname}}"
              bindinput="onWechatNicknameInput"
              maxlength="20"
            />
          </view>
        </view>

        <view class="wechat-steps" wx:if="{{wechatStep === 'idle'}}">
          <view class="wechat-step-item">
            <view class="step-icon-wrap">
              <text class="step-icon">1</text>
            </view>
            <text class="step-text">微信授权登录</text>
          </view>
          <view class="step-connector"></view>
          <view class="wechat-step-item">
            <view class="step-icon-wrap">
              <text class="step-icon">2</text>
            </view>
            <text class="step-text">获取头像昵称</text>
          </view>
          <view class="step-connector"></view>
          <view class="wechat-step-item">
            <view class="step-icon-wrap">
              <text class="step-icon">3</text>
            </view>
            <text class="step-text">完成登录</text>
          </view>
        </view>

        <button
          class="btn-wechat-login {{wechatLoading ? 'loading' : ''}}"
          bindtap="onWechatLogin"
          disabled="{{wechatLoading}}"
        >
          <text wx:if="{{wechatStep === 'idle'}}">微信一键登录</text>
          <text wx:elif="{{wechatStep === 'logging'}}">授权中...</text>
          <text wx:elif="{{wechatStep === 'profile' || wechatStep === 'done'}}">确认登录</text>
        </button>
      </view>

      <view class="switch-mode">
        <text class="switch-text" bindtap="switchToNickname">使用昵称登录</text>
      </view>
    </block>

    <block wx:else>
      <view class="login-form">
        <view class="form-item">
          <input
            class="form-input"
            placeholder="请输入昵称（至少2个字）"
            value="{{nickname}}"
            bindinput="onNicknameInput"
            maxlength="20"
          />
        </view>

        <button
          class="btn-login {{canLogin ? '' : 'disabled'}}"
          bindtap="onNicknameLogin"
          disabled="{{!canLogin}}"
        >
          登录
        </button>
      </view>

      <view class="switch-mode">
        <text class="switch-text" bindtap="switchToWechat">使用微信登录</text>
      </view>
    </block>
  </view>
</view>

<!--pages/login/login.wxml-->
<view class="page-container">
  <view class="login-card">
    <view class="login-header">
      <text class="login-title">欢迎来到乡村文化库</text>
      <text class="login-desc">请输入昵称登录</text>
    </view>
    
    <view class="login-form">
      <view class="form-item">
        <input 
          class="form-input"
          placeholder="请输入昵称（至少2个字）"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
      
      <button 
        class="btn-login {{canLogin ? '' : 'disabled'}}"
        bindtap="onLogin"
        disabled="{{!canLogin}}"
      >
        登录
      </button>
    </view>
  </view>
</view>

.map-page {
  height: 100vh;
  background: #f5f5f5;
}

.map-container {
  position: relative;
  height: 400rpx;
  width: 100%;
}

.map {
  width: 100%;
  height: 100%;
}

.filter-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.filter-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.filter-text {
  font-size: 26rpx;
  color: #333;
}

.publish-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
}

.publish-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.filter-header {
  background: #fff;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 36rpx;
  color: #999;
}

.filter-list {
  background: #fff;
  height: 60vh;
  padding: 0 24rpx 32rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eee;
}

.filter-item.active {
  background: rgba(139, 69, 19, 0.05);
  margin: 0 -24rpx;
  padding: 24rpx;
}

.cat-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.cat-name {
  font-size: 28rpx;
  color: #333;
}

.landmark-list {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100vh - 400rpx);
  background: #f5f5f5;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.list-header {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  background: #fff;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

.list-content {
  height: calc(100% - 80rpx);
  padding: 16rpx;
}

.landmark-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.landmark-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.landmark-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.landmark-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.landmark-category {
  font-size: 22rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  width: fit-content;
}

.landmark-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.landmark-meta {
  display: flex;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
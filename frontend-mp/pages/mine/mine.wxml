<!--pages/mine/mine.wxml-->
<view class="page-container">
  <!-- 未登录状态 -->
  <view class="login-wrap" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-icon">👤</text>
      <text class="login-text">登录后查看个人信息</text>
      <button class="btn-login" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-content">
        <view class="user-avatar">
          <image wx:if="{{userInfo.avatar}}" class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill" />
          <text wx:else class="avatar-text">{{userInfo.nickname[0] || '用'}}</text>
        </view>
        <view class="user-info">
          <view class="user-name-row">
            <view class="user-name">{{userInfo.nickname}}</view>
            <view class="user-role-tag {{isAdmin ? 'role-admin' : 'role-user'}}">
              {{isAdmin ? '🛡 管理员' : '👤 普通用户'}}
            </view>
          </view>
          <view class="user-signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</view>
          <view class="user-location" wx:if="{{userInfo.location}}">📍 {{userInfo.location}}</view>
          <view class="user-login-type" wx:if="{{userInfo.loginType}}">
            <text class="login-type-tag {{userInfo.loginType === 'wechat' ? 'type-wechat' : 'type-nickname'}}">
              {{userInfo.loginType === 'wechat' ? '🟢 微信登录' : '📝 昵称登录'}}
            </text>
          </view>
        </view>
        <view class="user-edit" bindtap="goToEditProfile">
          <text class="edit-icon">✏️</text>
          <text class="edit-text">编辑</text>
        </view>
      </view>

      <!-- 统计数据 -->
      <view class="user-stats">
        <view class="stat-item">
          <text class="stat-value">{{stats.articleCount}}</text>
          <text class="stat-label">投稿</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.likeCount}}</text>
          <text class="stat-label">获赞</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.viewCount}}</text>
          <text class="stat-label">阅读</text>
        </view>
      </view>

      <!-- 积分与成就卡片 -->
      <view class="achievement-card" bindtap="goToAchievements">
        <view class="achievement-left">
          <view class="achievement-stat">
            <text class="achievement-icon">💎</text>
            <view class="achievement-info">
              <text class="achievement-value">{{userPoints}}</text>
              <text class="achievement-label">积分</text>
            </view>
          </view>
          <view class="achievement-divider"></view>
          <view class="achievement-stat">
            <text class="achievement-icon">🏅</text>
            <view class="achievement-info">
              <text class="achievement-value">{{badgeCount}}/{{totalBadgeCount}}</text>
              <text class="achievement-label">勋章</text>
            </view>
          </view>
        </view>
        <text class="achievement-arrow">›</text>
      </view>

      <!-- 任务中心快捷卡片 -->
      <view class="task-quick-card" bindtap="goToTasks">
        <view class="task-quick-left">
          <view class="task-quick-icon-wrap">
            <text class="task-quick-icon">🎯</text>
          </view>
          <view class="task-quick-info">
            <view class="task-quick-title">
              <text>任务中心</text>
              <view class="task-quick-badge" wx:if="{{claimableCount > 0}}">
                <text>{{claimableCount}}</text>
              </view>
            </view>
            <view class="task-quick-desc">
              <text wx:if="{{sevenDayCurrentDay <= 7}}">七日任务：第 {{sevenDayCurrentDay}} 天</text>
              <text wx:else>完成今日任务赢取奖励</text>
            </view>
          </view>
        </view>
        <text class="task-quick-arrow">›</text>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="goToTasks">
        <view class="action-icon-wrap icon-task">
          <text class="action-icon">🎯</text>
          <view class="unread-badge" wx:if="{{claimableCount > 0}}">
            <text class="badge-text">{{claimableCount > 99 ? '99+' : claimableCount}}</text>
          </view>
        </view>
        <text class="action-text">任务中心</text>
      </view>
      <view class="action-item" bindtap="goToAchievements">
        <view class="action-icon-wrap icon-achievement">
          <text class="action-icon">🏆</text>
        </view>
        <text class="action-text">成就勋章</text>
      </view>
      <view class="action-item" bindtap="goToNotifications">
        <view class="action-icon-wrap">
          <text class="action-icon">🔔</text>
          <view class="unread-badge" wx:if="{{unreadNotificationCount > 0}}">
            <text class="badge-text">{{unreadNotificationCount > 99 ? '99+' : unreadNotificationCount}}</text>
          </view>
        </view>
        <text class="action-text">消息通知</text>
      </view>
      <view class="action-item" bindtap="goToDrafts">
        <view class="action-icon-wrap">
          <text class="action-icon">📝</text>
          <view class="unread-badge" wx:if="{{draftCount > 0}}">
            <text class="badge-text">{{draftCount > 99 ? '99+' : draftCount}}</text>
          </view>
        </view>
        <text class="action-text">草稿箱</text>
      </view>
      <view class="action-item" bindtap="goToFavorites">
        <view class="action-icon-wrap">
          <text class="action-icon">⭐</text>
        </view>
        <text class="action-text">我的收藏</text>
      </view>
      <view class="action-item" bindtap="goToLikes">
        <view class="action-icon-wrap">
          <text class="action-icon">👍</text>
        </view>
        <text class="action-text">我的点赞</text>
      </view>
      <view class="action-item" bindtap="goToMyActivities">
        <view class="action-icon-wrap">
          <text class="action-icon">🎭</text>
        </view>
        <text class="action-text">我的活动</text>
      </view>
      <view class="action-item" bindtap="goToHistory">
        <view class="action-icon-wrap">
          <text class="action-icon">📖</text>
        </view>
        <text class="action-text">阅读历史</text>
      </view>
    </view>

    <!-- 文化基金入口 -->
    <view class="fund-entry-card" bindtap="goToFundProjects">
      <view class="fund-entry-left">
        <view class="fund-icon-wrap">
          <text class="fund-icon">💝</text>
        </view>
        <view class="fund-entry-info">
          <view class="fund-entry-title">
            文化公益基金
            <text class="fund-badge">TRANSPARENT</text>
          </view>
          <view class="fund-entry-desc">公益项目 · 捐赠公示 · 透明公开</view>
        </view>
      </view>
      <text class="fund-entry-arrow">›</text>
    </view>

    <!-- 管理后台入口（仅管理员可见） -->
    <view class="admin-entry-card" wx:if="{{isAdmin}}" bindtap="goToAdmin">
      <view class="admin-entry-left">
        <view class="admin-icon-wrap">
          <text class="admin-icon">🛠</text>
        </view>
        <view class="admin-entry-info">
          <view class="admin-entry-title">
            管理后台
            <text class="admin-badge">ADMIN</text>
          </view>
          <view class="admin-entry-desc">内容审核 · 举报处理 · 数据看板 · 运营配置</view>
        </view>
      </view>
      <text class="admin-entry-arrow">›</text>
    </view>

    <!-- 角色调试工具 -->
    <view class="role-debug-section">
      <view class="debug-header">
        <text class="debug-title">🔧 角色模拟（调试用）</text>
        <text class="debug-hint">填 admin 或 user，写入 Storage 模拟角色切换</text>
      </view>
      <view class="debug-row">
        <input
          class="debug-input"
          placeholder="填 admin 或 user"
          value="{{roleInput}}"
          bindinput="onRoleInput"
        />
        <button class="btn-switch-role" bindtap="onSwitchRole">写入 Storage</button>
      </view>
    </view>

    <!-- 我的投稿 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">我的投稿</text>
        <text class="section-count">共 {{myArticles.length}} 篇</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrap" wx:if="{{!loading && myArticles.length === 0}}">
        <text class="empty-icon">暂无</text>
        <text class="empty-text">还没有投稿</text>
        <button class="btn-publish" bindtap="goToPublish">去投稿</button>
      </view>

      <!-- 文章列表 -->
      <view class="article-list" wx:else>
        <view
          class="article-item"
          wx:for="{{myArticles}}"
          wx:key="id"
        >
          <view class="article-content" bindtap="goToDetail" data-id="{{item.id}}">
            <view class="article-main">
              <view class="article-title">{{item.title}}</view>
              <view class="article-meta">
                <text class="meta-category tag-{{item.category}}">{{item.categoryName}}</text>
                <text class="meta-date">{{item.createTime}}</text>
              </view>
            </view>
            <view class="article-stats">
              <view class="mini-stat">
                <text class="mini-icon">阅读</text>
                <text class="mini-value">{{item.viewCount}}</text>
              </view>
              <view class="mini-stat">
                <text class="mini-icon">点赞</text>
                <text class="mini-value">{{item.likeCount}}</text>
              </view>
            </view>
          </view>
          <view class="article-actions">
            <view class="action-btn edit-btn" catchtap="onEditArticle" data-id="{{item.id}}">
              <text class="action-btn-icon">✏️</text>
              <text class="action-btn-text">编辑</text>
            </view>
            <view class="action-btn delete-btn" catchtap="onDeleteArticle" data-id="{{item.id}}">
              <text class="action-btn-icon">🗑️</text>
              <text class="action-btn-text">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 设置入口 -->
    <view class="settings-entry" bindtap="goToSettings">
      <view class="settings-entry-left">
        <text class="settings-icon">⚙️</text>
        <text class="settings-text">设置</text>
      </view>
      <text class="settings-arrow">›</text>
    </view>

    <!-- 意见反馈入口 -->
    <view class="feedback-entry" bindtap="onFeedbackTap">
      <view class="feedback-entry-left">
        <text class="feedback-icon">📝</text>
        <text class="feedback-text">意见反馈</text>
      </view>
      <text class="feedback-arrow">›</text>
    </view>

    <!-- 意见反馈弹窗 -->
    <view class="feedback-modal {{showFeedbackModal ? 'show' : ''}}">
      <view class="feedback-mask" bindtap="onCloseFeedback"></view>
      <view class="feedback-content">
        <view class="feedback-header">
          <text class="feedback-title">意见反馈</text>
          <view class="feedback-close" bindtap="onCloseFeedback">✕</view>
        </view>
        <view class="feedback-body">
          <view class="feedback-textarea-wrap">
            <textarea
              class="feedback-textarea"
              placeholder="请输入您的反馈内容（5-500字）"
              value="{{feedbackContent}}"
              bindinput="onFeedbackContentInput"
              maxlength="500"
            />
            <text class="feedback-char-count">{{feedbackContent.length}}/500</text>
          </view>
          <view class="feedback-contact-wrap">
            <text class="feedback-contact-label">联系方式（选填）</text>
            <input
              class="feedback-contact-input"
              placeholder="手机号/邮箱/微信号"
              value="{{feedbackContact}}"
              bindinput="onFeedbackContactInput"
              maxlength="50"
            />
          </view>
        </view>
        <view class="feedback-footer">
          <button class="btn-feedback-cancel" bindtap="onCloseFeedback">取消</button>
          <button class="btn-feedback-submit" bindtap="onSubmitFeedback" disabled="{{!feedbackContent.trim() || feedbackContent.trim().length < 5}}">提交反馈</button>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="btn-logout" bindtap="onLogout">退出登录</button>
    </view>
  </block>
</view>

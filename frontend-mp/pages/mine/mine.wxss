/* 勋章墙卡片 */
.badge-wall-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx 28rpx 24rpx;
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 50%, #CE93D8 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(156, 39, 176, 0.25);
  box-shadow: 0 12rpx 36rpx rgba(156, 39, 176, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.badge-wall-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(156, 39, 176, 0.2);
}

.badge-wall-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(156, 39, 176, 0.25) 0%, transparent 70%);
  border-radius: 50%;
}

.badge-wall-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: radial-gradient(circle, rgba(233, 30, 99, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.badge-wall-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.badge-wall-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #6A1B9A;
  letter-spacing: 1rpx;
}

.badge-wall-count {
  display: flex;
  align-items: baseline;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.badge-count-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #8E24AA;
  letter-spacing: 1rpx;
}

.badge-count-total {
  font-size: 22rpx;
  color: #AB47BC;
  margin-left: 4rpx;
}

.badge-wall-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.badge-item {
  width: calc((100% - 48rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 20rpx;
  transition: all 0.25s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.badge-item:active {
  transform: scale(0.92);
}

.badge-item.unlocked {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 6rpx 16rpx rgba(156, 39, 176, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
}

.badge-item.locked {
  opacity: 0.5;
  filter: grayscale(70%);
}

.badge-item.more-badges {
  background: rgba(255, 255, 255, 0.35);
  border: 2rpx dashed rgba(156, 39, 176, 0.35);
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.badge-name {
  font-size: 20rpx;
  color: #6A1B9A;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}


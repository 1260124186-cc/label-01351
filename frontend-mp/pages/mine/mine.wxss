  z-index: 1;
}

.level-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #E65100;
  line-height: 1;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.level-stat-label {
  font-size: 22rpx;
  color: #8B6914;
  font-weight: 500;
}


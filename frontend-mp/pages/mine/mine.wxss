}

/* 等级积分卡片 */
.level-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx 28rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 50%, #FFE082 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 152, 0, 0.25);
  box-shadow: 0 12rpx 36rpx rgba(255, 152, 0, 0.15);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.level-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.2);
}

.level-card::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 193, 7, 0.35) 0%, transparent 70%);
  border-radius: 50%;
}

.level-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255, 87, 34, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

.level-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.level-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.level-badge-icon {
  font-size: 52rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 8rpx rgba(255, 152, 0, 0.3));
}

.level-detail {
  flex: 1;
  min-width: 0;
}

.level-detail .level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #E65100;
  margin-bottom: 8rpx;
  display: block;
  letter-spacing: 1rpx;
}

.level-desc {
  font-size: 22rpx;
  color: #8B6914;
  line-height: 1.4;
  font-weight: 500;
}

.level-points {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6F00;
  line-height: 1;
  letter-spacing: 1rpx;
}

.points-label {
  font-size: 20rpx;
  color: #8B6914;
  margin-top: 6rpx;
  font-weight: 500;
}

.level-progress-bar {
  margin-top: 24rpx;
  height: 14rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 7rpx;
  overflow: hidden;
  position: relative;
  z-index: 1;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}

.level-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9800 0%, #FFC107 50%, #FFD54F 100%);
  border-radius: 7rpx;
  transition: width 0.5s ease;
  position: relative;
}

.level-progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.4), transparent);
  border-radius: 7rpx 7rpx 0 0;
}

.level-stats {
  display: flex;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(255, 152, 0, 0.2);

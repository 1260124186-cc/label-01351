/* pages/mine/mine.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(139, 69, 19, 0.12);
}

.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #8B4513, #CD853F, #DAA520, #CD853F, #8B4513);
  z-index: 1;
}

.user-bg {
  height: 200rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  position: relative;
}

.user-bg::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(to top, rgba(255,255,255,0.3), transparent);
}

.user-content {
  display: flex;
  padding: 24rpx;
  position: relative;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #228B22 0%, #32CD32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(34, 139, 34, 0.3);
  flex-shrink: 0;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.avatar-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.user-login-type {
  margin-top: 8rpx;
}

.login-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.login-type-tag.type-wechat {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
}

.login-type-tag.type-nickname {
  background: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.user-info {
  flex: 1;
  padding: 20rpx 0 20rpx 28rpx;
  min-width: 0;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.user-role-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.role-admin {
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.18) 0%, rgba(255, 193, 7, 0.14) 100%);
  color: #B8860B;
  border: 1rpx solid rgba(218, 165, 32, 0.3);
}

.role-user {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.12) 0%, rgba(139, 69, 19, 0.08) 100%);
  color: #8B4513;
  border: 1rpx solid rgba(139, 69, 19, 0.2);
}

.user-signature {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-location {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-top: 6rpx;
}

.user-welcome {
  font-size: 26rpx;
  color: #888888;
}

.user-id {
  font-size: 26rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.user-edit {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fff8f0 0%, #fff5eb 100%);
  border-radius: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(139, 69, 19, 0.1);
  flex-shrink: 0;
}

.edit-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.edit-text {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: 500;
}

/* 统计数据 */
.user-stats {
  display: flex;
  align-items: center;
  background: linear-gradient(180deg, #fefefe 0%, #faf8f5 100%);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 12rpx;
  line-height: 1;
}

.stat-label {
  font-size: 26rpx;
  color: #888888;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 70rpx;
  background: linear-gradient(180deg, transparent, #e0d5c8, transparent);
}

/* 积分与成就卡片 */
.achievement-card {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 28rpx 28rpx;
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 152, 0, 0.15);
}

.achievement-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.achievement-stat {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.achievement-icon {
  font-size: 40rpx;
}

.achievement-info {
  display: flex;
  flex-direction: column;
}

.achievement-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #E65100;
  line-height: 1.2;
}

.achievement-label {
  font-size: 22rpx;
  color: #8B7355;
  margin-top: 4rpx;
}

.achievement-divider {
  width: 2rpx;
  height: 72rpx;
  background: rgba(255, 152, 0, 0.2);
  margin: 0 10rpx;
}

.achievement-arrow {
  font-size: 36rpx;
  color: #FF8F00;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 任务中心快捷卡片 */
.task-quick-card {
  display: flex;
  align-items: center;
  margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(156, 39, 176, 0.15);
}

.task-quick-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.task-quick-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #9C27B0, #7B1FA2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(156, 39, 176, 0.25);
}

.task-quick-icon {
  font-size: 36rpx;
}

.task-quick-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.task-quick-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.task-quick-title text {
  font-size: 28rpx;
  font-weight: bold;
  color: #6A1B9A;
}

.task-quick-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: #E91E63;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-quick-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.task-quick-desc {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.task-quick-arrow {
  font-size: 36rpx;
  color: #9C27B0;
  font-weight: bold;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  margin: 0 32rpx 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.action-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.icon-task {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFB74D 0%, #FF9800 100%);
}

.icon-achievement {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFD54F 0%, #FFC107 100%);
}

.icon-certificate {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #81C784 0%, #4CAF50 100%);
}

.unread-badge {
  position: absolute;
  top: -10rpx;
  right: -20rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.4);
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.action-text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

/* 区块 */
.section {
  margin: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  background: linear-gradient(90deg, #faf8f5 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0ebe3;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #8B4513, #CD853F);
  border-radius: 3rpx;
}

.section-count {
  font-size: 26rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 36rpx;
  margin-bottom: 24rpx;
  color: #999999;
  font-weight: 500;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.btn-publish {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(139, 69, 19, 0.3);
}

/* 文章列表 */
.article-list {
  padding: 0 36rpx;
}

.article-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f0e8;
  transition: background-color 0.2s;
}

.article-item:last-child {
  border-bottom: none;
}

.article-item:active {
  background-color: #faf8f5;
}

.article-main {
  flex: 1;
  min-width: 0;
}

.article-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-category {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-folklore {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.12) 0%, rgba(139, 69, 19, 0.08) 100%);
  color: #8B4513;
}

.tag-farming {
  background: linear-gradient(135deg, rgba(34, 139, 34, 0.12) 0%, rgba(34, 139, 34, 0.08) 100%);
  color: #228B22;
}

.tag-craft {
  background: linear-gradient(135deg, rgba(70, 130, 180, 0.12) 0%, rgba(70, 130, 180, 0.08) 100%);
  color: #4682B4;
}

.tag-memory {
  background: linear-gradient(135deg, rgba(218, 165, 32, 0.12) 0%, rgba(218, 165, 32, 0.08) 100%);
  color: #B8860B;
}

.meta-date {
  font-size: 24rpx;
  color: #aaaaaa;
}

.article-stats {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 28rpx;
  padding: 8rpx 16rpx;
  background: #faf8f5;
  border-radius: 12rpx;
}

.mini-stat {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.mini-stat:last-child {
  margin-bottom: 0;
}

.mini-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
  color: #999999;
}

.mini-value {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.article-content {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.article-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 20rpx;
  padding-left: 20rpx;
  border-left: 1rpx solid #f0ebe3;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
  min-width: 80rpx;
}

.action-btn:active {
  transform: scale(0.95);
}

.edit-btn {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.08) 0%, rgba(160, 82, 45, 0.06) 100%);
}

.edit-btn:active {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.15) 0%, rgba(160, 82, 45, 0.1) 100%);
}

.delete-btn {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.08) 0%, rgba(255, 77, 79, 0.06) 100%);
}

.delete-btn:active {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.15) 0%, rgba(255, 77, 79, 0.1) 100%);
}

.action-btn-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.action-btn-text {
  font-size: 20rpx;
  color: #666666;
  font-weight: 500;
}

.edit-btn .action-btn-text {
  color: #8B4513;
}

.delete-btn .action-btn-text {
  color: #ff4d4f;
}

/* 关于区块 */
.about-section {
  margin: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.about-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.about-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.about-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.about-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.about-desc {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.8;
  padding-left: 56rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #f5f0e8;
  margin-top: 16rpx;
}

/* 编辑弹窗 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.edit-modal.show {
  opacity: 1;
  visibility: visible;
}

.edit-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.edit-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.85);
  width: 620rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  transition: transform 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.edit-modal.show .edit-content {
  transform: translate(-50%, -50%) scale(1);
}

.edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  background: linear-gradient(90deg, #faf8f5 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0ebe3;
}

.edit-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.edit-close {
  font-size: 40rpx;
  color: #999999;
  padding: 8rpx;
  line-height: 1;
}

.edit-body {
  padding: 48rpx 40rpx;
}

.edit-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  border: 2rpx solid #e0d5c8;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  background: #faf8f5;
  transition: all 0.2s;
}

.edit-input:focus {
  border-color: #8B4513;
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(139, 69, 19, 0.1);
}

.edit-footer {
  display: flex;
  padding: 28rpx 40rpx 36rpx;
  gap: 28rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-cancel {
  background-color: #f5f0e8;
  color: #666666;
}

.btn-confirm {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(139, 69, 19, 0.3);
}


/* 未登录状态 */
.login-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 32rpx;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.12);
}

.login-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 32rpx;
}

.login-text {
  display: block;
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 48rpx;
}

.login-wrap .btn-login {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 退出登录 */
.logout-section {
  margin: 32rpx;
  padding-top: 20rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: 2rpx solid #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 文化基金入口卡片 */
.fund-entry-card {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 60%, #ffd9d9 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.1);
  position: relative;
  overflow: hidden;
}

.fund-entry-card::before {
  content: '';
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 140rpx;
  height: 140rpx;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.25) 0%, transparent 70%);
  border-radius: 50%;
}

.fund-entry-left {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.fund-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
}

.fund-icon {
  font-size: 40rpx;
}

.fund-entry-info {
  flex: 1;
  margin-left: 20rpx;

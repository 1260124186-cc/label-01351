.page-container {
  min-height: 100vh;
  background-color: #FFF8DC;
}

.login-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.login-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.login-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.btn-login {
  width: 400rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  line-height: 88rpx;
}

.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #8B4513;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #8B4513;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-name {
  font-size: 26rpx;
  color: #666666;
}

.tab-item.active .tab-name {
  color: #8B4513;
  font-weight: 500;
}

.tab-content {
  padding: 24rpx;
}

.publish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.publish-hint {
  font-size: 26rpx;
  color: #666666;
}

.btn-publish {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-radius: 32rpx;
}

.publish-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.publish-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #EEEEEE;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.activity-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-content {
  padding: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.type-lecture {
  background: linear-gradient(135deg, rgba(255,179,71,0.15) 0%, rgba(255,204,51,0.15) 100%);
}

.type-study {
  background: linear-gradient(135deg, rgba(135,206,235,0.15) 0%, rgba(70,130,180,0.15) 100%);
}

.type-craft {
  background: linear-gradient(135deg, rgba(222,184,135,0.15) 0%, rgba(210,105,30,0.15) 100%);
}

.header-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.header-type {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.header-status {
  font-size: 22rpx;
  font-weight: 500;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-info {
  margin-bottom: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.register-time {
  font-size: 22rpx;
  color: #999999;
}

.card-footer {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #F5F5F5;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.btn-cancel {
  height: 56rpx;
  padding: 0 32rpx;
  background-color: #FFFFFF;
  color: #FF6B6B;
  font-size: 24rpx;
  border: 1rpx solid #FF6B6B;
  border-radius: 28rpx;
  line-height: 54rpx;
}

.register-tag {
  font-size: 24rpx;
  color: #999999;
}

.register-tag.success {
  color: #52C41A;
}

<view class="page-container">
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === item.key ? 'tab-active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      wx:for-item="item"
      bindtap="onTabChange"
      data-tab="{{item.key}}"
    >
      <text class="tab-text">{{item.name}}</text>
      <view class="tab-indicator" wx:if="{{currentTab === item.key}}"></view>
    </view>
  </view>

  <view class="action-bar" wx:if="{{unreadCount > 0}}">
    <text class="unread-hint">{{unreadCount}} 条未读</text>
    <text class="mark-all-btn" bindtap="onMarkAllRead">全部已读</text>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-wrap" wx:elif="{{notifications.length === 0}}">
    <text class="empty-icon">🔔</text>
    <text class="empty-text">暂无通知消息</text>
  </view>

  <view class="notification-list" wx:else>
    <view
      class="notification-item {{item.isRead ? '' : 'notification-unread'}}"
      wx:for="{{notifications}}"
      wx:key="id"
    >
      <view class="notification-main" bindtap="onNotificationTap" data-id="{{item.id}}">
        <view class="notification-icon-wrap type-{{item.type}}">
          <text class="notification-type-icon">{{item.typeIcon}}</text>
        </view>
        <view class="notification-content">
          <view class="notification-header">
            <text class="notification-type-label">{{item.typeLabel}}</text>
            <text class="notification-time">{{item.timeText}}</text>
          </view>
          <view class="notification-body">
            <text class="notification-text">{{item.content}}</text>
          </view>
          <view class="notification-target" wx:if="{{item.targetTitle}}">
            <text class="notification-target-text">{{item.targetTitle}}</text>
          </view>
        </view>
        <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
      </view>
      <view class="notification-actions">
        <text class="action-delete" bindtap="onDeleteNotification" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>
</view>

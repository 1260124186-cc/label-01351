.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  display: flex;
  flex-direction: column;
}

.login-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 80rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 48rpx;
}

.btn-login {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-login::after {
  border: none;
}

.page-header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 48rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  text-align: center;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.form-container {
  flex: 1;
  padding: 24rpx;
}

.form-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}

.title-hint {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-left: 12rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.label-required {
  color: #F53F3F;
  margin-left: 8rpx;
}

.label-hint {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-left: 12rpx;
}

.form-input-wrap {
  position: relative;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #F7F7F7;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  background-color: #FFFFFF;
  border-color: var(--color-primary);
}

.input-placeholder {
  color: var(--color-text-light);
}

.input-count {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: var(--color-text-light);
}

.form-picker,
.region-picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #F7F7F7;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-text);
}

.picker-placeholder {
  font-size: 28rpx;
  color: var(--color-text-light);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-light);
}

.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tag-chip {
  display: flex;
  align-items: center;
  padding: 10rpx 12rpx 10rpx 20rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border-radius: 32rpx;
}

.chip-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.chip-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  margin-left: 8rpx;
  color: var(--color-primary);
  font-size: 24rpx;
}

.tag-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

.tag-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border: 2rpx solid var(--color-primary);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}

.form-textarea-wrap {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background-color: #F7F7F7;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.2s;
}

.form-textarea:focus {
  background-color: #FFFFFF;
  border-color: var(--color-primary);
}

.textarea-count {
  position: absolute;
  right: 24rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-light);
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #F7F7F7;
  border-radius: 12rpx;
}

.switch-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.region-picker-list {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #F7F7F7;
  border-radius: 12rpx;
}

.region-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.region-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
  min-width: 140rpx;
}

.region-item:active {
  transform: scale(0.96);
}

.region-item.active {
  background-color: rgba(139, 69, 19, 0.1);
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.aria-item {
  border: 2rpx solid var(--color-border);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.aria-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.aria-index {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.aria-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-light);
  font-size: 28rpx;
}

.aria-remove:active {
  color: #F53F3F;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border: 2rpx dashed var(--color-primary);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.add-btn:active {
  background-color: rgba(139, 69, 19, 0.15);
}

.add-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: bold;
}

.add-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.form-tips {
  background-color: rgba(218, 165, 32, 0.1);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.draft-item {
  background-color: #F7F7F7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.draft-item:last-child {
  margin-bottom: 0;
}

.draft-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.draft-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.review-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status-pending {
  background-color: rgba(255, 193, 7, 0.15);
  color: #B8860B;
}

.status-approved {
  background-color: rgba(82, 196, 26, 0.15);
  color: #52C41A;
}

.status-rejected {
  background-color: rgba(245, 63, 63, 0.15);
  color: #F53F3F;
}

.draft-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.draft-genre {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 4rpx 12rpx;
  background-color: rgba(139, 69, 19, 0.1);
  border-radius: 6rpx;
}

.draft-date {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.draft-intro {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.btn-submit::after {
  border: none;
}

.btn-submit.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}

.btn-submit:active:not(.disabled) {
  opacity: 0.9;
}

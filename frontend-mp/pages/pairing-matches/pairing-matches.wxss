.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 40rpx;
}

.header-banner {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.banner-content {
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.match-list {
  padding: 24rpx;
}

.match-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  min-width: 120rpx;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.skill-section {
  flex: 1;
  margin-left: 24rpx;
}

.skill-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(139, 69, 19, 0.1);
  border-radius: 12rpx;
  padding: 6rpx 14rpx;
  margin-bottom: 12rpx;
}

.skill-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.skill-name {
  font-size: 26rpx;
  color: #8B4513;
  font-weight: 500;
}

.region-info {
  display: flex;
  align-items: center;
}

.region-icon {
  font-size: 22rpx;
  margin-right: 4rpx;
}

.region-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.card-body {
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: flex-start;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.user-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.apply-btn {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  border-radius: 32rpx;
  padding: 14rpx 40rpx;
}

.apply-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

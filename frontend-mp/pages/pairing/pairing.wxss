.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: 40rpx;
}

.header-banner {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.banner-content {
  margin-bottom: 20rpx;
}

.banner-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.banner-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

.search-bar {
  padding: 24rpx 24rpx 0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-light);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

.tab-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx 0;
  background-color: #FFFFFF;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 20rpx;
  position: relative;
}

.tab-name {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #8B4513;
  font-weight: bold;
}

.tab-indicator {
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  border-radius: 3rpx;
  margin-top: 8rpx;
}

.skill-scroll {
  white-space: nowrap;
  padding: 20rpx 24rpx 8rpx;
  background-color: #FFFFFF;
  margin: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.skill-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  min-width: 88rpx;
}

.skill-item.active {
  background: rgba(139, 69, 19, 0.1);
}

.skill-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.skill-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.skill-item.active .skill-name {
  color: #8B4513;
  font-weight: 500;
}

.region-scroll {
  white-space: nowrap;
  padding: 12rpx 24rpx 16rpx;
  background-color: #FFFFFF;
  margin: 0 24rpx;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.region-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  margin-right: 12rpx;
  background-color: var(--color-bg);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.region-item.active {
  background: linear-gradient(135deg, #8B4513, #CD853F);
  color: #FFFFFF;
  font-weight: 500;
}

.list-container {
  padding: 0 24rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-light);
}

.teaching-card,
.learning-card,
.pairing-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  margin-top: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  gap: 12rpx;
}

.meta-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.skill-badge {
  background: rgba(139, 69, 19, 0.1);
  color: #8B4513;
}

.method-badge {
  background: rgba(46, 139, 87, 0.1);
  color: #2E8B57;
}

.status-badge {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.card-region {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.region-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.card-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-info-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.info-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.info-text {
  font-size: 24rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 4rpx 12rpx;
  background: rgba(139, 69, 19, 0.06);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #A0522D;
}

.pairing-names {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  padding: 12rpx 0;
}

.pairing-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.pairing-arrow {
  font-size: 28rpx;
  color: #CD853F;
  margin: 0 20rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-light);
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513, #CD853F);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.fab-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.fab-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

.fab-menu-list {
  position: absolute;
  right: 40rpx;
  bottom: 240rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  min-width: 240rpx;
}

.fab-menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
}

.fab-menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.fab-menu-text {
  font-size: 28rpx;
  color: var(--color-text);
}

/* pages/profile-edit/profile-edit.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 160rpx;
}

.edit-section {
  margin: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.avatar-row:active {
  background-color: #faf8f5;
}

.avatar-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #228B22 0%, #32CD32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(34, 139, 34, 0.3);
  overflow: hidden;
}

.avatar-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.field-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
  width: 200rpx;
}

.field-arrow {
  font-size: 36rpx;
  color: #cccccc;
  font-weight: 300;
  line-height: 1;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.field-row:active {
  background-color: #faf8f5;
}

.field-row--top {
  border-bottom: none;
  padding-bottom: 12rpx;
}

.field-right {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
  gap: 12rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333333;
  min-width: 0;
}

.field-input--location {
  max-width: 360rpx;
}

.field-char-count {
  font-size: 22rpx;
  color: #bbbbbb;
  flex-shrink: 0;
}

.char-invalid {
  color: #ff4d4f;
}

.textarea-wrap {
  position: relative;
  padding: 0 36rpx 24rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background: #faf8f5;
  border: 2rpx solid #e0d5c8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.6;
}

.field-textarea:focus {
  border-color: #8B4513;
  background: #ffffff;
}

.textarea-char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 8rpx;
}

.save-section {
  margin: 48rpx 32rpx 0;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(139, 69, 19, 0.3);
}

.btn-save[disabled] {
  background: #cccccc;
  box-shadow: none;
}

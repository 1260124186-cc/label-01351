<!--pages/publish/publish.wxml-->
<view class="page-container">
  <!-- 未登录状态 -->
  <view class="login-wrap" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-icon">👤</text>
      <text class="login-text">登录后即可投稿</text>
      <button class="btn-login" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <block wx:else>
    <!-- 页面标题 -->
    <view class="page-header">
      <text class="header-title">{{isEditingArticle ? '编辑文章' : '分享你的故事'}}</text>
      <text class="header-desc">{{isEditingArticle ? '修改文章内容，保存后立即生效' : '记录乡村记忆，传承文化智慧'}}</text>
    </view>

    <!-- 归属村庄 -->
    <view class="village-info-bar" bindtap="goToVillageSelect">
      <view class="village-info-left">
        <text class="village-info-icon">🏘️</text>
        <view class="village-info-detail">
          <text class="village-info-label">归属村庄</text>
          <text class="village-info-name">{{currentVillage.name || '请选择村庄'}}</text>
        </view>
      </view>
      <text class="village-info-arrow">›</text>
    </view>

    <!-- 表单区域 -->
    <view class="form-container">
      <!-- 标题输入 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">文章标题</text>
          <text class="label-required">*</text>
        </view>
        <view class="form-input-wrap">
          <input
            class="form-input"
            placeholder="请输入文章标题（至少2字）"
            placeholder-class="input-placeholder"
            maxlength="50"
            value="{{formData.title}}"
            bindinput="onTitleInput"
          />
          <text class="input-count">{{formData.title.length}}/50</text>
        </view>
      </view>

      <!-- 分类选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">文章分类</text>
          <text class="label-required">*</text>
        </view>
        <view class="category-list">
          <view
            class="category-option {{formData.category === item.id ? 'active' : ''}}"
            wx:for="{{categories}}"
            wx:key="id"
            wx:if="{{item.id !== 'all'}}"
            bindtap="onCategorySelect"
            data-id="{{item.id}}"
          >
            <text class="option-icon">{{categoryIcons[item.id]}}</text>
            <text class="option-name">{{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- 摘要输入 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">文章摘要</text>
          <text class="label-hint">（选填，不填将自动截取正文前100字）</text>
        </view>
        <view class="form-input-wrap">
          <input
            class="form-input"
            placeholder="一句话概括文章内容（50字内）"
            placeholder-class="input-placeholder"
            maxlength="50"
            value="{{formData.summary}}"
            bindinput="onSummaryInput"
          />
          <text class="input-count">{{formData.summary.length}}/50</text>
        </view>
      </view>

      <!-- 标签选择 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">文章标签</text>
          <text class="label-hint">（选填，1-3个，如 #端午节 #织布）</text>
        </view>

        <!-- 已选标签 -->
        <view class="selected-tags" wx:if="{{formData.tags.length > 0}}">
          <view
            class="tag-item selected"
            wx:for="{{formData.tags}}"
            wx:key="*this"
            wx:for-item="tag"
          >
            <text class="tag-prefix">#</text>
            <text class="tag-text">{{tag}}</text>
            <view class="tag-remove" bindtap="removeTag" data-tag="{{tag}}">
              <text>✕</text>
            </view>
          </view>
        </view>

        <!-- 推荐标签 -->
        <view class="tag-suggest">
          <view class="suggest-label">推荐标签：</view>
          <view class="suggest-list">
            <view
              class="tag-item {{formData.tags.indexOf(item) > -1 ? 'selected' : ''}}"
              wx:for="{{suggestedTags}}"
              wx:key="*this"
              wx:for-item="item"
              bindtap="toggleSuggestedTag"
              data-tag="{{item}}"
            >
              <text class="tag-prefix">#</text>
              <text class="tag-text">{{item}}</text>
            </view>
            <view class="tag-item add" wx:if="{{!showTagInput}}" bindtap="showAddTagInput">
              <text class="tag-text">+ 自定义</text>
            </view>
          </view>
        </view>

        <!-- 自定义标签输入 -->
        <view class="custom-tag-wrap" wx:if="{{showTagInput}}">
          <input
            class="custom-tag-input"
            placeholder="输入自定义标签（10字内）"
            placeholder-class="input-placeholder"
            maxlength="10"
            value="{{tagInput}}"
            bindinput="onTagInputChange"
            confirm-type="done"
            bindconfirm="addCustomTag"
          />
          <view class="tag-action-cancel" bindtap="hideAddTagInput">取消</view>
          <view class="tag-action-confirm" bindtap="addCustomTag">添加</view>
        </view>
      </view>

      <!-- 关联人物 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">关联人物</text>
          <text class="label-hint">（可选）</text>
        </view>

        <!-- 已选择的人物 -->
        <view class="selected-figure" wx:if="{{selectedFigure}}">
          <view class="figure-info">
            <image class="figure-avatar" src="{{selectedFigure.avatar}}" mode="aspectFill" />
            <view class="figure-detail">
              <view class="figure-name-row">
                <text class="figure-name">{{selectedFigure.name}}</text>
                <view class="identity-tag" style="background-color: {{selectedFigure.identityInfo.color}}20; color: {{selectedFigure.identityInfo.color}};">
                  <text class="tag-icon">{{selectedFigure.identityInfo.icon}}</text>
                  <text>{{selectedFigure.identityInfo.name}}</text>
                </view>
              </view>
              <text class="figure-brief">{{selectedFigure.briefIntroduction}}</text>
            </view>
          </view>
          <view class="figure-remove" bindtap="clearSelectedFigure">
            <text>✕</text>
          </view>
        </view>

        <!-- 人物选择区域 -->
        <block wx:else>
          <!-- 搜索框 -->
          <view class="figure-search-wrap" wx:if="{{showFigureSelector}}">
            <view class="search-input-wrap">
              <text class="search-icon">🔍</text>
              <input
                class="search-input"
                placeholder="搜索人物姓名"
                placeholder-class="input-placeholder"
                value="{{figureSearchKeyword}}"
                bindinput="onFigureSearchInput"
              />
              <text class="search-clear" wx:if="{{figureSearchKeyword}}" bindtap="clearFigureSearch">✕</text>
            </view>
          </view>

          <!-- 人物列表 -->
          <view class="figure-list" wx:if="{{showFigureSelector}}">
            <scroll-view scroll-y style="max-height: 400rpx;">
              <view
                class="figure-option"
                wx:for="{{filteredFigures}}"
                wx:key="id"
                bindtap="onFigureSelect"
                data-figure="{{item}}"
              >
                <image class="option-avatar" src="{{item.avatar}}" mode="aspectFill" />
                <view class="option-info">
                  <view class="option-name-row">
                    <text class="option-figure-name">{{item.name}}</text>
                    <text class="option-identity" style="color: {{item.identityInfo.color}};">{{item.identityInfo.icon}} {{item.identityInfo.name}}</text>
                  </view>
                  <text class="option-figure-brief">{{item.briefIntroduction}}</text>
                </view>
              </view>
              <view class="empty-figures" wx:if="{{filteredFigures.length === 0}}">
                <text class="empty-text">未找到相关人物</text>
              </view>
            </scroll-view>
          </view>

          <!-- 操作按钮 -->
          <view class="figure-actions">
            <view class="action-btn primary" bindtap="toggleFigureSelector">
              <text class="action-icon">👥</text>
              <text class="action-text">{{showFigureSelector ? '收起选择' : '选择已有传承人'}}</text>
            </view>
            <view class="action-btn secondary" bindtap="goToCreateFigure">
              <text class="action-icon">➕</text>
              <text class="action-text">新建人物草稿</text>
            </view>
          </view>
        </block>
      </view>

      <!-- 内容输入 -->
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">文章内容</text>
          <text class="label-required">*</text>
        </view>
        <view class="form-textarea-wrap">
          <textarea
            class="form-textarea"
            placeholder="请输入文章内容（至少10字）"
            placeholder-class="input-placeholder"
            maxlength="5000"
            value="{{formData.content}}"
            bindinput="onContentInput"
            auto-height
          />
          <text class="textarea-count">{{formData.content.length}}/5000</text>
        </view>
      </view>

      <!-- 提示信息 -->
      <view class="form-tips">
        <view class="tip-item">
          <text class="tip-icon">💡</text>
          <text class="tip-text">内容需原创，禁止抄袭或发布违规信息</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">📝</text>
          <text class="tip-text">建议分段书写，让文章更易阅读</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">🔍</text>
          <text class="tip-text">发布前可点击「预览」查看排版效果</text>
        </view>
      </view>

      <!-- 发布按钮 -->
      <view class="form-actions">
        <button class="btn-draft" bindtap="onSaveDraft" disabled="{{savingDraft || isEditingArticle}}" wx:if="{{!isEditingArticle}}">
          <text wx:if="{{savingDraft}}">保存中...</text>
          <text wx:elif="{{isEditingDraft}}">更新草稿</text>
          <text wx:else>保存草稿</text>
        </button>
        <button class="btn-preview" bindtap="onPreview" disabled="{{!canSubmit}}" wx:if="{{!isEditingArticle}}">
          <text>预览排版</text>
        </button>
        <button
          class="btn-publish {{isEditingArticle ? 'btn-save' : ''}}"
          bindtap="onSubmit"
          disabled="{{!canSubmit || submitting}}"
        >
          <text wx:if="{{submitting && isEditingArticle}}">保存中...</text>
          <text wx:elif="{{submitting}}">发布中...</text>
          <text wx:elif="{{isEditingArticle}}">保存修改</text>
          <text wx:else>发布文章</text>
        </button>
      </view>
    </view>
  </block>
</view>

<!-- 预览弹窗 -->
<view class="preview-modal {{showPreview ? 'show' : ''}}" wx:if="{{showPreview}}">
  <view class="preview-mask" bindtap="closePreview"></view>
  <view class="preview-container">
    <view class="preview-header">
      <text class="preview-title">文章预览</text>
      <view class="preview-close" bindtap="closePreview">
        <text>✕</text>
      </view>
    </view>
    <scroll-view class="preview-body" scroll-y>
      <view class="preview-article">
        <view class="preview-category tag-{{previewData.category}}">
          {{previewData.categoryName}}
        </view>
        <view class="preview-article-title">{{previewData.title}}</view>
        <view class="preview-meta">
          <text class="preview-author">{{previewData.authorName}}</text>
          <text class="preview-date">{{previewData.createTime}}</text>
        </view>
        <view class="preview-summary" wx:if="{{previewData.summary}}">
          <text class="summary-label">摘要：</text>
          <text class="summary-text">{{previewData.summary}}</text>
        </view>
        <view class="preview-tags" wx:if="{{previewData.tags && previewData.tags.length > 0}}">
          <view
            class="preview-tag-item"
            wx:for="{{previewData.tags}}"
            wx:key="*this"
            wx:for-item="tag"
          >
            <text>#{{tag}}</text>
          </view>
        </view>
        <view class="preview-divider"></view>
        <view class="preview-content">{{previewData.content}}</view>
      </view>
    </scroll-view>
    <view class="preview-footer">
      <button class="btn-preview-back" bindtap="closePreview">返回修改</button>
      <button class="btn-preview-publish" bindtap="onSubmit" disabled="{{submitting}}">
        <text wx:if="{{submitting && isEditingArticle}}">保存中...</text>
        <text wx:elif="{{submitting}}">发布中...</text>
        <text wx:elif="{{isEditingArticle}}">确认保存</text>
        <text wx:else>确认发布</text>
      </button>
    </view>
  </view>
</view>

<!-- 发布成功弹窗 -->
<view class="success-modal {{showSuccess ? 'show' : ''}}" wx:if="{{showSuccess}}">
  <view class="success-mask"></view>
  <view class="success-content">
    <text class="success-icon">🎉</text>
    <text class="success-title">发布成功</text>
    <text class="success-desc">感谢你的分享，让更多人了解乡村文化</text>
    <view class="success-actions">
      <button class="btn-continue" bindtap="continuePublish">继续投稿</button>
      <button class="btn-view" bindtap="goToHome">查看文章</button>
    </view>
  </view>
</view>

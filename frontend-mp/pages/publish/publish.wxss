/* pages/publish/publish.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 120rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  text-align: center;
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
  letter-spacing: 2rpx
}

/* 表单容器 */
.form-container {
  padding: 32rpx;
}

/* 表单项 */
.form-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.label-required {
  color: #ff4d4f;
  margin-left: 8rpx;
}

/* 输入框 */
.form-input-wrap {
  position: relative;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 100rpx 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: var(--color-secondary);
}

.input-placeholder {
  color: var(--color-text-light);
}

.input-count {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 分类选择 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-option {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  background-color: var(--color-bg);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.category-option.active {
  background-color: rgba(34, 139, 34, 0.1);
  border-color: var(--color-secondary);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.option-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.category-option.active .option-name {
  color: var(--color-secondary);
  font-weight: 500;
}

/* 文本域 */
.form-textarea-wrap {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 24rpx;
  padding-bottom: 60rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.8;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.form-textarea:focus {
  border-color: var(--color-secondary);
}

.textarea-count {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 提示信息 */
.form-tips {
  background-color: rgba(34, 139, 34, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 发布按钮 */
.form-actions {
  padding: 0 16rpx;
}

.btn-publish {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #228B22 0%, #2E8B57 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(34, 139, 34, 0.3);
}

.btn-publish.disabled {
  background: #cccccc;
  box-shadow: none;
}

.btn-publish:active:not(.disabled) {
  transform: scale(0.98);
}

/* 成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.success-modal.show {
  opacity: 1;
  visibility: visible;
}

.success-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.success-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: transform 0.3s;
}

.success-modal.show .success-content {
  transform: translate(-50%, -50%) scale(1);
}

.success-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.success-actions {
  display: flex;
  gap: 24rpx;
}

.btn-continue,
.btn-view {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-continue {
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
}

.btn-view {
  background-color: var(--color-secondary);
  color: #FFFFFF;
}


/* 未登录状态 */
.login-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 32rpx;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.12);
}

.login-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 32rpx;
}

.login-text {
  display: block;
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 48rpx;
}

.btn-login {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* pages/publish/publish.wxss */

.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #faf8f5 100%);
  padding-bottom: 120rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  text-align: center;
  padding: 40rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
  letter-spacing: 2rpx
}

/* 归属村庄 */
.village-info-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  margin: -20rpx 24rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.village-info-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.village-info-icon {
  font-size: 40rpx;
}

.village-info-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.village-info-label {
  font-size: 22rpx;
  color: #999;
}

.village-info-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.village-info-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 表单容器 */
.form-container {
  padding: 32rpx;
}

/* 表单项 */
.form-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.label-required {
  color: #ff4d4f;
  margin-left: 8rpx;
}

.label-hint {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-left: 12rpx;
}

/* 输入框 */
.form-input-wrap {
  position: relative;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 100rpx 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.form-input:focus {
  border-color: var(--color-secondary);
}

.input-placeholder {
  color: var(--color-text-light);
}

.input-count {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 分类选择 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-option {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  background-color: var(--color-bg);
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.category-option.active {
  background-color: rgba(34, 139, 34, 0.1);
  border-color: var(--color-secondary);
}

.option-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.option-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.category-option.active .option-name {
  color: var(--color-secondary);
  font-weight: 500;
}

/* 文本域 */
.form-textarea-wrap {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 24rpx;
  padding-bottom: 60rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.8;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.form-textarea:focus {
  border-color: var(--color-secondary);
}

.textarea-count {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 提示信息 */
.form-tips {
  background-color: rgba(34, 139, 34, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 标签样式 */
.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #f5f0e8;
  border: 2rpx solid transparent;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.tag-item.selected {
  background-color: rgba(34, 139, 34, 0.1);
  border-color: var(--color-secondary);
}

.tag-item.add {
  background-color: rgba(139, 69, 19, 0.08);
  border: 2rpx dashed rgba(139, 69, 19, 0.3);
  color: var(--color-primary);
}

.tag-prefix {
  font-size: 24rpx;
  color: var(--color-secondary);
  margin-right: 4rpx;
}

.tag-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.tag-item.selected .tag-text {
  color: var(--color-secondary);
  font-weight: 500;
}

.tag-item.add .tag-text {
  color: var(--color-primary);
}

.tag-remove {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-light);
}

.tag-suggest {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggest-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.suggest-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.custom-tag-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-tag-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 36rpx;
  font-size: 26rpx;
  background-color: #faf8f5;
  box-sizing: border-box;
}

.tag-action-cancel {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.tag-action-confirm {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  background-color: var(--color-secondary);
  color: #FFFFFF;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 发布按钮 */
.form-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 16rpx;
}

.btn-draft {
  width: 200rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border: 2rpx solid #8B4513;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #8B4513;
  box-sizing: border-box;
}

.btn-draft[disabled] {
  border-color: #cccccc;
  color: #cccccc;
}

.btn-preview {
  width: 200rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border: 2rpx solid var(--color-secondary);
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-secondary);
  box-sizing: border-box;
}

.btn-preview[disabled] {
  border-color: #cccccc;
  color: #cccccc;
}

.btn-publish {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #228B22 0%, #2E8B57 100%);
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(34, 139, 34, 0.3);
}

.btn-publish[disabled] {
  background: #cccccc;
  box-shadow: none;
}

/* 预览弹窗 */
.preview-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.preview-modal.show {
  opacity: 1;
  visibility: visible;
}

.preview-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.preview-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 85vh;
  background-color: #faf8f5;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.preview-modal.show .preview-container {
  transform: translateY(0);
}

.preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.preview-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.preview-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.9);
  font-size: 36rpx;
}

.preview-body {
  flex: 1;
  overflow: hidden;
  padding: 32rpx;
}

.preview-article {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  min-height: 100%;
}

.preview-category {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.preview-article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.preview-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 28rpx;
}

.preview-author {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}

.preview-date {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.preview-summary {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background-color: rgba(139, 69, 19, 0.05);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.summary-label {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-right: 8rpx;
}

.summary-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.preview-tag-item {
  display: inline-flex;
  padding: 10rpx 20rpx;
  background-color: rgba(34, 139, 34, 0.08);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--color-secondary);
  font-weight: 500;
}

.preview-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  margin-bottom: 28rpx;
}

.preview-content {
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 2;
  white-space: pre-wrap;
  text-align: justify;
}

.preview-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.btn-preview-back {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f0e8;
  color: var(--color-text-secondary);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-preview-publish {
  flex: 1.5;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #228B22 0%, #2E8B57 100%);
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(34, 139, 34, 0.3);
}

.btn-preview-publish[disabled] {
  background: #cccccc;
  box-shadow: none;
}

.btn-publish.disabled {
  background: #cccccc;
  box-shadow: none;
}

.btn-publish:active:not(.disabled) {
  transform: scale(0.98);
}

/* 成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.success-modal.show {
  opacity: 1;
  visibility: visible;
}

.success-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.success-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: transform 0.3s;
}

.success-modal.show .success-content {
  transform: translate(-50%, -50%) scale(1);
}

.success-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.success-actions {
  display: flex;
  gap: 24rpx;
}

.btn-continue,
.btn-view {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-continue {
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
}

.btn-view {
  background-color: var(--color-secondary);
  color: #FFFFFF;
}


/* 未登录状态 */
.login-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 32rpx;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(139, 69, 19, 0.12);
}

.login-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 32rpx;
}

.login-text {
  display: block;
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 48rpx;
}

.btn-login {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 已选择的人物 */
.selected-figure {
  display: flex;
  align-items: flex-start;
  background-color: rgba(139, 69, 19, 0.05);
  border: 2rpx solid rgba(139, 69, 19, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  position: relative;
}

.figure-info {
  display: flex;
  flex: 1;
  gap: 16rpx;
}

.figure-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #F0F0F0;
  flex-shrink: 0;
}

.figure-detail {
  flex: 1;
  min-width: 0;
}

.figure-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.figure-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}

.identity-tag {
  display: flex;
  align-items: center;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-icon {
  margin-right: 4rpx;
}

.figure-brief {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.figure-remove {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-light);
  font-size: 28rpx;
  flex-shrink: 0;
}

.figure-remove:active {
  color: #F53F3F;
}

/* 人物搜索 */
.figure-search-wrap {
  margin-bottom: 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #F7F7F7;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
  background-color: transparent;
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 8rpx;
}

/* 人物列表 */
.figure-list {
  margin-bottom: 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
}

.figure-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.2s;
}

.figure-option:last-child {
  border-bottom: none;
}

.figure-option:active {
  background-color: #F7F7F7;
}

.option-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F0F0F0;
  flex-shrink: 0;
}

.option-info {
  flex: 1;
  min-width: 0;
}

.option-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.option-figure-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.option-identity {
  font-size: 22rpx;
}

.option-figure-brief {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.empty-figures {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* 人物操作按钮 */
.figure-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.action-btn.primary {
  background-color: rgba(139, 69, 19, 0.1);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.action-btn.secondary {
  background-color: #F7F7F7;
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
}

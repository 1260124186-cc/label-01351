.page-container {
  min-height: 100vh;
  background: #FFF8DC;
  padding: 30rpx;
  padding-bottom: 200rpx;
}

.loading-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ddd;
  border-top-color: #8B4513;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .empty-text {
  font-size: 26rpx;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.quiz-header {
  margin-bottom: 30rpx;
}

.header-badge {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FAAD14, #FFD666);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}

.badge-icon { font-size: 32rpx; margin-right: 10rpx; }
.badge-text { font-size: 26rpx; color: #fff; font-weight: bold; }

.quiz-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f0e6;
}

.meta-icon { font-size: 24rpx; margin-right: 6rpx; }
.meta-name { font-size: 22rpx; color: #666; }

.diff-level { font-size: 22rpx; color: #666; margin-right: 8rpx; }
.diff-score { font-size: 22rpx; color: #8B4513; font-weight: bold; }

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.question-text {
  font-size: 34rpx;
  line-height: 1.6;
  color: #333;
  font-weight: 500;
}

.options-list {
  margin-bottom: 32rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.option-item.selected {
  border-color: #8B4513;
  background: #fdf8f0;
}

.option-item.correct {
  border-color: #52C41A;
  background: #f6ffed;
}

.option-item.wrong {
  border-color: #FF4D4F;
  background: #fff2f0;
}

.option-radio {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-radio {
  background: #8B4513;
}

.option-item.correct .option-radio { background: #52C41A; }
.option-item.wrong .option-radio { background: #FF4D4F; }

.radio-inner {
  font-size: 28rpx;
  color: #999;
  font-weight: bold;
}

.option-item.selected .radio-inner,
.option-item.correct .radio-inner,
.option-item.wrong .radio-inner { color: #fff; }

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

.option-icon {
  font-size: 36rpx;
  color: #52C41A;
  font-weight: bold;
}

.option-icon.wrong { color: #FF4D4F; }

.result-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #52C41A, #73D13D);
}

.result-header.wrong {
  background: linear-gradient(135deg, #FF7875, #FFA39E);
}

.result-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
}

.result-info { flex: 1; }

.result-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.result-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.analysis-box {
  padding: 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.analysis-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.related-box {
  padding: 32rpx;
}

.related-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.related-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.related-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.related-info { flex: 1; }

.related-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.related-cat {
  font-size: 20rpx;
  color: #999;
}

.related-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.submit-btn.disabled {
  background: #ddd !important;
  color: #fff !important;
}

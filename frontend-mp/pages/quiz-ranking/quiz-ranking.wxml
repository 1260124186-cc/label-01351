<view class="page-container">
  <view class="top-bar">
    <view class="back-btn" bindtap="onBack">‹</view>
    <text class="page-title">🏆 知识排行榜</text>
    <view class="dummy"></view>
  </view>

  <view class="tabs-wrap">
    <view class="tabs">
      <view class="tab {{activeTab === 'weekly' ? 'active' : ''}}" data-type="weekly" bindtap="switchTab">
        <text class="tab-icon">📅</text>
        <text class="tab-text">周榜</text>
      </view>
      <view class="tab {{activeTab === 'total' ? 'active' : ''}}" data-type="total" bindtap="switchTab">
        <text class="tab-icon">👑</text>
        <text class="tab-text">总榜</text>
      </view>
    </view>
  </view>

  <view class="podium" wx:if="{{!loading}}">
    <view class="podium-row" wx:if="{{podiumItems.length > 0}}">
      <view class="podium-item second" wx:if="{{podiumItems[1]}}">
        <view class="p-avatar silver" style="background: {{podiumItems[1].avatarBgColor}}">
          {{podiumItems[1].initial}}
        </view>
        <text class="p-name">{{podiumItems[1].nickname}}</text>
        <view class="p-score">{{podiumItems[1].score}}</view>
        <text class="p-medal">🥈</text>
      </view>
      <view class="podium-item first" wx:if="{{podiumItems[0]}}">
        <text class="p-crown">👑</text>
        <view class="p-avatar gold" style="background: {{podiumItems[0].avatarBgColor}}">
          {{podiumItems[0].initial}}
        </view>
        <text class="p-name">{{podiumItems[0].nickname}}</text>
        <view class="p-score">{{podiumItems[0].score}}</view>
        <text class="p-medal">🥇</text>
      </view>
      <view class="podium-item third" wx:if="{{podiumItems[2]}}">
        <view class="p-avatar bronze" style="background: {{podiumItems[2].avatarBgColor}}">
          {{podiumItems[2].initial}}
        </view>
        <text class="p-name">{{podiumItems[2].nickname}}</text>
        <view class="p-score">{{podiumItems[2].score}}</view>
        <text class="p-medal">🥉</text>
      </view>
    </view>
  </view>

  <view class="rank-list-wrap">
    <view class="loading" wx:if="{{loading}}">加载中...</view>
    <block wx:elif="{{displayList.length > 0}}">
      <view class="rank-item" wx:for="{{displayList}}" wx:key="id" wx:for-index="ri">
        <view class="rank-left">
          <view class="rank-num {{ri < 3 ? 'top' : ''}}">
            <text wx:if="{{ri < 3}}">{{ri === 0 ? '🥇' : ri === 1 ? '🥈' : '🥉'}}</text>
            <text wx:else>{{ri + 1}}</text>
          </view>
          <view class="rank-avatar" style="background: {{item.avatarBgColor}}">
            {{item.initial}}
          </view>
          <view class="rank-info">
            <text class="rank-name">{{item.nickname}}</text>
            <text class="rank-meta">答题 {{item.answerCount}} 题 · 正确率 {{item.accuracy}}%</text>
          </view>
        </view>
        <view class="rank-right">
          <text class="rank-score">{{item.score}}</text>
          <text class="rank-unit">分</text>
        </view>
      </view>
    </block>
    <view class="empty" wx:else>暂无数据，快去答题吧！</view>
  </view>

  <view class="my-rank-bar" wx:if="{{!loading && myRankItem}}">
    <view class="my-rank-left">
      <text class="mr-label">我的排名</text>
      <text class="mr-num">#{{myRankItem.rank}}</text>
    </view>
    <view class="my-rank-right">
      <text class="mr-score">{{myRankItem.score}}</text>
      <text class="mr-unit">分</text>
    </view>
  </view>
</view>

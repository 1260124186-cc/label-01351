.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8DC 0%, #FFEFD6 100%);
  padding-bottom: 200rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.back-btn {
  font-size: 56rpx;
  color: #8B4513;
  width: 60rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.dummy { width: 60rpx; }

.tabs-wrap { padding: 10rpx 30rpx 30rpx; }

.tabs {
  display: flex;
  background: #fff;
  border-radius: 44rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #8B4513, #A0522D);
}

.tab-icon { font-size: 32rpx; margin-right: 8rpx; }

.tab-text { font-size: 28rpx; color: #666; }
.tab.active .tab-text { color: #fff; font-weight: bold; }

.podium {
  padding: 40rpx 30rpx 20rpx;
}

.podium-row {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 20rpx;
  min-height: 360rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  border-radius: 24rpx 24rpx 8rpx 8rpx;
  padding: 30rpx 20rpx;
  position: relative;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.podium-item.first {
  width: 220rpx;
  height: 340rpx;
  background: linear-gradient(180deg, #FFFBF0 0%, #FFF8DC 100%);
  border: 4rpx solid #FFD700;
}

.podium-item.second {
  height: 280rpx;
  background: linear-gradient(180deg, #F7FAFC 0%, #EDF2F7 100%);
  border: 4rpx solid #C0C0C0;
}

.podium-item.third {
  height: 240rpx;
  background: linear-gradient(180deg, #FFF5F0 0%, #FFEBD9 100%);
  border: 4rpx solid #CD7F32;
}

.p-crown {
  position: absolute;
  top: -40rpx;
  font-size: 60rpx;
}

.p-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.p-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.p-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF7A45;
  margin-bottom: 8rpx;
}

.p-medal { font-size: 40rpx; }

.rank-list-wrap { padding: 0 30rpx; }
.loading { text-align: center; padding: 80rpx; color: #999; font-size: 26rpx; }

.rank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rank-left { display: flex; align-items: center; flex: 1; }

.rank-num {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-num.top {
  background: transparent;
  font-size: 44rpx;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-info { display: flex; flex-direction: column; flex: 1; min-width: 0; }
.rank-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rank-meta { font-size: 22rpx; color: #999; }

.rank-right {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.rank-score {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF7A45;
}

.rank-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }

.my-rank-bar {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  background: linear-gradient(135deg, #8B4513, #A0522D);
  border-radius: 50rpx;
  padding: 28rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.3);
}

.my-rank-left { display: flex; align-items: center; }
.mr-label { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-right: 16rpx; }
.mr-num { font-size: 36rpx; font-weight: bold; color: #FFD666; }

.my-rank-right { display: flex; align-items: baseline; }
.mr-score { font-size: 40rpx; font-weight: bold; color: #fff; }
.mr-unit { font-size: 22rpx; color: rgba(255,255,255,0.85); margin-left: 4rpx; }

.page-container {
  min-height: 100vh;
  background: #FFF8DC;
  padding-bottom: 200rpx;
}

.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0; }
.loading-spinner {
  width: 60rpx; height: 60rpx; border: 4rpx solid #ddd; border-top-color: #8B4513;
  border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 20rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 26rpx; color: #999; }

.timed-header {
  padding: 30rpx 30rpx 20rpx;
}

.time-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.time-display.urgent .time-num {
  color: #FF4D4F;
  animation: blink 0.8s infinite;
}

@keyframes blink {
  50% { opacity: 0.5; }
}

.time-icon { font-size: 40rpx; margin-right: 12rpx; }
.time-num { font-size: 56rpx; font-weight: bold; color: #8B4513; }

.progress-info { text-align: center; }
.progress-text { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }

.progress-bar {
  height: 10rpx; background: #eee; border-radius: 5rpx; overflow: hidden;
}

.progress-fill {
  height: 100%; background: linear-gradient(90deg, #8B4513, #A0522D);
  border-radius: 5rpx; transition: width 0.3s;
}

.question-card {
  margin: 10rpx 30rpx 30rpx;
  background: #fff; border-radius: 24rpx; padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.q-meta { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.q-tag { padding: 6rpx 16rpx; border-radius: 14rpx; font-size: 20rpx; background: #f5f0e6; color: #8B4513; }
.q-tag.diff { background: #e6f7ff; color: #1890FF; }
.q-text { font-size: 34rpx; line-height: 1.6; color: #333; font-weight: 500; }

.options-list { padding: 0 30rpx; margin-bottom: 30rpx; }

.option-item {
  display: flex; align-items: center; background: #fff; border-radius: 20rpx;
  padding: 28rpx 24rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04); border: 4rpx solid transparent;
}

.option-item.selected { border-color: #8B4513; background: #fdf8f0; }

.option-radio {
  width: 56rpx; height: 56rpx; border-radius: 50%; background: #f5f5f5;
  display: flex; align-items: center; justify-content: center;
  margin-right: 20rpx; flex-shrink: 0;
}
.option-item.selected .option-radio { background: #8B4513; }
.radio-inner { font-size: 28rpx; color: #999; font-weight: bold; }
.option-item.selected .radio-inner { color: #fff; }
.option-text { flex: 1; font-size: 30rpx; color: #333; line-height: 1.5; }

.action-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex; gap: 20rpx;
}

.nav-btn {
  flex: 1; height: 88rpx; line-height: 88rpx;
  background: #f5f5f5; color: #333; font-size: 30rpx;
  border-radius: 44rpx; border: none;
}
.nav-btn.primary { background: linear-gradient(135deg, #8B4513, #A0522D); color: #fff; }
.nav-btn.submit { background: linear-gradient(135deg, #F5222D, #FF7875); color: #fff; }
.nav-btn.disabled { opacity: 0.5; }

.result-wrap { padding: 40rpx 30rpx 200rpx; }

.result-hero.timed-hero {
  background: linear-gradient(135deg, #FA8C16, #FFA940);
  border-radius: 32rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 40rpx;
}

.hero-emoji { font-size: 100rpx; display: block; margin-bottom: 16rpx; }
.hero-title { display: block; font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 32rpx; }

.hero-stats { display: flex; justify-content: space-around; flex-wrap: wrap; }
.hero-stat { display: flex; flex-direction: column; align-items: center; min-width: 120rpx; }
.stat-val { font-size: 36rpx; font-weight: bold; color: #FFD666; margin-bottom: 8rpx; }
.stat-lbl { font-size: 22rpx; color: rgba(255, 255, 255, 0.85); }

.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }

.detail-item {
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.detail-head { display: flex; align-items: center; margin-bottom: 16rpx; }
.detail-num {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: #52C41A; color: #fff; font-size: 26rpx;
  display: flex; align-items: center; justify-content: center; margin-right: 16rpx;
}
.detail-num.wrong { background: #FF4D4F; }
.detail-status { font-size: 24rpx; color: #8B4513; font-weight: bold; }
.detail-q { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 16rpx; }

.detail-analysis {
  font-size: 24rpx; color: #666; line-height: 1.8;
  padding: 16rpx; background: #fffbe6; border-radius: 12rpx; margin-bottom: 12rpx;
}
.a-label { color: #8B4513; font-weight: bold; }
.a-user { color: #333; font-weight: bold; }
.a-correct { color: #52C41A; font-weight: bold; }

.rel-link {
  display: inline-flex; align-items: center; padding: 12rpx 20rpx;
  background: #e6f7ff; border-radius: 20rpx; margin-top: 8rpx;
}
.rel-icon { font-size: 24rpx; margin-right: 8rpx; }
.rel-text { font-size: 22rpx; color: #1890FF; }

.result-actions {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff; box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex; gap: 20rpx;
}

.r-btn {
  flex: 1; height: 88rpx; line-height: 88rpx;
  border-radius: 44rpx; font-size: 30rpx; border: none;
}
.r-btn.secondary { background: #f5f5f5; color: #333; }
.r-btn.primary { background: linear-gradient(135deg, #8B4513, #A0522D); color: #fff; }

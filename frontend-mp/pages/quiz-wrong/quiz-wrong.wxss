.page-container {
  min-height: 100vh;
  background: #FFF8DC;
  padding-bottom: 60rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.back-btn { font-size: 56rpx; color: #8B4513; width: 60rpx; }
.page-title { font-size: 36rpx; font-weight: bold; color: #333; }
.dummy { width: 60rpx; }

.smart-banner {
  margin: 10rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FF7A45, #FFA940);
  border-radius: 24rpx;
  padding: 32rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 69, 0.3);
}

.smart-left { display: flex; align-items: center; flex: 1; }

.smart-icon { font-size: 60rpx; margin-right: 20rpx; }

.smart-texts { display: flex; flex-direction: column; }
.smart-title { font-size: 30rpx; font-weight: bold; color: #fff; margin-bottom: 6rpx; }
.smart-desc { font-size: 22rpx; color: rgba(255,255,255,0.9); }

.smart-arrow { font-size: 48rpx; color: rgba(255,255,255,0.85); }

.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 0 30rpx 30rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.stat-card.active {
  border-color: #8B4513;
  background: #fdf8f0;
}

.stat-num { font-size: 48rpx; font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.stat-num.warning { color: #FAAD14; }
.stat-num.success { color: #52C41A; }
.stat-label { font-size: 22rpx; color: #999; }

.list-wrap { padding: 0 30rpx; }
.loading { text-align: center; padding: 80rpx; color: #999; font-size: 26rpx; }

.empty-state {
  background: #fff;
  border-radius: 24rpx;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-emoji { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: bold; color: #333; display: block; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #999; }

.wrong-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.item-tags { display: flex; flex-wrap: wrap; gap: 10rpx; flex: 1; }

.tag {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  background: #f5f0e6;
  color: #8B4513;
}

.tag.diff { background: #e6f7ff; color: #1890FF; }
.tag.times { background: #fff2f0; color: #FF4D4F; }
.tag.status.ok { background: #f6ffed; color: #52C41A; }
.tag.status.warn { background: #fffbe6; color: #FAAD14; }

.expand-icon { font-size: 28rpx; color: #999; margin-left: 16rpx; }

.item-body {
  padding: 28rpx 24rpx;
}

.item-q {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.item-detail {
  padding: 0 24rpx 24rpx;
  border-top: 2rpx solid #f5f5f5;
}

.detail-section {
  padding: 20rpx 0;
  border-bottom: 2rpx dashed #f0f0f0;
}

.detail-section:last-of-type { border-bottom: none; }

.detail-section.links { padding-bottom: 0; }

.sec-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 8rpx;
  display: block;
}

.sec-val {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.sec-val.wrong { color: #FF4D4F; }
.sec-val.correct { color: #52C41A; font-weight: bold; }

.link-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #e6f7ff;
  border-radius: 18rpx;
  margin-top: 12rpx;
}

.link-icon { font-size: 24rpx; margin-right: 8rpx; }
.link-text { font-size: 22rpx; color: #1890FF; }

.item-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
}

.act-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.act-btn.secondary {
  background: linear-gradient(135deg, #52C41A, #73D13D);
}

.act-btn.danger {
  background: #fff2f0;
  border: 2rpx solid #FFCCC7;
}

.act-icon { font-size: 26rpx; margin-right: 8rpx; }

.act-text { font-size: 24rpx; color: #fff; }
.act-btn.danger .act-text { color: #FF4D4F; }

.tag.cat-folklore { background: #fff0f6; color: #EB2F96; }
.tag.cat-agriculture { background: #f6ffed; color: #52C41A; }
.tag.cat-craft { background: #fffbe6; color: #FAAD14; }
.tag.cat-history { background: #e6f7ff; color: #1890FF; }
.tag.cat-literature { background: #f9f0ff; color: #722ED1; }
.tag.cat-food { background: #fff7e6; color: #FA8C16; }

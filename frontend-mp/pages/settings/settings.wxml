<view class="page-container">
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.general}}</text>
    </view>

    <view class="setting-item" bindtap="onTapLanguage">
      <view class="setting-left">
        <text class="setting-icon">🌐</text>
        <text class="setting-label">{{t.language}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{languageName}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📖</text>
        <text class="setting-label">{{t.dialect}}</text>
      </view>
      <view class="setting-right">
        <switch
          checked="{{showDialectAnnotation}}"
          bindchange="onToggleDialectAnnotation"
          color="#8B4513"
        />
      </view>
    </view>

    <view class="setting-item" bindtap="onClearCache">
      <view class="setting-left">
        <text class="setting-icon">🗑️</text>
        <text class="setting-label">{{t.clearCache}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{cacheSize}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item" bindtap="onRestoreDefaultData">
      <view class="setting-left">
        <text class="setting-icon">🔄</text>
        <text class="setting-label">{{t.restoreDefault}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.devMode}}</text>
    </view>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">🔌</text>
        <text class="setting-label">{{t.remoteDataSource}}</text>
      </view>
      <view class="setting-right">
        <switch
          checked="{{useRemote}}"
          bindchange="onSwitchDataSource"
          color="#8B4513"
        />
      </view>
    </view>

    <view class="setting-item" bindtap="onToggleBaseUrlEdit">
      <view class="setting-left">
        <text class="setting-icon">🌐</text>
        <text class="setting-label">{{t.serverUrl}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{baseUrl}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="base-url-edit" wx:if="{{showBaseUrlEdit}}">
      <input
        class="url-input"
        placeholder="请输入服务地址"
        value="{{baseUrlInput}}"
        bindinput="onBaseUrlInput"
      />
      <button class="btn-save-url" bindtap="onSaveBaseUrl">保存</button>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.about}}</text>
    </view>

    <view class="setting-item" bindtap="goToAbout">
      <view class="setting-left">
        <text class="setting-icon">ℹ️</text>
        <text class="setting-label">{{t.aboutUs}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item" bindtap="goToUserAgreement">
      <view class="setting-left">
        <text class="setting-icon">📄</text>
        <text class="setting-label">{{t.userAgreement}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item" bindtap="goToPrivacyPolicy">
      <view class="setting-left">
        <text class="setting-icon">🔒</text>
        <text class="setting-label">{{t.privacyPolicy}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item" bindtap="goToBlockedList">
      <view class="setting-left">
        <text class="setting-icon">🚫</text>
        <text class="setting-label">拉黑管理</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{blockCount}} 位用户</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item" bindtap="goToMyReports">
      <view class="setting-left">
        <text class="setting-icon">🚩</text>
        <text class="setting-label">我的举报</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">{{reportCount}} 条</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📌</text>
        <text class="setting-label">{{t.version}}</text>
      </view>
      <view class="setting-right">
        <text class="setting-value">v{{version}}</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">乡村文化库 · 传承乡村记忆</text>
  </view>

  <view class="language-picker {{showLanguagePicker ? 'show' : ''}}">
    <view class="picker-mask" bindtap="onCloseLanguagePicker"></view>
    <view class="picker-content">
      <view class="picker-header">
        <text class="picker-title">{{t.language}}</text>
        <view class="picker-close" bindtap="onCloseLanguagePicker">✕</view>
      </view>
      <view class="picker-body">
        <view
          class="picker-item {{language === item.value ? 'selected' : ''}}"
          wx:for="{{languageOptions}}"
          wx:key="value"
          bindtap="onSelectLanguage"
          data-lang="{{item.value}}"
        >
          <text class="item-text">{{item.name}}</text>
          <text class="item-check" wx:if="{{language === item.value}}">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>

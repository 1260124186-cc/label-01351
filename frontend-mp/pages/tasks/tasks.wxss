.container {
  min-height: 100vh;
  background: #FFF8DC;
  padding-bottom: 40rpx;
}

.loading-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: #8B4513;
  font-size: 32rpx;
}

.header-card {
  position: relative;
  margin: 0;
  padding: 40rpx 30rpx 60rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #8B4513 0%, #CD853F 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.user-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 36rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.15);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
}

.stat-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #8B4513;
}

.stat-label {
  font-size: 24rpx;
  color: #8B7355;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #E8DCC8;
  align-self: center;
}

.tabs-bar {
  display: flex;
  padding: 0 30rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.tab-item {
  flex: 1;
  background: white;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #E8DCC8;
  transition: all 0.3s ease;
}

.tab-item:first-child {
  border-top-left-radius: 16rpx;
  border-bottom-left-radius: 16rpx;
}

.tab-item:last-child {
  border-top-right-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #CD853F, #8B4513);
  border-color: #8B4513;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-name {
  color: white;
}

.tab-name {
  font-size: 24rpx;
  color: #5D4037;
  font-weight: 500;
}

.tab-content {
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D4037;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8B7355;
}

.seven-day-progress {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
}

.progress-track {
  height: 12rpx;
  background: #F5E6D3;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB74D, #FF8A65);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.progress-dots {
  display: flex;
  justify-content: space-between;
  padding: 0 8rpx;
}

.day-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5E6D3;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-dot.current {
  background: linear-gradient(135deg, #FF8A65, #FF5722);
  box-shadow: 0 4rpx 12rpx rgba(255, 87, 34, 0.4);
  transform: scale(1.15);
}

.day-dot.done {
  background: linear-gradient(135deg, #81C784, #4CAF50);
}

.day-dot.locked {
  opacity: 0.5;
}

.day-num {
  font-size: 22rpx;
  color: #8B7355;
  font-weight: bold;
}

.day-dot.current .day-num,
.day-dot.done .day-num {
  color: white;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
  border-left: 8rpx solid #CD853F;
  transition: all 0.3s ease;
}

.task-card.current-day {
  border-left-color: #FF5722;
  box-shadow: 0 6rpx 20rpx rgba(255, 87, 34, 0.15);
}

.task-card.locked {
  opacity: 0.6;
}

.task-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.task-day-tag {
  background: linear-gradient(135deg, #FF8A65, #FF5722);
  color: white;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.locked-tag {
  background: #9E9E9E;
}

.status-tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.status-tag.done {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-tag.claimable {
  background: #FFF3E0;
  color: #E65100;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.status-tag.pending {
  background: #E3F2FD;
  color: #1565C0;
}

.task-body {
  display: flex;
  margin-bottom: 20rpx;
}

.task-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3E2723;
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-desc {
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.5;
  margin-bottom: 16rpx;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-progress-bar {
  flex: 1;
  height: 8rpx;
  background: #F5E6D3;
  border-radius: 4rpx;
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFB74D, #FF8A65);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.task-progress-text {
  font-size: 22rpx;
  color: #8B7355;
  min-width: 60rpx;
  text-align: right;
  font-weight: bold;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #E8DCC8;
}

.task-reward {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.reward-text {
  font-size: 22rpx;
  color: #8B7355;
}

.reward-chip {
  background: #FFF8E1;
  color: #E65100;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.badge-chip {
  background: linear-gradient(135deg, #FCE4EC, #F8BBD9);
  color: #AD1457;
}

.task-actions {
  display: flex;
  gap: 12rpx;
}

.claim-btn {
  background: linear-gradient(135deg, #FFB74D, #FF8A65);
  color: white;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: bold;
  border: none;
  line-height: 1.4;
}

.claim-btn::after {
  border: none;
}

.go-btn {
  background: white;
  color: #8B4513;
  border: 2rpx solid #CD853F;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.4;
}

.go-btn::after {
  border: none;
}

.go-btn.small {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
}

.claimed-btn {
  background: #E0E0E0;
  color: #9E9E9E;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  border: none;
  line-height: 1.4;
}

.claimed-btn::after {
  border: none;
}

.empty-state {
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #5D4037;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.5;
}

.festival-card {
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(139, 69, 19, 0.12);
}

.festival-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx dashed rgba(139, 69, 19, 0.2);
}

.festival-icon {
  font-size: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.festival-info {
  flex: 1;
  min-width: 0;
}

.festival-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B0000;
  margin-bottom: 8rpx;
  word-break: break-all;
  line-height: 1.3;
}

.festival-desc {
  font-size: 24rpx;
  color: #8B4513;
  line-height: 1.5;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.festival-tasks {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.festival-task {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 24rpx;
}

.festival-task.claimed {
  opacity: 0.7;
}

.ft-body {
  margin-bottom: 16rpx;
}

.ft-info {
  flex: 1;
}

.ft-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 8rpx;
  line-height: 1.4;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ft-desc {
  font-size: 22rpx;
  color: #8B7355;
  margin-bottom: 12rpx;
  line-height: 1.5;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ft-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ft-progress-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(139, 69, 19, 0.1);
  border-radius: 3rpx;
  overflow: hidden;
}

.ft-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #E57373, #D32F2F);
  border-radius: 3rpx;
}

.ft-progress-text {
  font-size: 20rpx;
  color: #8B7355;
  min-width: 50rpx;
  text-align: right;
  font-weight: bold;
}

.ft-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed rgba(139, 69, 19, 0.1);
}

.ft-reward {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.ft-action {
  display: flex;
  flex-shrink: 0;
}

.onboarding-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.08);
}

.onboarding-progress {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.ob-progress-track {
  flex: 1;
  height: 16rpx;
  background: #F5E6D3;
  border-radius: 8rpx;
  overflow: hidden;
}

.ob-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #A5D6A7, #66BB6A);
  border-radius: 8rpx;
}

.ob-progress-text {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: bold;
  min-width: 80rpx;
  text-align: right;
}

.ob-steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.ob-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
}

.ob-step.done {
  background: #E8F5E9;
}

.ob-step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #BDBDBD;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.ob-step.done .ob-step-dot {
  background: linear-gradient(135deg, #66BB6A, #43A047);
}

.ob-step-info {
  flex: 1;
  min-width: 0;
}

.ob-step-title {
  font-size: 26rpx;
  color: #3E2723;
  font-weight: 500;
  margin-bottom: 4rpx;
  line-height: 1.4;
  word-break: break-all;
}

.ob-step-desc {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ob-step-status {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  flex-shrink: 0;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.status-dot.green {
  background: #4CAF50;
}

.status-dot.gray {
  background: #BDBDBD;
}

.go-ob-btn {
  width: 100%;
  margin-top: 10rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  background: white;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  margin: 0 60rpx;
  width: 80%;
  max-width: 600rpx;
  text-align: center;
}

.modal-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5D4037;
  margin-bottom: 30rpx;
}

.reward-display {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.rd-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.rd-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.rd-text {
  font-size: 32rpx;
  color: #E65100;
  font-weight: bold;
}

.rd-badge-info {
  text-align: left;
  flex: 1;
  min-width: 0;
}

.rd-badge-name {
  display: block;
  font-size: 30rpx;
  color: #AD1457;
  font-weight: bold;
  margin-bottom: 6rpx;
  line-height: 1.3;
  word-break: break-all;
}

.rd-badge-desc {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
  word-break: break-all;
}

.btn-primary {
  background: linear-gradient(135deg, #CD853F, #8B4513);
  color: white;
  border-radius: 50rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.3);
}

.btn-primary::after {
  border: none;
}

.modal-btn {
  margin-top: 20rpx;
}

.festival-reward {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFEBEE 100%);
}

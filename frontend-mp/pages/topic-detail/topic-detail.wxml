<view class="page-container">
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{topic}}">
    <view class="topic-hero">
      <view class="hero-cover">
        <text class="cover-emoji">📚</text>
      </view>
      <view class="hero-content">
        <view class="topic-category tag-{{topic.category}}">
          {{topic.category === 'festival' ? '节日专题' : topic.category === 'craft' ? '技艺专题' : topic.category === 'custom' ? '民俗专题' : topic.category === 'figure' ? '人物专题' : '文化专题'}}
        </view>
        <view class="topic-title">{{topic.title}}</view>
        <view class="topic-meta">
          <text class="meta-item">👤 {{topic.authorName}}</text>
          <text class="meta-item">📅 {{topic.createTime}}</text>
        </view>
        <view class="topic-stats">
          <view class="stat-item">
            <text class="stat-value">{{topic.viewCount}}</text>
            <text class="stat-label">阅读</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{topic.articleCount}}</text>
            <text class="stat-label">文章</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{topic.likeCount}}</text>
            <text class="stat-label">点赞</text>
          </view>
        </view>
      </view>
    </view>

    <view class="topic-intro">
      <view class="section-title">导语</view>
      <view class="intro-content">{{topic.introduction}}</view>
      <view class="topic-tags" wx:if="{{topic.tags && topic.tags.length > 0}}">
        <view class="tag-item" wx:for="{{topic.tags}}" wx:key="*this">
          #{{item}}
        </view>
      </view>
    </view>

    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === 'articles' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="articles"
      >
        文章列表
      </view>
      <view 
        class="tab-item {{activeTab === 'extended' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="extended"
      >
        延伸阅读
      </view>
      <view 
        class="tab-item {{activeTab === 'related' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="related"
      >
        相关专题
      </view>
    </view>

    <view class="tab-content">
      <block wx:if="{{activeTab === 'articles'}}">
        <view wx:if="{{topic.articleList && topic.articleList.length > 0}}">
          <view 
            class="article-card"
            wx:for="{{topic.articleList}}"
            wx:key="id"
            bindtap="goToArticle"
            data-id="{{item.id}}"
          >
            <view class="article-header">
              <view class="article-category tag-{{item.category}}">
                {{item.categoryName}}
              </view>
              <text class="article-date">{{item.createTime}}</text>
            </view>
            <view class="article-title">{{item.title}}</view>
            <view class="article-content">{{item.summary}}</view>
            <view class="article-footer">
              <view class="article-author">
                <text class="author-icon">👤</text>
                <text class="author-name">{{item.authorName}}</text>
              </view>
              <view class="article-stats">
                <text class="stat-icon">👁</text>
                <text class="stat-value">{{item.viewCount}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-wrap" wx:else>
          <text class="empty-icon">📝</text>
          <text class="empty-text">暂无相关文章</text>
        </view>
      </block>

      <block wx:elif="{{activeTab === 'extended'}}">
        <view wx:if="{{topic.extendedReading && topic.extendedReading.length > 0}}">
          <view 
            class="reading-card"
            wx:for="{{topic.extendedReading}}"
            wx:key="title"
            bindtap="openExternal"
            data-url="{{item.url}}"
          >
            <view class="reading-icon">📖</view>
            <view class="reading-info">
              <view class="reading-title">{{item.title}}</view>
              <view class="reading-source">来源：{{item.source}}</view>
            </view>
            <text class="reading-arrow">→</text>
          </view>
        </view>
        <view class="empty-wrap" wx:else>
          <text class="empty-icon">📚</text>
          <text class="empty-text">暂无延伸阅读</text>
        </view>
      </block>

      <block wx:elif="{{activeTab === 'related'}}">
        <view wx:if="{{topic.relatedTopics && topic.relatedTopics.length > 0}}">
          <view class="related-topics">
            <view 
              class="related-card"
              wx:for="{{topic.relatedTopics}}"
              wx:key="id"
              bindtap="goToTopic"
              data-id="{{item.id}}"
            >
              <view class="related-cover">
                <text class="cover-emoji">📖</text>
              </view>
              <view class="related-info">
                <view class="related-title">{{item.title}}</view>
                <view class="related-meta">{{item.articleCount}}篇文章</view>
              </view>
            </view>
          </view>
        </view>
        <view class="empty-wrap" wx:else>
          <text class="empty-icon">🔗</text>
          <text class="empty-text">暂无相关专题</text>
        </view>
      </block>
    </view>
  </block>

  <view class="empty-wrap" wx:else>
    <text class="empty-icon">📚</text>
    <text class="empty-text">专题不存在</text>
  </view>

  <view class="bottom-bar" wx:if="{{topic}}">
    <view class="action-item" bindtap="onFavorite">
      <text class="action-icon">⭐</text>
      <text class="action-text">收藏</text>
    </view>
    <view class="action-item" bindtap="onLike">
      <text class="action-icon">👍</text>
      <text class="action-text">点赞</text>
    </view>
    <button class="share-btn" open-type="share">
      <text class="share-icon">📤</text>
      <text class="share-text">分享</text>
    </button>
  </view>
</view>

/* pages/village-select/village-select.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 60rpx 30rpx 50rpx;
  color: #fff;
}

.header-title {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.title-main {
  font-size: 44rpx;
  font-weight: bold;
}

.title-sub {
  font-size: 26rpx;
  opacity: 0.9;
}

.current-village {
  background: #fff;
  margin: -20rpx 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.current-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.current-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.village-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #f5deb3 0%, #daa520 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.village-emoji {
  font-size: 40rpx;
}

.village-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.village-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.village-level {
  font-size: 22rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.village-level.county {
  color: #2e8b57;
  background: rgba(46, 139, 87, 0.1);
}

.village-level.city {
  color: #4169e1;
  background: rgba(65, 105, 225, 0.1);
}

.current-tag {
  background: #8B4513;
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

.featured-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-title-desc {
  font-size: 24rpx;
  color: #999;
}

.featured-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
}

.featured-list {
  display: inline-flex;
  gap: 20rpx;
}

.featured-item {
  width: 280rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: inline-block;
  vertical-align: top;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.featured-item.active {
  border-color: #8B4513;
}

.featured-banner {
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.featured-emoji {
  font-size: 48rpx;
}

.featured-info {
  padding: 20rpx;
  white-space: normal;
}

.featured-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.featured-slogan {
  font-size: 22rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level-tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.level-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.level-tab.active {
  color: #8B4513;
  font-weight: bold;
}

.level-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #8B4513;
  border-radius: 2rpx;
}

.village-list {
  height: calc(100vh - 500rpx);
  padding: 0 30rpx;
}

.village-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.village-item.selected {
  border-color: #8B4513;
  background: rgba(139, 69, 19, 0.02);
}

.village-avatar-lg {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f5deb3 0%, #daa520 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.village-content {
  flex: 1;
  min-width: 0;
}

.village-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.village-header .village-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.village-level-tag {
  font-size: 20rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.village-level-tag.county {
  color: #2e8b57;
  background: rgba(46, 139, 87, 0.1);
}

.village-level-tag.city {
  color: #4169e1;
  background: rgba(65, 105, 225, 0.1);
}

.village-intro {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.village-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.village-check {
  width: 48rpx;
  height: 48rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
